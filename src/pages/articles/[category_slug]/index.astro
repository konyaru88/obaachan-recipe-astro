---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import articlesData from '../../../data/articles.json';

const categoryMeta: Record<string, { name: string; en: string; heroBg: string; description: string; intro: string }> = {
  teshigoto: {
    name: '季節の手仕事',
    en: 'Seasonal Craft',
    heroBg: '手仕事',
    description: 'たくあん、梅干し、味噌づくり。昔ながらの保存食や季節の仕込みもののレシピと知恵をまとめました。',
    intro: 'たくあん、梅干し、味噌——昔ながらの保存食や季節の仕込みもの。おばあちゃんが毎年繰り返してきた手仕事の知恵を、初心者にもわかるようにまとめました。',
  },
  life: {
    name: '暮らしのレシピ帖',
    en: 'Life Recipe',
    heroBg: '暮らし',
    description: '一人暮らし、体調がすぐれないとき、忙しい日の夕飯。暮らしの場面に寄り添うおばあちゃんのレシピまとめ。',
    intro: '一人暮らし、体調がすぐれないとき、忙しい日の夕飯。暮らしの場面に寄り添うおばあちゃんのレシピをまとめました。',
  },
  story: {
    name: 'おばあちゃんのストーリー',
    en: "Grandma's Story",
    heroBg: '物語',
    description: '台所の記憶、煮物の匂い、あの小さな椅子。おばあちゃんにまつわる暮らしのエピソード。',
    intro: '台所の記憶、煮物の匂い、あの小さな椅子。おばあちゃんにまつわる暮らしのエピソードを綴ります。',
  },
  column: {
    name: '食文化コラム',
    en: 'Food Culture',
    heroBg: '文化',
    description: '目分量の科学、発酵の仕組み、郷土料理の歴史。おばあちゃんの料理を深く知るためのコラム。',
    intro: '目分量の科学、発酵の仕組み、郷土料理の歴史。おばあちゃんの料理を少し深く知るためのコラムです。',
  },
};

export function getStaticPaths() {
  return ['teshigoto', 'life', 'story', 'column'].map((slug) => ({ params: { category_slug: slug } }));
}

const { category_slug } = Astro.params;
const base = import.meta.env.BASE_URL;
const meta = categoryMeta[category_slug!];

if (!meta) {
  return Astro.redirect('/404');
}

const articles = articlesData
  .filter((a: any) => a.category_slug === category_slug)
  .sort((a: any, b: any) => b.published_at.localeCompare(a.published_at));

const siteUrl = 'https://www.obaachan-recipe.com';
const pageUrl = `${siteUrl}/articles/${category_slug}/`;
const pageTitle = `${meta.name}の記事一覧｜おばあちゃんのレシピ`;
---

<BaseLayout
  title={pageTitle}
  description={meta.description}
  canonicalUrl={pageUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "CollectionPage",
          "name": meta.name,
          "description": meta.description,
          "url": pageUrl,
          "isPartOf": { "@id": `${siteUrl}/#website` },
          "numberOfItems": articles.length
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "ホーム", "item": siteUrl },
            { "@type": "ListItem", "position": 2, "name": "読み物", "item": `${siteUrl}/articles/` },
            { "@type": "ListItem", "position": 3, "name": meta.name, "item": pageUrl },
          ],
        }
      ]
    })} />
  </Fragment>
  <Header />

  <main id="main" class="articles-cat-page">

    <!-- Breadcrumb -->
    <nav class="articles-cat-page__breadcrumb" aria-label="パンくずリスト">
      <div class="articles-cat-page__breadcrumb-inner">
        <a href={base}>ホーム</a>
        <span aria-hidden="true"> › </span>
        <a href={`${base}articles/`}>読み物</a>
        <span aria-hidden="true"> › </span>
        <span aria-current="page">{meta.name}</span>
      </div>
    </nav>

    <!-- Hero -->
    <section class="articles-cat-page__hero" aria-labelledby="cat-title">
      <span class="articles-cat-page__hero-bg" aria-hidden="true">{meta.heroBg}</span>
      <p class="articles-cat-page__hero-en">{meta.en}</p>
      <h1 class="articles-cat-page__title" id="cat-title">{meta.name}</h1>
      <p class="articles-cat-page__intro">{meta.intro}</p>
      <p class="articles-cat-page__count">{articles.length}記事</p>
    </section>

    <!-- Article list -->
    <div class="articles-cat-page__list">
      {articles.length > 0 ? (
        articles.map((article: any) => {
          const date = article.published_at.replace(/-/g, '.').slice(2);
          return (
            <a
              href={`${base}articles/${article.id}/`}
              class="articles-cat-page__card"
              data-category-slug={article.category_slug}
            >
              <div class="articles-cat-page__card-thumb" aria-hidden="true">
                <span class="articles-cat-page__card-emoji">{article.thumbnail_emoji}</span>
              </div>
              <div class="articles-cat-page__card-body">
                <span class="articles-cat-page__card-cat">{article.category}</span>
                <h2 class="articles-cat-page__card-title" set:html={article.title.replace(/\n/g, '<br />')} />
                <p class="articles-cat-page__card-desc">{article.lead}</p>
                <div class="articles-cat-page__card-meta">
                  <time datetime={article.published_at}>{date}</time>
                  <span>約{article.reading_time}分で読める</span>
                </div>
              </div>
              <span class="articles-cat-page__card-arrow" aria-hidden="true">→</span>
            </a>
          );
        })
      ) : (
        <div class="articles-cat-page__empty">
          <p class="articles-cat-page__empty-icon" aria-hidden="true">📖</p>
          <p class="articles-cat-page__empty-msg">まだ記事がありません。</p>
        </div>
      )}
    </div>

    <div class="articles-cat-page__back">
      <a href={`${base}articles/`} class="articles-cat-page__back-btn" data-cta="articles-category-back">← 読み物一覧にもどる</a>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  .articles-cat-page {
    font-family: 'Noto Sans JP', sans-serif;
    color: #222;
    background: #f0ece4;
    padding-bottom: 3rem;
  }

  /* Breadcrumb */
  .articles-cat-page__breadcrumb {
    padding: 1rem 5% 0.3rem;
  }
  .articles-cat-page__breadcrumb-inner {
    max-width: 1000px;
    margin: 0 auto;
    font-size: 0.68rem;
    color: #999;
    letter-spacing: 0.04em;
  }
  .articles-cat-page__breadcrumb a {
    color: #999;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .articles-cat-page__breadcrumb a:hover { color: #222; }
  .articles-cat-page__breadcrumb span { margin: 0 0.1em; }

  /* Hero */
  .articles-cat-page__hero {
    position: relative;
    overflow: hidden;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2.5rem 5% 1.8rem;
    text-align: left;
  }
  .articles-cat-page__hero-bg {
    position: absolute;
    top: 50%;
    right: 5%;
    transform: translateY(-50%);
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(6rem, 18vw, 13rem);
    font-weight: 800;
    color: rgba(0, 0, 0, 0.04);
    pointer-events: none;
    user-select: none;
    line-height: 1;
    z-index: 0;
    white-space: nowrap;
  }
  .articles-cat-page__hero-en {
    position: relative;
    z-index: 1;
    margin: 0 0 0.4rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    color: #aaa;
  }
  .articles-cat-page__title {
    position: relative;
    z-index: 1;
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #222;
  }
  .articles-cat-page__intro {
    position: relative;
    z-index: 1;
    margin: 0.7rem 0 0.6rem;
    max-width: 640px;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.86rem;
    line-height: 2;
    color: #777;
    text-wrap: pretty;
  }
  .articles-cat-page__count {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 0.68rem;
    color: #999;
    letter-spacing: 0.08em;
  }

  /* List */
  .articles-cat-page__list {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1rem 5% 2rem;
  }

  .articles-cat-page__card {
    display: flex;
    align-items: stretch;
    gap: 1.4rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid #e0dcd4;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.25s ease;
  }
  .articles-cat-page__card:hover {
    opacity: 0.72;
  }
  .articles-cat-page__card:hover .articles-cat-page__card-arrow {
    color: #222;
    transform: translateX(4px);
  }
  .articles-cat-page__card:focus-visible {
    outline: 2px solid #222;
    outline-offset: 4px;
    opacity: 1;
  }

  .articles-cat-page__card-thumb {
    flex-shrink: 0;
    width: 110px;
    height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1px solid #e0dcd4;
  }
  .articles-cat-page__card-emoji {
    font-size: 2.4rem;
    line-height: 1;
  }

  .articles-cat-page__card-body {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .articles-cat-page__card-cat {
    font-size: 0.62rem;
    color: #999;
    letter-spacing: 0.12em;
  }
  .articles-cat-page__card-title {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.55;
    letter-spacing: 0.03em;
    color: #222;
  }
  .articles-cat-page__card-desc {
    margin: 0;
    font-size: 0.78rem;
    color: #777;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .articles-cat-page__card-meta {
    margin-top: auto;
    display: flex;
    gap: 0.8rem;
    font-size: 0.68rem;
    color: #999;
    letter-spacing: 0.05em;
  }
  .articles-cat-page__card-arrow {
    align-self: center;
    flex-shrink: 0;
    font-size: 0.9rem;
    color: #ccc;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  /* Empty */
  .articles-cat-page__empty {
    max-width: 520px;
    margin: 2rem auto;
    padding: 2.5rem 1.5rem;
    text-align: center;
    background: #fff;
    border: 1px solid #e0dcd4;
  }
  .articles-cat-page__empty-icon {
    margin: 0 0 0.6rem;
    font-size: 2.2rem;
    line-height: 1;
  }
  .articles-cat-page__empty-msg {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    color: #666;
  }

  /* Back */
  .articles-cat-page__back {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.5rem 5% 2.5rem;
    text-align: center;
  }
  .articles-cat-page__back-btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #222;
    background: transparent;
    border: 1.5px solid #222;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
  }
  .articles-cat-page__back-btn:hover {
    background: #222;
    color: #f0ece4;
  }

  @media (max-width: 640px) {
    .articles-cat-page__hero {
      padding: 1.5rem 5% 1.2rem;
    }
    .articles-cat-page__intro {
      font-size: 0.82rem;
    }
    .articles-cat-page__card {
      gap: 1rem;
      padding: 1.1rem 0;
    }
    .articles-cat-page__card-thumb {
      width: 80px;
      height: 80px;
    }
    .articles-cat-page__card-emoji {
      font-size: 1.8rem;
    }
    .articles-cat-page__card-title {
      font-size: 0.92rem;
    }
    .articles-cat-page__card-desc {
      font-size: 0.74rem;
    }
    .articles-cat-page__card-meta {
      font-size: 0.64rem;
      gap: 0.6rem;
    }
    .articles-cat-page__card-arrow {
      display: none;
    }
  }
</style>
