---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes } from '../../data/recipes';
import { t, localePath, areaLabel } from '../../i18n/index';
import recipesEnData from '../../data/recipes.en.json';

const lang = 'en';
const base = import.meta.env.BASE_URL;
const enMap = new Map((recipesEnData as any[]).map((r: any) => [r.id, r]));
const allRecipes = getAllRecipes();
const latest = [...allRecipes]
  .sort((a, b) => b.meta.created_at.localeCompare(a.meta.created_at))
  .slice(0, 6);

// Region recipe count for heatmap
const regionRecipeCount: Record<string, number> = {};
for (const r of allRecipes) {
  const area = r.region?.area ?? '';
  if (area) regionRecipeCount[area] = (regionRecipeCount[area] ?? 0) + 1;
}

// Time machine: all recipe IDs
const recipeIds = allRecipes.map((r: any) => r.id);
const recipesWithImages = allRecipes
  .filter((r: any) => r.photos?.main)
  .map((r: any) => ({ id: r.id, img: r.photos.main }));

const grandmaTags = [
  { label: t(lang, 'tag.nimono'), tag: '煮物' },
  { label: t(lang, 'tag.daily'), tag: '日常のごはん' },
  { label: t(lang, 'tag.sansai'), tag: '山菜' },
  { label: t(lang, 'tag.newyear'), tag: 'お正月' },
  { label: t(lang, 'tag.kyodo'), tag: '郷土料理' },
  { label: t(lang, 'tag.home'), tag: '家庭料理' },
  { label: t(lang, 'tag.jobi'), tag: '常備菜' },
  { label: t(lang, 'tag.hozon'), tag: '保存食' },
  { label: t(lang, 'tag.spring'), tag: '春の味覚' },
];

const categories = [
  { img: `${base}assets/images/categories/shirumono.png`, label: t(lang, 'cat.soup') },
  { img: `${base}assets/images/categories/shusai.png`,   label: t(lang, 'cat.main') },
  { img: `${base}assets/images/categories/fukusai.png`,   label: t(lang, 'cat.side') },
  { img: `${base}assets/images/categories/tsukemono.png`, label: t(lang, 'cat.pickle') },
  { img: `${base}assets/images/categories/gohanmono.png`, label: t(lang, 'cat.rice') },
  { img: `${base}assets/images/categories/oyatsu.png`,    label: t(lang, 'cat.snack') },
];
---

<BaseLayout
  title="Japanese Grandma Recipes | Authentic Home Cooking Passed Down Through Generations"
  description="Discover authentic Japanese grandma recipes — real home cooking from kitchens across Japan. Traditional recipes with stories, cultural context, and step-by-step instructions."
  lang="en"
>
  <Header lang="en" />

  <main id="main" class="home">

    <!-- Hero Section -->
    <section class="hero" aria-label="Introduction">
      <div class="hero__bg" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__content">
        <h1 class="hero__title">
          <span class="hero__line" style="--line-i:0">{t(lang, 'home.hero.title.1')}</span><br />
          <span class="hero__line" style="--line-i:1">{t(lang, 'home.hero.title.2')}</span>
        </h1>
        <p class="hero__lead">
          <span class="hero__line" style="--line-i:2">{t(lang, 'home.hero.lead.1')}</span><br />
          <span class="hero__line" style="--line-i:3">{t(lang, 'home.hero.lead.2')}</span><br />
          <span class="hero__line" style="--line-i:4">{t(lang, 'home.hero.lead.3')}</span><br />
          <span class="hero__line" style="--line-i:5">{t(lang, 'home.hero.lead.4')}</span><br />
          <span class="hero__line" style="--line-i:6">{t(lang, 'home.hero.lead.5')}</span>
        </p>
      </div>
    </section>

    <div class="hero__divider" aria-hidden="true"><div class="hero__divider-line"></div></div>

    <!-- About intro for EN (SEO + cultural context) -->
    <section class="home__intro" style="text-align:center; padding: 2rem 1rem 0;">
      <div class="container" style="max-width: 680px;">
        <p style="font-family:var(--font-serif); font-size:0.95rem; color:var(--color-text-muted); line-height:2;">
          In Japan, the best home cooking doesn't come from restaurants — it comes from grandma's kitchen. These are real recipes collected from grandmothers across the country, each one carrying decades of wisdom, local ingredients, and family memories. We preserve them here so the next generation can taste them too.
        </p>
      </div>
    </section>

    <!-- Recently Added -->
    <section class="home__latest" aria-labelledby="latest-heading">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <h2 id="latest-heading" class="section-title">{t(lang, 'home.latest.title')}</h2>
        </div>
        <div class="recipe-grid recipe-grid--3">
          {latest.map((recipe) => {
            const en = enMap.get(recipe.id);
            return <RecipeCard recipe={recipe} lang="en" titleOverride={en?.title_en} tagsOverride={en?.tags_en} />;
          })}
        </div>
        <div class="section-footer">
          <a href={localePath(lang, `${base}recipes/`)} class="btn btn--outline" data-cta="view-all-recipes">{t(lang, 'home.latest.viewall')}</a>
        </div>
      </div>
    </section>

    <!-- wave -->
    <div class="wave-divider wave-divider--cream-to-green">
      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C240,40 480,0 720,20 C960,40 1200,0 1440,20 L1440,40 L0,40 Z" fill="#F5F3EF"/>
      </svg>
    </div>

    <!-- Browse by style / category -->
    <section class="home__explore" aria-labelledby="explore-heading">
      <div class="container">
        <div class="explore-tabs">
          <button class="explore-tab explore-tab--active" data-tab="grandma">
            {t(lang, 'home.explore.grandma')}
          </button>
          <button class="explore-tab" data-tab="recipe">
            {t(lang, 'home.explore.category')}
          </button>
        </div>

        <div class="explore-panel" id="panel-grandma">
          <div class="hashtag-cloud">
            {grandmaTags.map(({ label, tag }) => (
              <a href={localePath(lang, `${base}recipes/?tag=${encodeURIComponent(tag)}`)} class="hashtag-btn" data-cta="hashtag-filter">{label}</a>
            ))}
          </div>
        </div>

        <div class="explore-panel" id="panel-recipe" style="display:none">
          <div class="category-grid">
            {categories.map((c) => (
              <a href={localePath(lang, `${base}recipes/?category=${encodeURIComponent(c.label)}`)} class="category-btn animate-on-scroll" data-cta="category-filter">
                <img class="category-btn__img" src={c.img} alt={c.label} loading="lazy" />
                <span class="category-btn__label">{c.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- wave -->
    <div class="wave-divider wave-divider--green-to-blue">
      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C240,0 480,40 720,20 C960,0 1200,40 1440,20 L1440,40 L0,40 Z" fill="#FAFAF8"/>
      </svg>
    </div>

    <!-- Explore by Region -->
    <section class="home__regions-map" aria-labelledby="regions-heading">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <h2 id="regions-heading" class="section-title">{t(lang, 'home.regions.title')}</h2>
        </div>
        <div class="japan-map-container">
          <div class="japan-map-wrapper" id="japan-map-wrapper"></div>
          <div class="japan-map-tooltip" id="map-tooltip" style="display:none"></div>
        </div>
        <div class="section-footer">
          <a href={localePath(lang, `${base}regions/`)} class="btn btn--outline" data-cta="view-all-regions">{t(lang, 'home.regions.viewall')}</a>
        </div>
      </div>
    </section>

    <!-- wave -->
    <div class="wave-divider wave-divider--blue-to-warm">
      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C240,40 480,0 720,20 C960,40 1200,0 1440,20 L1440,40 L0,40 Z" fill="#F5F3EF"/>
      </svg>
    </div>

    <!-- Random Kitchen -->
    <section class="home__timemachine" aria-labelledby="timemachine-heading">
      <div class="container" style="text-align:center; padding: 5rem 1rem;">
        <h2 id="timemachine-heading" style="font-family:var(--font-serif); font-size:clamp(1.5rem,3vw,2rem); font-weight:400; color:var(--color-text-primary); margin-bottom:1.5rem; letter-spacing:0.05em;">{t(lang, 'home.timemachine.title')}</h2>
        <p style="font-family:var(--font-serif); font-size:0.95rem; color:var(--color-text-muted); line-height:2; margin-bottom:2.5rem;">
          {t(lang, 'home.timemachine.lead.1')}<br />
          {t(lang, 'home.timemachine.lead.2')}
        </p>
        <div class="tm-btn-wrapper">
          <a href="#" id="timemachine-btn" class="btn btn--outline tm-btn-combined" data-cta="timemachine" style="padding:1rem 3.5rem; font-family:var(--font-sans); font-size:0.8rem; letter-spacing:0.15em;">
            <span class="tm-clock-icon" aria-hidden="true"></span>
            {t(lang, 'home.timemachine.btn')}
          </a>
        </div>
      </div>
    </section>

    <!-- About This Project -->
    <section class="home__about" aria-labelledby="about-heading">
      <div class="container">
        <div class="about-block animate-on-scroll">
          <div class="about-block__deco" aria-hidden="true"><img src={`${base}assets/images/grandma-icon.png`} alt="" class="about-block__deco-img" /></div>
          <h2 id="about-heading" class="about-block__title">{t(lang, 'home.about.title')}</h2>
          <p class="about-block__text">
            {t(lang, 'home.about.text.1')}<br />
            {t(lang, 'home.about.text.2')}
          </p>
          <p class="about-block__text">
            {t(lang, 'home.about.text.3')}<br />
            {t(lang, 'home.about.text.4')}
          </p>
          <p class="about-block__text">
            {t(lang, 'home.about.text.5')}
          </p>
          <p class="about-block__text">
            {t(lang, 'home.about.text.6')}<br />
            {t(lang, 'home.about.text.7')}
          </p>
          <a href={localePath(lang, base + 'support/')} class="about-block__btn" data-cta="about">about</a>
        </div>
      </div>
    </section>

  </main>

  <Footer lang="en" />

  <!-- Tab switching & map JS -->
  <script type="application/json" id="recipe-images-data" set:html={JSON.stringify(recipesWithImages)}></script>
  <script define:vars={{ regionRecipeCount, base, recipeIds }}>
    // Tab switching
    document.querySelectorAll('.explore-tab').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.explore-tab').forEach((b) => b.classList.remove('explore-tab--active'));
        btn.classList.add('explore-tab--active');
        const tab = btn.dataset.tab;
        document.querySelectorAll('.explore-panel').forEach((p) => {
          p.style.display = p.id === `panel-${tab}` ? '' : 'none';
        });
      });
    });

    // Japan map
    const classToRegion = {
      'hokkaido': 'hokkaido',
      'tohoku': 'tohoku',
      'kanto': 'kanto',
      'ishikawa': 'hokuriku', 'toyama': 'hokuriku', 'fukui': 'hokuriku',
      'niigata': 'koshinetsu', 'nagano': 'koshinetsu', 'yamanashi': 'koshinetsu',
      'aichi': 'tokai', 'gifu': 'tokai', 'shizuoka': 'tokai', 'mie': 'tokai',
      'kinki': 'kinki',
      'chugoku': 'chugoku',
      'shikoku': 'shikoku',
      'kyushu': 'kyushu', 'kyushu-okinawa': 'kyushu',
    };
    const regionNames = {
      hokkaido: 'Hokkaido', tohoku: 'Tohoku', kanto: 'Kanto', hokuriku: 'Hokuriku',
      koshinetsu: 'Koshinetsu', tokai: 'Tokai', kinki: 'Kansai', chugoku: 'Chugoku',
      shikoku: 'Shikoku', kyushu: 'Kyushu & Okinawa',
    };

    function getColorForCount(count) {
      if (count === 0) return '#E8DCC8';
      if (count <= 2) return '#D4B896';
      if (count <= 5) return '#C49A6C';
      if (count <= 10) return '#A0703C';
      return '#7D4E1E';
    }

    const mapWrapper = document.getElementById('japan-map-wrapper');
    const mapTooltip = document.getElementById('map-tooltip');
    if (mapWrapper) {
      fetch(base + 'assets/japan-map.svg')
        .then(res => res.text())
        .then(svgText => {
          mapWrapper.innerHTML = svgText;
          const svgEl = mapWrapper.querySelector('svg');
          if (!svgEl) return;
          const prefGroups = svgEl.querySelectorAll('.prefecture');
          for (const g of prefGroups) {
            const classes = (g.className.baseVal || g.getAttribute('class') || '').split(/\s+/);
            let regionCode = null;
            for (const [cls, code] of Object.entries(classToRegion)) {
              if (classes.includes(cls)) { regionCode = code; break; }
            }
            if (!regionCode) continue;
            const count = regionRecipeCount[regionCode] ?? 0;
            const color = getColorForCount(count);
            g.setAttribute('fill', color);
            g.setAttribute('stroke', '#fff');
            g.setAttribute('stroke-width', '0.8');
            g.querySelectorAll('polygon, path').forEach(s => {
              s.setAttribute('fill', color);
              s.setAttribute('stroke', '#fff');
              s.setAttribute('stroke-width', '0.8');
            });
            g.addEventListener('mouseenter', () => {
              const name = regionNames[regionCode] ?? regionCode;
              mapTooltip.innerHTML = `<strong>${name}</strong>${count} recipes`;
              mapTooltip.style.display = 'block';
            });
            g.addEventListener('mousemove', (e) => {
              mapTooltip.style.left = (e.clientX + 12) + 'px';
              mapTooltip.style.top = (e.clientY + 12) + 'px';
            });
            g.addEventListener('mouseleave', () => { mapTooltip.style.display = 'none'; });
            g.style.cursor = 'pointer';
            g.addEventListener('click', () => {
              window.location.href = `/en/recipes?region=${regionCode}`;
            });
          }
        })
        .catch(err => console.warn('Japan map SVG load failed:', err));
    }

    // Scroll animation (Progressive Enhancement)
    const animatedEls = document.querySelectorAll('.animate-on-scroll');
    if (animatedEls.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      }, { threshold: 0.1 });
      animatedEls.forEach((el) => observer.observe(el));
    } else {
      animatedEls.forEach((el) => el.classList.add('is-visible'));
    }

    // Time machine
    const recipesWithImgs = JSON.parse(document.getElementById('recipe-images-data')?.textContent || '[]');
    const tmBtn = document.getElementById('timemachine-btn');
    if (tmBtn) {
      tmBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const pool = recipesWithImgs.length > 0 ? recipesWithImgs : recipeIds.map(id => ({ id, img: null }));
        const pick = pool[Math.floor(Math.random() * pool.length)];
        const randomId = pick.id;
        const imgSrc = pick.img ? base + pick.img : null;
        const overlay = document.createElement('div');
        overlay.className = 'tm-overlay';
        overlay.innerHTML = `
          <div class="tm-overlay__bg"></div>
          ${imgSrc ? `<div class="tm-overlay__food"><img src="${imgSrc}" alt="" /></div>` : ''}
          <div class="tm-overlay__flash"></div>
        `;
        document.body.appendChild(overlay);
        overlay.offsetHeight;
        overlay.classList.add('is-active');
        setTimeout(() => {
          const flash = overlay.querySelector('.tm-overlay__flash');
          if (flash) { flash.style.animation = 'none'; flash.style.opacity = '1'; }
          window.location.href = '/en/recipes/' + randomId + '/';
        }, 1600);
      });
    }
  </script>
</BaseLayout>
