---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes, getRecipeById, getTotalTime, getDifficultyLabel } from '../../data/recipes';
import type { Recipe } from '../../data/types';
import articlesData from '../../data/articles.json';

export async function getStaticPaths() {
  const recipes = getAllRecipes();
  return recipes.map((r) => ({ params: { id: r.id } }));
}

const { id } = Astro.params;
const recipe = getRecipeById(id!) as Recipe;

if (!recipe) {
  return Astro.redirect('/404');
}

const allRecipes = getAllRecipes();
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://www.obaachan-recipe.com';

// 基本データ
const grandmother = recipe.grandmother ?? {};
const region = recipe.region ?? {};
const meta = recipe.meta ?? {};
const tags = recipe.tags ?? [];
const servings = recipe.servings ?? 2;
const cookTime = recipe.cook_time_minutes;
const prepTime = recipe.prep_time_minutes;
const difficulty = recipe.difficulty;
const isEndangered = meta.is_endangered ?? false;
const imageUrl = recipe.photos?.main ?? recipe.photos?.thumbnail ?? '';
// 縦書きkanban用：「おばあちゃんの」「昔ながらの」などの冠詞を外して短く
const kanbanTitle = recipe.title.replace(/^(おばあちゃんの|昔ながらの)/, '').replace(/\n/g, '').replace(/[ 　|｜].*$/, '');
// タイトル：h1 用は \n → <br>、SEO/alt/breadcrumb 用は空白に置換
const titleHtml = recipe.title.replace(/\n/g, '<br>');
const titleFlat = recipe.title.replace(/\n/g, ' ');
const areaCode = region.area ?? '';
const prefecture = grandmother.prefecture ?? region.prefecture ?? '';
const AREA_LABELS: Record<string, string> = {
  hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
  koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
  shikoku: '四国', kyushu: '九州・沖縄',
};
const areaLabel = AREA_LABELS[areaCode] ?? '';
const seasonArr = Array.isArray(recipe.season) ? recipe.season : [];
const story = recipe.story ?? '';
const episode = recipe.episode ?? '';
// ものがたり：手動で設定されたリード文（recipes.json の episode_lead）。\n は <br> に
const episodeLeadRaw = (recipe.episode_lead ?? '').trim();
const episodeLead = episodeLeadRaw.replace(/\n/g, '<br>');
const culturalBg = recipe.cultural_background ?? '';
const source = recipe.source ?? { types: [], contributor: '' };
const grandmaNotes = recipe.grandma_notes ?? [];

const totalTime = getTotalTime(recipe);
const difficultyLabel = getDifficultyLabel(difficulty);

// pattern-c hero 用：通し番号（作成日順、最新=1）
const sortedAll = [...allRecipes].sort(
  (a: any, b: any) => (b.meta?.created_at ?? '').localeCompare(a.meta?.created_at ?? '')
);
const recipeIndex = sortedAll.findIndex((r: any) => r.id === recipe.id);
const recipeNumber = String(recipeIndex >= 0 ? recipeIndex + 1 : 0).padStart(2, '0');

// pattern-c hero 用：リード文（story の先頭3文）
const leadSource = (story || '').replace(/<[^>]+>/g, '').trim();
const leadLines = (() => {
  if (!leadSource) return [] as string[];
  return leadSource
    .split('。')
    .filter(Boolean)
    .slice(0, 3)
    .map((s: string) => s + '。');
})();

// pattern-c hero 用：おばあちゃんの一言（grandma_notes 優先、無ければ episode から要約的に2行抽出）
const heroQuoteResult = (() => {
  if (grandmaNotes && grandmaNotes.length > 0) {
    // grandma_notes はおばあちゃん自身の言葉 → おばあちゃん attribution
    return { text: grandmaNotes.slice(0, 2).join('\n'), from: 'grandma' as const };
  }
  const plainEpisode = (episode || '').replace(/<[^>]+>/g, '').trim();
  if (!plainEpisode) return { text: '', from: 'none' as const };

  // 台詞「...」を抽出（短いものを優先、30字以内）
  const dialogs = Array.from(plainEpisode.matchAll(/「([^」]+)」/g))
    .map((m) => m[1])
    .filter((s) => s.length <= 30);

  if (dialogs.length >= 2) {
    return { text: dialogs.slice(0, 2).join('\n'), from: 'episode' as const };
  }

  // 短い文（60字以内）を2つ選ぶ
  const sentences = plainEpisode
    .split('。')
    .map((s: string) => s.trim())
    .filter((s: string) => s.length > 0 && s.length <= 60);

  if (dialogs.length === 1 && sentences.length > 0) {
    const intro = sentences.find((s) => !s.includes(dialogs[0])) || '';
    return { text: intro ? `${dialogs[0]}\n${intro}。` : dialogs[0], from: 'episode' as const };
  }

  if (sentences.length > 0) {
    const pick = sentences.slice(0, 2).map((s) => s + '。');
    return { text: pick.join('\n'), from: 'episode' as const };
  }

  // フォールバック：先頭60字で切って "…" を付ける
  const head = plainEpisode.slice(0, 60);
  return { text: head + '…', from: 'episode' as const };
})();
const heroQuote = heroQuoteResult.text;
// 各行を「」で囲む（既に囲まれている場合はそのまま）
const heroQuoteFormatted = heroQuote
  .split('\n')
  .map((line) => {
    const t = line.trim();
    if (!t) return '';
    if (t.startsWith('「') && t.endsWith('」')) return t;
    return `「${t}」`;
  })
  .filter(Boolean)
  .join('<br />');
const heroQuoteName = (() => {
  const gName = grandmother.name || source.contributor || '';
  if (heroQuoteResult.from === 'grandma') {
    if (gName) return `— ${gName}さんのおばあちゃん（${prefecture}）`;
    return prefecture ? `— ${prefecture}のおばあちゃん` : '';
  }
  if (heroQuoteResult.from === 'episode') {
    if (gName) return `— ${gName}さんの食卓から（${prefecture}）`;
    return prefecture ? `— ${prefecture}のおばあちゃんの食卓から` : '';
  }
  return '';
})();

// 季節絵文字
const seasonEmoji = (_s: string) => '';

// SEO: meta_description があればそちらを優先、なければ自動生成
const rawEpisode = (episode || story || '').replace(/<[^>]+>/g, '').replace(/\n/g, '');
const descPrefix = `${titleFlat}（${prefecture}）`;
const descBody = rawEpisode
  ? `── ${rawEpisode}`.slice(0, 85 - descPrefix.length)
  : `── ${prefecture}のおばあちゃんから届いた手料理`;
const description = (recipe as any).meta_description || (descPrefix + descBody);
const pageTitle = (recipe as any).seo_title || `${titleFlat}（${prefecture}）| おばあちゃんのレシピ`;

// GA4 tracking vars
const trackRecipeName = titleFlat;
const trackRecipeId = recipe.id;
const trackRegion = prefecture;
const trackArea = areaCode;
const trackCategory = recipe.category ?? '';
const ogImage = imageUrl
  ? `${siteUrl}/${imageUrl}`
  : `${siteUrl}/assets/images/grandma-icon.png`;
const pageUrl = `${siteUrl}/recipes/${recipe.id}/`;

// JSON-LD
const allIngredients = recipe.ingredients.flatMap((g) =>
  g.items.map((item) => {
    const base = `${item.name} ${item.amount ?? ''}${item.unit}`.trim();
    return item.approx_weight ? `${base}（約${item.approx_weight}）` : base;
  })
);

// image: 実レシピ画像があるときだけ URL 配列で指定（フォールバックアイコンは使わない）
const recipeImageUrl = imageUrl ? `${siteUrl}/${imageUrl}` : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: titleFlat,
  description,
  ...(recipeImageUrl ? { image: [recipeImageUrl] } : {}),
  url: pageUrl,
  datePublished: meta.created_at,
  author: { '@type': 'Organization', name: 'おばあちゃんのレシピ', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'おばあちゃんのレシピ', url: siteUrl, logo: { '@type': 'ImageObject', url: `${siteUrl}/assets/images/grandma-icon.png` } },
  recipeYield: `${servings}人分`,
  prepTime: `PT${prepTime}M`,
  cookTime: `PT${cookTime}M`,
  totalTime: `PT${prepTime + cookTime}M`,
  recipeCategory: recipe.category,
  recipeCuisine: '日本料理',
  keywords: tags.join(','),
  recipeIngredient: allIngredients,
  recipeInstructions: recipe.steps.map((s) => ({
    '@type': 'HowToStep',
    position: s.step,
    text: s.text,
    url: `${pageUrl}#step-${s.step}`,
    ...(s.tip ? { name: s.tip } : {}),
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '食卓一覧', item: `${siteUrl}/recipes/` },
    { '@type': 'ListItem', position: 3, name: titleFlat, item: pageUrl },
  ],
};

// 関連レシピ（同地域 → 同カテゴリ → 新着の順でフォールバックして最大4件）
const RELATED_MAX = 4;
const sameArea = areaCode
  ? allRecipes.filter((r) => r.region?.area === areaCode && r.id !== recipe.id)
  : [];
const sameCategory = allRecipes.filter(
  (r) => r.category === recipe.category && r.id !== recipe.id &&
         !sameArea.some((s) => s.id === r.id)
);
const others = allRecipes.filter(
  (r) => r.id !== recipe.id &&
         !sameArea.some((s) => s.id === r.id) &&
         !sameCategory.some((s) => s.id === r.id)
);
const related = [...sameArea, ...sameCategory, ...others].slice(0, RELATED_MAX);

// 関連記事（地域タグ一致 → レシピタグ一致の優先順）
const AREA_TO_REGION: Record<string, string> = {
  hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
  koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
  shikoku: '四国', kyushu: '九州',
};
const regionName = AREA_TO_REGION[areaCode] ?? '';
const regionArticles = regionName
  ? (articlesData as any[]).filter((a: any) => a.tags?.includes(regionName))
  : [];
const tagArticles = (articlesData as any[]).filter((a: any) =>
  !regionArticles.some((ra: any) => ra.id === a.id) &&
  a.tags?.some((t: string) => tags.includes(t))
);
const relatedArticles = [...regionArticles, ...tagArticles].slice(0, 2);

// 似た料理（related_recipe_ids）
const relatedRecipeIds: string[] = (recipe as any).related_recipe_ids ?? [];
const similarRecipes = relatedRecipeIds
  .map((rid: string) => getRecipeById(rid))
  .filter((r): r is Recipe => r != null && r.id !== recipe.id);

// 食文化背景（文字列 or オブジェクト対応）
const bgHistory = typeof culturalBg === 'string' ? culturalBg : (culturalBg.history ?? story ?? '');
const bgIngredients = typeof culturalBg === 'object' && culturalBg !== null ? (culturalBg.local_ingredients ?? []).join('、') : '';
const bgSimilar = typeof culturalBg === 'object' && culturalBg !== null ? (culturalBg.similar_dishes ?? []).join('、') : '';
const hasBackground = bgHistory || bgIngredients;

// formatTime helper
function formatTime(minutes: number): string {
  if (!minutes) return '-';
  if (minutes >= 60) {
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m > 0 ? `${h}時間${m}分` : `${h}時間`;
  }
  return `${minutes}分`;
}

function difficultyStars(d: number): string {
  const labels = ['', '★☆☆', '★★☆', '★★★'];
  return labels[d] ?? '★☆☆';
}
---

<BaseLayout title={pageTitle} description={description} ogImage={ogImage} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <Header />

  <main id="main" class="recipe-detail">

    <!-- パンくず -->
    <nav class="recipe-detail__breadcrumb" aria-label="パンくずリスト">
      <div class="recipe-detail__breadcrumb-inner">
        <a href={base}>ホーム</a>
        <span aria-hidden="true"> › </span>
        <a href={`${base}recipes/`}>食卓一覧</a>
        {areaCode && (
          <>
            <span aria-hidden="true"> › </span>
            <a href={`${base}region/${areaCode}/`}>{areaLabel}</a>
          </>
        )}
        <span aria-hidden="true"> › </span>
        <span aria-current="page">{titleFlat}</span>
      </div>
    </nav>

    <!-- ヒーロー（pattern-c 準拠） -->
    <section class="recipe-detail__hero">
      <div class="recipe-detail__hero-visual">
        <span class="recipe-detail__hero-num" aria-hidden="true">#{recipeNumber}</span>
        <span class="recipe-detail__hero-kanban">{kanbanTitle}</span>
        {imageUrl ? (
          <img
            class="recipe-detail__hero-img"
            src={`${base}${imageUrl}`}
            alt={titleFlat}
            width="1200"
            height="800"
            style={recipe.photos?.position ? `object-position: ${recipe.photos.position}` : ''}
          />
        ) : (
          <img
            class="recipe-detail__hero-img"
            src={`${base}assets/images/sample-placeholder.png.jpg`}
            alt="準備中"
            width="1200"
            height="800"
          />
        )}
      </div>

      <div class="recipe-detail__hero-info">
        <span class="recipe-detail__hero-region">
          #{recipeNumber}{prefecture ? ` — ` : ''}
          {prefecture && areaCode && <a href={`${base}region/${areaCode}/`} class="recipe-detail__hero-region-link">{prefecture}</a>}
          {prefecture && !areaCode && prefecture}
          {seasonArr.length > 0 && (
            <span class="recipe-detail__hero-season">{seasonArr.join('・')}</span>
          )}
          {isEndangered && <span class="recipe-detail__hero-endangered">消えゆくレシピ</span>}
        </span>

        <h1 class="recipe-detail__title" set:html={titleHtml} />

        {recipe.category && (
          <span class="recipe-detail__subtitle">{recipe.subtitle ?? `${recipe.category}${prefecture ? ` — ${prefecture}の味` : ''}`}</span>
        )}

        {leadLines.length > 0 && (
          <p class="recipe-detail__lead">
            {leadLines.map((line: string, i: number) => (
              <Fragment>{line}{i < leadLines.length - 1 && <br />}</Fragment>
            ))}
          </p>
        )}

        <ul class="recipe-detail__meta">
          <li class="recipe-detail__meta-item">
            <span class="recipe-detail__meta-label">調理時間</span>
            <span class="recipe-detail__meta-value">{formatTime(cookTime)}</span>
          </li>
          <li class="recipe-detail__meta-item">
            <span class="recipe-detail__meta-label">分量</span>
            <span class="recipe-detail__meta-value" id="current-servings">{servings}人分</span>
          </li>
          {prefecture && (
            <li class="recipe-detail__meta-item">
              <span class="recipe-detail__meta-label">地域</span>
              <span class="recipe-detail__meta-value">{prefecture}</span>
            </li>
          )}
        </ul>

        {heroQuote && (
          <div class="recipe-detail__quote">
            <p class="recipe-detail__quote-text" set:html={heroQuoteFormatted} />
            {heroQuoteName && <span class="recipe-detail__quote-name">{heroQuoteName}</span>}
          </div>
        )}

        <div class="recipe-detail__share">
          <span class="recipe-detail__share-label">共有する</span>
          <button type="button" class="recipe-detail__share-btn recipe-detail__share-btn--x" data-share="x" data-cta="recipe-share-x" aria-label="Xでシェア" title="Xでシェア">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4l6.5 8L4 20h2l5.5-6.8L16 20h4l-6.8-8.5L20 4h-2l-5.2 6.3L9 4H4z" fill="currentColor"/></svg>
          </button>
          <button type="button" class="recipe-detail__share-btn recipe-detail__share-btn--line" data-share="line" data-cta="recipe-share-line" aria-label="LINEでシェア" title="LINEでシェア">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 5.81 2 10.5c0 3.11 2.33 5.81 5.71 7.08l-.71 2.62c-.06.22.18.4.37.28L11 18.2c.33.03.66.05 1 .05 5.52 0 10-3.81 10-8.5S17.52 2 12 2z" fill="currentColor"/></svg>
          </button>
          <button type="button" class="recipe-detail__share-btn" data-share="copy" data-cta="recipe-share-copy" aria-label="リンクをコピー" title="リンクをコピー">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
          <span class="recipe-detail__share-toast" id="share-toast" role="status" aria-live="polite">リンクをコピーしました</span>
        </div>

        <div class="recipe-detail__tags">
          {tags.map((t) => (
            <a href={`${base}recipes/?tag=${encodeURIComponent(t)}`} class="recipe-detail__tag">{t}</a>
          ))}
        </div>
      </div>
    </section>

    <!-- 材料 -->
    <section class="recipe-detail__ingredients" aria-labelledby="ingredients-heading">
      <div class="recipe-detail__ingredients-inner">
        <div class="recipe-detail__ingredients-head">
          <h2 class="recipe-detail__section-title" id="ingredients-heading" data-chapter="一ノ巻">材料</h2>
          <div class="servings-control">
            <button class="servings-btn" id="servings-minus" aria-label="人数を減らす">−</button>
            <span class="servings-display"><output id="servings-output">{servings}</output>人分</span>
            <button class="servings-btn" id="servings-plus" aria-label="人数を増やす">＋</button>
          </div>
        </div>

        <div class="recipe-detail__ingredients-body">
          <div class="measure-toggle">
            <button class="measure-toggle__btn measure-toggle__btn--active" data-mode="grandma">
              おばあちゃん流
            </button>
            <button class="measure-toggle__btn" data-mode="precise">
              きっちり計量
            </button>
          </div>
          <p class="ingredient__approx-note">※ おばあちゃんのレシピでは「だいたいこのくらい」で作ることも多いため、分量は目安としてご覧ください。</p>
          <table class="ingredient-table">
            <tbody id="ingredient-tbody">
              {recipe.ingredients.map((group) => (
                <>
                  {group.group && (
                    <tr class="ingredient-group-header">
                      <td colspan="2" class="ingredient__group">{group.group}</td>
                    </tr>
                  )}
                  {group.items.map((ing) => (
                    <tr class="ingredient-row" data-base-amount={String(ing.amount ?? '')} data-unit={ing.unit ?? ''} data-base-unit={ing.unit ?? ''}>
                      <td class="ingredient__name">{ing.name}</td>
                      <td class="ingredient__amount">
                        {ing.grandma_amount ? (
                          <>
                            <span class="ingredient__grandma">{ing.grandma_amount}</span>
                            <span class="ingredient__precise" style="display:none">
                              <span class="ingredient__qty">{String(ing.amount ?? '')}</span><span class="ingredient__unit-text">{ing.unit ?? ''}</span>{ing.approx_weight && <span class="ingredient__approx-weight">（約{ing.approx_weight}）</span>}
                            </span>
                          </>
                        ) : (
                          <span class="ingredient__precise-always">
                            <span class="ingredient__qty">{String(ing.amount ?? '')}</span><span class="ingredient__unit-text">{ing.unit ?? ''}</span>{ing.approx_weight && <span class="ingredient__approx-weight">（約{ing.approx_weight}）</span>}
                          </span>
                        )}
                        {ing.note && <small class="ingredient__note">（{ing.note}）</small>}
                      </td>
                    </tr>
                  ))}
                </>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- 作り方 -->
    <section class="recipe-detail__steps" aria-labelledby="steps-heading">
      <header class="recipe-detail__steps-head">
        <h2 class="recipe-detail__section-title" id="steps-heading" data-chapter="二ノ巻">作り方</h2>
      </header>
      <ol class="step-list">
        {recipe.steps.map((step, i) => (
          <li class="step" id={`step-${step.step ?? (i + 1)}`}>
            <div class="step__num">{String(step.step ?? (i + 1)).padStart(2, '0')}</div>
            <div class="step__content">
              {step.title && <p class="step__title">{step.title}</p>}
              <p class="step__text">{step.text}</p>
              {step.tip && <p class="step__tip">💡 {step.tip}</p>}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- 思い出・エピソード（ダーク背景） -->
    {episode && (
      <section class="recipe-detail__episode" aria-labelledby="episode-heading">
        <span class="recipe-detail__episode-bg" aria-hidden="true">{prefecture ? prefecture.replace(/[都府県]$/, '') : '味'}</span>
        <div class="recipe-detail__episode-inner">
          <h2 class="recipe-detail__episode-title" id="episode-heading">ものがたり</h2>
          <div class="episode-block">
            {episodeLead && <p class="episode-block__lead" set:html={episodeLead} />}
            <p class="episode-block__text" set:html={episode} />
            {source && (
              <div class="episode-block__source">
                <span class="episode-block__source-label">情報源：</span>
                {source.types.map((t) => <span class="episode-block__source-tag">{t}</span>)}
                {source.contributor && <span class="episode-block__contributor">（語り部：{source.contributor}さん）</span>}
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- 食文化こぼれ話 -->
    {hasBackground && (
      <section class="recipe-detail__background" aria-labelledby="background-heading">
        <div class="recipe-detail__background-inner">
          <h2 class="recipe-detail__section-title recipe-detail__background-title" id="background-heading">食文化こぼれ話</h2>
          <div class="background-block">
            {bgHistory && <p class="background-block__text" set:html={bgHistory} />}
            {bgIngredients && <p class="background-block__text"><strong>この地域の特産食材：</strong>{bgIngredients}</p>}
            {bgSimilar && <p class="background-block__text"><strong>似た料理：</strong>{bgSimilar}</p>}
          </div>
        </div>
      </section>
    )}

    <!-- ほかの食卓から -->
    {related.length > 0 && (
      <section class="recipe-detail__others" aria-labelledby="related-heading">
        <header class="recipe-detail__others-head">
          <h2 class="recipe-detail__section-title" id="related-heading">ほかの食卓から</h2>
        </header>
        <div class="recipe-detail__others-grid">
          {related.map((r: any) => {
            const rIdx = sortedAll.findIndex((x: any) => x.id === r.id);
            const rNum = String(rIdx >= 0 ? rIdx + 1 : 0).padStart(2, '0');
            const rPref = r.grandmother?.prefecture || r.region?.prefecture || '';
            const rName = r.grandmother?.name || r.source?.contributor || '';
            const rSeasonRaw = Array.isArray(r.season) && r.season.length > 0 ? r.season[0] : '';
            const rSeasonLabel = rSeasonRaw.includes('春') ? '春'
              : rSeasonRaw.includes('夏') ? '夏'
              : rSeasonRaw.includes('秋') ? '秋'
              : rSeasonRaw.includes('冬') ? '冬'
              : 'ある日';
            const rImg = r.photos?.main || '';
            const rKanban = r.title.replace(/^(おばあちゃんの|昔ながらの)/, '').replace(/[\s|｜].*$/, '');
            const nameSuffix = rName ? `${rName}さん` : `${rPref}のおばあちゃん`;
            const captionParts = [rPref, rSeasonLabel !== 'ある日' ? rSeasonLabel : ''].filter(Boolean).join('・');
            const caption = `${captionParts}。${nameSuffix}の食卓から。`;
            return (
              <a href={`${base}recipes/${r.id}/`} class="other-card" data-recipe-id={r.id}>
                <div class="other-card__visual">
                  <span class="other-card__kanban">{rKanban}</span>
                  {rImg ? (
                    <img class="other-card__img" src={`${base}${rImg}`} alt={r.title} loading="lazy" />
                  ) : (
                    <img class="other-card__img" src={`${base}assets/images/sample-placeholder.png.jpg`} alt="準備中" loading="lazy" />
                  )}
                </div>
                <span class="other-card__num">#{rNum}{rPref ? ` — ${rPref}` : ''}</span>
                <p class="other-card__caption">{caption}</p>
              </a>
            );
          })}
        </div>
      </section>
    )}

