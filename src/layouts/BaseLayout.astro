---
import type { Lang } from '../i18n/index';
import { t, alternatePath } from '../i18n/index';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  lang?: Lang;
  /** Set false to suppress hreflang alternate (e.g. pages without EN translation) */
  hasAlternate?: boolean;
}

const {
  title,
  description,
  ogImage = '/assets/images/ogp-default.jpg',
  ogType = 'website',
  canonicalUrl,
  lang = 'ja',
  hasAlternate = true,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://www.obaachan-recipe.com';
const currentUrl = canonicalUrl ?? siteUrl + Astro.url.pathname;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : siteUrl + ogImage;

const ogLocale = lang === 'en' ? 'en_US' : 'ja_JP';
const ogLocaleAlt = lang === 'en' ? 'ja_JP' : 'en_US';
const siteName = lang === 'en' ? "Grandma's Recipes" : 'おばあちゃんのレシピ';

// hreflang
const jaUrl = lang === 'ja' ? currentUrl : siteUrl + alternatePath('en', Astro.url.pathname);
const enUrl = lang === 'en' ? currentUrl : siteUrl + alternatePath('ja', Astro.url.pathname);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <!-- SEO -->
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />
  <link rel="icon" type="image/png" href={`${base}assets/images/grandma-icon.png`} />

  {hasAlternate && (
    <>
      <link rel="alternate" hreflang="ja" href={jaUrl} />
      <link rel="alternate" hreflang="en" href={enUrl} />
      <link rel="alternate" hreflang="x-default" href={jaUrl} />
    </>
  )}

  <!-- OGP -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={ogLocaleAlt} />
  <meta property="og:site_name" content={siteName} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />
  <meta name="twitter:site" content="@obaachan_recipe" />

  <!-- Google Search Console -->
  <meta name="google-site-verification" content="o8CGRwi6p8d6FL8x-uHhxRCxZVuSK3pnas4yYmXAnJY" />

  <!-- Google Analytics (GA4) — ?notrack=1 で自己アクセス除外 -->
  <script is:inline>
    (function(){
      if (location.search.indexOf('notrack=1') !== -1) {
        document.cookie = 'ga_notrack=1;path=/;max-age=31536000;SameSite=Lax';
      }
      if (document.cookie.indexOf('ga_notrack=1') !== -1) {
        window['ga-disable-G-EVYD2MEX67'] = true;
      }
    })();
  </script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-EVYD2MEX67"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EVYD2MEX67');
  </script>

  <!-- GA4 Custom Events (イベント委譲で一括処理・二重発火なし) -->
  <script is:inline>
  (function() {
    var isDev = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
    document.addEventListener('click', function(e) {
      var ctaEl = e.target.closest('[data-cta]');
      if (ctaEl) {
        var params = {
          cta_name: ctaEl.getAttribute('data-cta'),
          page_location: location.href,
          transport_type: 'beacon'
        };
        if (isDev) console.log('[GA4] cta_click', params);
        gtag('event', 'cta_click', params);

        if (ctaEl.getAttribute('data-cta') === 'recipe-view') {
          var rp = {
            recipe_name: ctaEl.getAttribute('data-recipe-name') || '',
            recipe_id: ctaEl.getAttribute('data-recipe-id') || '',
            region: ctaEl.getAttribute('data-region') || '',
            click_source: location.pathname,
            transport_type: 'beacon'
          };
          if (isDev) console.log('[GA4] recipe_click', rp);
          gtag('event', 'recipe_click', rp);
        }
      }

      var outEl = e.target.closest('[data-outbound]');
      if (outEl) {
        var op = {
          link_url: outEl.href || '',
          link_text: outEl.getAttribute('data-outbound'),
          page_location: location.href,
          transport_type: 'beacon'
        };
        if (isDev) console.log('[GA4] outbound_click', op);
        gtag('event', 'outbound_click', op);
      }
    });
  })();
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&display=swap"
    rel="stylesheet"
  />

  <!-- Global CSS -->
  <link rel="stylesheet" href={`${base}styles/global.css`} />

  <!-- Page-specific structured data slot -->
  <slot name="head" />
</head>
<body data-base={base} data-lang={lang}>
  <slot />
</body>
</html>
