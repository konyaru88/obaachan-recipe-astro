---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

// Supabase の公開キー（クライアントに露出してよい publishable key）
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const regions = ['北海道','東北','関東','北陸','甲信越','東海','近畿','中国','四国','九州'];
---

<BaseLayout
  title="みんなの食卓 | おばあちゃんのレシピ"
  description="みんなのおばあちゃんの味・再現したい味・ひとことを残す場所。投稿は運営がひとつずつ読ませてもらって、順に掲載していきます。"
  hasAlternate={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://www.obaachan-recipe.com/" },
        { "@type": "ListItem", "position": 2, "name": "みんなの食卓" }
      ]
    })} />
  </Fragment>
  <Header />

  <main class="board-page">
    <!-- Hero -->
    <section class="board-page__hero" aria-labelledby="board-title">
      <span class="board-page__hero-bg" aria-hidden="true">食卓</span>
      <h1 class="board-page__title" id="board-title">みんなの食卓</h1>
      <p class="board-page__lead">
        みんなのおばあちゃんの味、再現したい味、<br />
        今日のひとことを、ここに残しておきませんか。
      </p>
      <p class="board-page__count">
        現在 <strong id="postCount">0</strong> 件の投稿
      </p>
      <p class="board-page__note" role="note">
        あなたの投稿は、その場で「<strong>みんなの食卓</strong>」にならびます。<br />
        自分の投稿は、あとから編集・削除もできます。<br />
        みんなの食卓にあわない投稿は、運営でそっと片付けることがあります。
      </p>
    </section>

    <!-- Post form -->
    <div class="board-page__form-wrap">
      <div class="post-form" id="post-form-root">
        <div class="post-form__tabs" role="tablist" aria-label="投稿タイプ">
          <button type="button" class="post-form__tab is-active" data-tab="quick" role="tab" aria-selected="true">ひとこと</button>
          <button type="button" class="post-form__tab" data-tab="recipe" role="tab" aria-selected="false">レシピ</button>
          <button type="button" class="post-form__tab" data-tab="memory" role="tab" aria-selected="false">再現したい味</button>
        </div>

        <div class="post-form__body">
          <!-- Quick -->
          <form class="post-form__panel is-active" id="panelQuick" data-panel="quick">
            <div class="post-form__group">
              <label class="post-form__label" for="qNickname">ニックネーム</label>
              <input type="text" class="post-form__input" placeholder="例：みかの孫" id="qNickname" required />
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="qRegion">地域 <small>任意</small></label>
              <select class="post-form__select" id="qRegion">
                <option value="">選択してください</option>
                {regions.map((r) => <option>{r}</option>)}
              </select>
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="qText">ひとこと</label>
              <textarea class="post-form__textarea" placeholder="今日の一皿について、おばあちゃんの口癖、思い出など" id="qText" required></textarea>
            </div>
            <button type="submit" class="post-form__submit" data-cta="board-post-quick">投稿する</button>
          </form>

          <!-- Recipe -->
          <form class="post-form__panel" id="panelRecipe" data-panel="recipe">
            <div class="post-form__group">
              <label class="post-form__label" for="rNickname">ニックネーム</label>
              <input type="text" class="post-form__input" placeholder="例：よしこの孫" id="rNickname" required />
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="rName">料理名</label>
              <input type="text" class="post-form__input" placeholder="例：おばあちゃんの肉じゃが" id="rName" required />
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="rRegion">地域 <small>任意</small></label>
              <select class="post-form__select" id="rRegion">
                <option value="">選択してください</option>
                {regions.map((r) => <option>{r}</option>)}
              </select>
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="rIngredients">材料</label>
              <textarea class="post-form__textarea" placeholder={'例：\n鶏もも肉 … 「手のひらくらい」\n里芋 … 「ごろっと5つ」\n醤油 … 「ぐるっと3周」'} id="rIngredients"></textarea>
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="rSteps">作り方</label>
              <textarea class="post-form__textarea post-form__textarea--tall" placeholder={'例：\n1. 鍋に油を熱して鶏肉を炒める\n2. 野菜を加えて…'} id="rSteps"></textarea>
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="rEpisode">おばあちゃんのエピソード <small>任意</small></label>
              <textarea class="post-form__textarea" placeholder="例：お正月に必ず作ってくれた一品。いつも「味見してみり」って…" id="rEpisode"></textarea>
            </div>
            <button type="submit" class="post-form__submit" data-cta="board-post-recipe">レシピを投稿する</button>
          </form>

          <!-- Memory -->
          <form class="post-form__panel" id="panelMemory" data-panel="memory">
            <p class="post-form__memory-intro">
              レシピは残ってない。でも、あの味だけは忘れられない。<br />
              手がかりを書いて、ここに残しておきませんか。
            </p>
            <div class="post-form__group">
              <label class="post-form__label" for="mNickname">ニックネーム</label>
              <input type="text" class="post-form__input" placeholder="例：ひろしの孫" id="mNickname" required />
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="mName">その料理、なんて呼んでた？</label>
              <input type="text" class="post-form__input" placeholder={'例：「あの甘いやつ」「名前はなかった」'} id="mName" required />
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="mRegion">地域 <small>任意</small></label>
              <select class="post-form__select" id="mRegion">
                <option value="">選択してください</option>
                {regions.map((r) => <option>{r}</option>)}
              </select>
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="mMemory">覚えていること</label>
              <textarea class="post-form__textarea post-form__textarea--tall" placeholder={'例：\n夏に遊びに行くと必ず出てきた。\n冷たくて、甘くて、ちょっとシャリシャリしてた。'} id="mMemory"></textarea>
            </div>
            <div class="post-form__group">
              <label class="post-form__label" for="mClue">味の手がかり <small>わかる範囲で</small></label>
              <textarea class="post-form__textarea" placeholder="例：甘かった / 温かかった / 茶色っぽかった / さつまいもっぽい？" id="mClue"></textarea>
            </div>
            <button type="submit" class="post-form__submit post-form__submit--memory" data-cta="board-post-memory">思い出を投稿する</button>
          </form>
        </div>

      </div>
    </div>

    <!-- みんなの食卓（Supabase から動的取得） -->
    <section class="posts-section" aria-labelledby="posts-heading">
      <header class="posts-section__header">
        <h2 class="posts-section__title" id="posts-heading">みんなの食卓</h2>
      </header>

      <div id="postsList" aria-live="polite">
        <p class="posts-section__loading" id="postsLoading">読み込み中…</p>
        <p class="posts-section__empty" id="postsEmpty" hidden>
          最初の声をお待ちしています。
        </p>
      </div>
    </section>

    <!-- Toast -->
    <div class="toast" id="toast" role="status" aria-live="polite"></div>
  </main>

  <Footer />

  <script is:inline define:vars={{ base, SUPABASE_URL, SUPABASE_ANON_KEY }}>
    (function() {
      const UID_KEY = 'obaachan_board_uid';
      const LIKED_KEY = 'obaachan_board_liked';
      const NG_WORDS_URL = base + 'moderation/ng-words.json';

      // ------------------------------------------------------------
      // Supabase REST helpers
      // ------------------------------------------------------------
      const sbHeaders = () => ({
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
        'Content-Type': 'application/json',
        'Accept': 'application/json',
      });

      async function sbSelect(query) {
        const res = await fetch(SUPABASE_URL + '/rest/v1/posts?' + query, {
          headers: sbHeaders(),
        });
        if (!res.ok) throw new Error('fetch failed: ' + res.status);
        return await res.json();
      }

      async function sbInsert(row) {
        const res = await fetch(SUPABASE_URL + '/rest/v1/posts', {
          method: 'POST',
          headers: { ...sbHeaders(), 'Prefer': 'return=representation' },
          body: JSON.stringify(row),
        });
        if (!res.ok) {
          const err = await res.text();
          throw new Error('insert failed: ' + res.status + ' ' + err);
        }
        const rows = await res.json();
        return rows[0];
      }

      async function sbRpc(fn, args) {
        const res = await fetch(SUPABASE_URL + '/rest/v1/rpc/' + fn, {
          method: 'POST',
          headers: sbHeaders(),
          body: JSON.stringify(args || {}),
        });
        if (!res.ok) {
          const err = await res.text();
          throw new Error('rpc ' + fn + ' failed: ' + res.status + ' ' + err);
        }
        try { return await res.json(); } catch { return null; }
      }

      // ------------------------------------------------------------
      // NG ワード（クライアント側チェック）
      // ------------------------------------------------------------
      let ngData = null;
      async function loadNgWords() {
        if (ngData) return ngData;
        try {
          const res = await fetch(NG_WORDS_URL);
          ngData = await res.json();
        } catch {
          ngData = { ng_words: [], patterns: [] };
        }
        return ngData;
      }
      async function checkNg(...texts) {
        const d = await loadNgWords();
        const joined = texts.filter(Boolean).join(' ');
        for (const w of d.ng_words || []) {
          if (w && joined.includes(w)) return { hit: w, reason: 'ng_word' };
        }
        for (const p of d.patterns || []) {
          try {
            const re = new RegExp(p.regex);
            if (re.test(joined)) return { hit: p.reason, reason: p.reason };
          } catch { /* ignore bad regex */ }
        }
        return null;
      }

      // ------------------------------------------------------------
      // localStorage helpers
      // ------------------------------------------------------------
      function getMyUid() {
        let id = localStorage.getItem(UID_KEY);
        if (!id) {
          id = 'u_' + Math.random().toString(36).slice(2) + Date.now().toString(36);
          localStorage.setItem(UID_KEY, id);
        }
        return id;
      }
      const MY_UID = getMyUid();

      function loadLiked() {
        try { return new Set(JSON.parse(localStorage.getItem(LIKED_KEY)) || []); }
        catch { return new Set(); }
      }
      function saveLiked(set) {
        localStorage.setItem(LIKED_KEY, JSON.stringify([...set]));
      }
      const likedSet = loadLiked();

      // ------------------------------------------------------------
      // State
      // ------------------------------------------------------------
      let postsCache = [];
      let editingId = null;

      // ------------------------------------------------------------
      // Utils
      // ------------------------------------------------------------
      function timeAgo(dateStr) {
        const diff = Date.now() - new Date(dateStr).getTime();
        const m = Math.floor(diff / 60000);
        if (m < 1) return 'たった今';
        if (m < 60) return m + '分前';
        const h = Math.floor(m / 60);
        if (h < 24) return h + '時間前';
        const d = Math.floor(h / 24);
        if (d < 30) return d + '日前';
        return new Date(dateStr).toLocaleDateString('ja-JP');
      }

      function esc(str) {
        const d = document.createElement('div');
        d.textContent = String(str ?? '');
        return d.innerHTML;
      }

      function showToast(msg) {
        const t = document.getElementById('toast');
        if (!t) return;
        t.textContent = msg;
        t.classList.add('is-visible');
        setTimeout(() => t.classList.remove('is-visible'), 2500);
      }

      // ------------------------------------------------------------
      // Render
      // ------------------------------------------------------------
      function renderPostCard(post) {
        const isRecipe = post.type === 'recipe';
        const isMemory = post.type === 'memory';
        const typeLabel = isRecipe ? 'レシピ' : isMemory ? '再現したい味' : 'ひとこと';
        const typeClass = isRecipe ? 'recipe' : isMemory ? 'memory' : 'quick';

        let title = '', bodyText = '';
        if (isRecipe) {
          title = esc(post.recipe_name || '');
          const parts = [];
          if (post.ingredients) parts.push(post.ingredients);
          if (post.steps) parts.push(post.steps);
          if (post.episode) parts.push(post.episode);
          bodyText = esc(parts.join(' / '));
        } else if (isMemory) {
          title = esc(post.memory_name || '');
          const parts = [];
          if (post.memory) parts.push(post.memory);
          if (post.clue) parts.push('手がかり: ' + post.clue);
          bodyText = esc(parts.join(' '));
        } else {
          bodyText = esc(post.text || '');
        }

        const kanban = isRecipe && post.recipe_name
          ? '<span class="post-card__kanban">' + esc(post.recipe_name.slice(0, 6)) + '</span>'
          : '';
        const classes = [
          'post-card',
          isRecipe ? 'post-card--recipe' : '',
          post.uid === MY_UID ? 'post-card--mine' : '',
        ].filter(Boolean).join(' ');
        const regionHtml = post.region
          ? '<span>' + esc(post.region) + '</span>' : '';
        const manageHtml = post.uid === MY_UID
          ? '<div class="post-card__manage">'
            + '<button type="button" class="post-card__manage-btn" data-edit="' + post.id + '">編集</button>'
            + '<button type="button" class="post-card__manage-btn post-card__manage-btn--delete" data-delete="' + post.id + '">削除</button>'
          + '</div>'
          : '';
        const mineBadge = post.uid === MY_UID
          ? '<span class="post-card__mine-badge">あなたの投稿</span>' : '';
        const liked = likedSet.has(post.id);
        const likeClass = 'post-card__action' + (liked ? ' is-liked' : '');

        return (
          '<div class="' + classes + '" data-post-id="' + post.id + '">'
          + kanban
          + '<div class="post-card__body">'
          +   '<span class="post-card__type post-card__type--' + typeClass + '">' + typeLabel + '</span>'
          +   mineBadge
          +   (title ? '<h3 class="post-card__title">' + title + '</h3>' : '')
          +   '<p class="post-card__text">' + bodyText + '</p>'
          +   '<div class="post-card__meta">'
          +     '<span class="post-card__nickname">' + esc(post.nickname) + '</span>'
          +     regionHtml
          +     '<span>' + timeAgo(post.created_at) + '</span>'
          +     '<div class="post-card__actions">'
          +       '<button type="button" class="' + likeClass + '" data-like="' + post.id + '" aria-pressed="' + liked + '">🍙 <span>' + (post.likes_count ?? 0) + '</span></button>'
          +       manageHtml
          +     '</div>'
          +   '</div>'
          + '</div>'
          + '</div>'
        );
      }

      function render() {
        const listEl = document.getElementById('postsList');
        const loadingEl = document.getElementById('postsLoading');
        const emptyEl = document.getElementById('postsEmpty');
        const countEl = document.getElementById('postCount');
        if (!listEl) return;

        if (loadingEl) loadingEl.hidden = true;
        if (countEl) countEl.textContent = String(postsCache.length);

        if (postsCache.length === 0) {
          if (emptyEl) emptyEl.hidden = false;
          listEl.querySelectorAll('.post-card').forEach((n) => n.remove());
          return;
        }
        if (emptyEl) emptyEl.hidden = true;

        listEl.querySelectorAll('.post-card').forEach((n) => n.remove());
        const html = postsCache.map(renderPostCard).join('');
        listEl.insertAdjacentHTML('beforeend', html);
      }

      // ------------------------------------------------------------
      // Fetch posts
      // ------------------------------------------------------------
      async function loadPosts() {
        try {
          const rows = await sbSelect('select=*&is_hidden=eq.false&order=created_at.desc&limit=100');
          postsCache = rows;
          render();
        } catch (err) {
          console.error('[board] loadPosts failed', err);
          const loadingEl = document.getElementById('postsLoading');
          if (loadingEl) loadingEl.textContent = '読み込みに失敗しました。時間をおいて再読み込みしてください。';
        }
      }

      // ------------------------------------------------------------
      // Form helpers
      // ------------------------------------------------------------
      function switchTab(tabName) {
        document.querySelectorAll('.post-form__tab').forEach((t) => {
          const isThis = t.dataset.tab === tabName;
          t.classList.toggle('is-active', isThis);
          t.setAttribute('aria-selected', isThis ? 'true' : 'false');
        });
        document.querySelectorAll('.post-form__panel').forEach((p) => {
          p.classList.toggle('is-active', p.dataset.panel === tabName);
        });
      }

      function resetAllForms() {
        document.querySelectorAll('.post-form__panel').forEach((f) => f.reset && f.reset());
      }

      function setEditingIndicator(on) {
        const formRoot = document.getElementById('post-form-root');
        if (formRoot) formRoot.classList.toggle('is-editing', on);
      }

      async function submitPost(type, data) {
        // NG ワード検査（クライアント側）
        const fields = [data.nickname, data.text, data.recipe_name, data.ingredients, data.steps, data.episode, data.memory_name, data.memory, data.clue];
        const ng = await checkNg(...fields);
        if (ng) {
          if (ng.reason === 'phone_number') showToast('電話番号は投稿できません');
          else if (ng.reason === 'email') showToast('メールアドレスは投稿できません');
          else if (ng.reason === 'external_link') showToast('外部URLは投稿できません');
          else showToast('不適切な表現が含まれている可能性があります');
          return false;
        }

        try {
          if (editingId) {
            await sbRpc('update_my_post', {
              p_id: editingId,
              p_uid: MY_UID,
              p_nickname: data.nickname,
              p_region: data.region || null,
              p_text: data.text || null,
              p_recipe_name: data.recipe_name || null,
              p_ingredients: data.ingredients || null,
              p_steps: data.steps || null,
              p_episode: data.episode || null,
              p_memory_name: data.memory_name || null,
              p_memory: data.memory || null,
              p_clue: data.clue || null,
            });
            editingId = null;
            setEditingIndicator(false);
            showToast('編集しました');
          } else {
            const row = await sbInsert({
              type,
              nickname: data.nickname,
              region: data.region || null,
              text: data.text || null,
              recipe_name: data.recipe_name || null,
              ingredients: data.ingredients || null,
              steps: data.steps || null,
              episode: data.episode || null,
              memory_name: data.memory_name || null,
              memory: data.memory || null,
              clue: data.clue || null,
              uid: MY_UID,
            });
            // Optimistic: 先頭に追加して即反映
            if (row) postsCache = [row, ...postsCache];
            showToast('みんなの食卓にならびました');
          }
          await loadPosts();
          return true;
        } catch (err) {
          console.error('[board] submit failed', err);
          showToast('投稿に失敗しました。時間をおいて再送してください');
          return false;
        }
      }

      // ------------------------------------------------------------
      // Event wiring
      // ------------------------------------------------------------
      // Tabs
      document.querySelectorAll('.post-form__tab').forEach((tab) => {
        tab.addEventListener('click', () => switchTab(tab.dataset.tab));
      });

      // Form submit: quick
      document.getElementById('panelQuick')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const nickname = document.getElementById('qNickname').value.trim();
        const text = document.getElementById('qText').value.trim();
        if (!nickname || !text) { showToast('ニックネームとひとことを入力してください'); return; }
        const ok = await submitPost('quick', {
          nickname,
          region: document.getElementById('qRegion').value,
          text,
        });
        if (ok) e.target.reset();
      });

      // Form submit: recipe
      document.getElementById('panelRecipe')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const nickname = document.getElementById('rNickname').value.trim();
        const recipe_name = document.getElementById('rName').value.trim();
        if (!nickname || !recipe_name) { showToast('ニックネームと料理名を入力してください'); return; }
        const ok = await submitPost('recipe', {
          nickname,
          recipe_name,
          region: document.getElementById('rRegion').value,
          ingredients: document.getElementById('rIngredients').value.trim(),
          steps: document.getElementById('rSteps').value.trim(),
          episode: document.getElementById('rEpisode').value.trim(),
        });
        if (ok) e.target.reset();
      });

      // Form submit: memory
      document.getElementById('panelMemory')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const nickname = document.getElementById('mNickname').value.trim();
        const memory_name = document.getElementById('mName').value.trim();
        if (!nickname || !memory_name) { showToast('ニックネームと料理名を入力してください'); return; }
        const ok = await submitPost('memory', {
          nickname,
          memory_name,
          region: document.getElementById('mRegion').value,
          memory: document.getElementById('mMemory').value.trim(),
          clue: document.getElementById('mClue').value.trim(),
        });
        if (ok) e.target.reset();
      });

      // Delegate like / edit / delete
      document.getElementById('postsList')?.addEventListener('click', async (e) => {
        const target = e.target.closest('button');
        if (!target) return;

        // like toggle
        const likeId = target.getAttribute('data-like');
        if (likeId) {
          const post = postsCache.find((p) => p.id === likeId);
          if (!post) return;
          const alreadyLiked = likedSet.has(likeId);
          // 楽観的更新
          if (alreadyLiked) {
            likedSet.delete(likeId);
            post.likes_count = Math.max(0, (post.likes_count ?? 0) - 1);
          } else {
            likedSet.add(likeId);
            post.likes_count = (post.likes_count ?? 0) + 1;
          }
          saveLiked(likedSet);
          render();
          try {
            await sbRpc(alreadyLiked ? 'unlike_post' : 'like_post', { p_id: likeId });
          } catch (err) {
            console.error('[board] like toggle failed', err);
            // ロールバック
            if (alreadyLiked) {
              likedSet.add(likeId);
              post.likes_count = (post.likes_count ?? 0) + 1;
            } else {
              likedSet.delete(likeId);
              post.likes_count = Math.max(0, (post.likes_count ?? 0) - 1);
            }
            saveLiked(likedSet);
            render();
          }
          return;
        }

        // delete
        const delId = target.getAttribute('data-delete');
        if (delId) {
          if (!confirm('この投稿を削除しますか？')) return;
          try {
            await sbRpc('delete_my_post', { p_id: delId, p_uid: MY_UID });
            postsCache = postsCache.filter((p) => p.id !== delId);
            render();
            showToast('投稿を削除しました');
          } catch (err) {
            console.error('[board] delete failed', err);
            showToast('削除に失敗しました');
          }
          return;
        }

        // edit
        const editId = target.getAttribute('data-edit');
        if (editId) {
          const post = postsCache.find((p) => p.id === editId);
          if (!post) return;
          const tabName = ['quick','recipe','memory'].includes(post.type) ? post.type : 'quick';
          switchTab(tabName);

          if (tabName === 'quick') {
            document.getElementById('qNickname').value = post.nickname || '';
            document.getElementById('qRegion').value = post.region || '';
            document.getElementById('qText').value = post.text || '';
          } else if (tabName === 'recipe') {
            document.getElementById('rNickname').value = post.nickname || '';
            document.getElementById('rName').value = post.recipe_name || '';
            document.getElementById('rRegion').value = post.region || '';
            document.getElementById('rIngredients').value = post.ingredients || '';
            document.getElementById('rSteps').value = post.steps || '';
            document.getElementById('rEpisode').value = post.episode || '';
          } else if (tabName === 'memory') {
            document.getElementById('mNickname').value = post.nickname || '';
            document.getElementById('mName').value = post.memory_name || '';
            document.getElementById('mRegion').value = post.region || '';
            document.getElementById('mMemory').value = post.memory || '';
            document.getElementById('mClue').value = post.clue || '';
          }
          editingId = editId;
          setEditingIndicator(true);
          document.querySelector('.post-form')?.scrollIntoView({ behavior: 'smooth' });
          showToast('編集モード — 修正して送信してください');
          return;
        }
      });

      // 初期ロード
      loadPosts();
    })();
  </script>
</BaseLayout>

