---
import recipesData from '../data/recipes.json';
const recipes = recipesData.recipes;

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  const fullPath = base + path.replace(/^\//, '');
  if (path === '/') return pathname === base || pathname === base.replace(/\/$/, '');
  return pathname.startsWith(fullPath);
};
const navClass = (path: string) =>
  isActive(path) ? 'nav__link nav__link--active is-active' : 'nav__link';

// Ticker data (build-time)
const recipeCount = recipes.length;

const prefSet = new Set<string>();
recipes.forEach((r: any) => {
  const pref = r.grandmother?.prefecture || r.region?.prefecture || '';
  if (pref) prefSet.add(pref);
});
const prefCount = prefSet.size;

const grandmaSet = new Set<string>();
recipes.forEach((r: any) => {
  const name = r.grandmother?.name;
  const pref = r.grandmother?.prefecture || '';
  if (name) {
    grandmaSet.add(name);
  } else if (pref) {
    grandmaSet.add(pref + 'のおばあちゃん');
  }
});
const grandmaCount = grandmaSet.size;

const sorted = [...recipes].sort(
  (a: any, b: any) => new Date(b.meta?.created_at ?? 0).getTime() - new Date(a.meta?.created_at ?? 0).getTime()
);
const latest = sorted[0];
const latestPref = (latest?.grandmother?.prefecture || latest?.region?.prefecture || '').replace(/[都府県]$/, '');
const latestGrandma = latest?.grandmother?.name || '';
const latestTitle = latest?.title || '';
const latestLabel = latestGrandma
  ? `${latestPref}・${latestGrandma}さんの${latestTitle}`
  : `${latestPref}の${latestTitle}`;
const latestHref = `${base}recipes/${latest?.id || ''}/`;
---

<!-- β版ティッカーバー -->
<div class="beta-bar" role="banner" aria-label="お知らせ">
  <span class="beta-bar__badge">β版公開中</span>
  <span class="beta-bar__sep">－</span>
  <div class="beta-bar__ticker">
    <div class="beta-bar__ticker-track" id="ticker-track">
      <span class="ticker__item is-active">残されたレシピ：<strong>{recipeCount}</strong>件</span>
      <span class="ticker__item">つながった土地：<strong>{prefCount}</strong>県</span>
      <span class="ticker__item">出会ったおばあちゃん：<strong>{grandmaCount}</strong>人</span>
      <span class="ticker__item">最新の記録：<a href={latestHref} class="ticker__link">{latestLabel}</a></span>
    </div>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__logo" href={base}>
      <img src={`${base}assets/images/grandma-icon.png`} alt="" class="site-header__logo-img" aria-hidden="true" />
      おばあちゃんのレシピ
    </a>

    <nav class="site-header__nav" aria-label="メインナビゲーション">
      <a href={base} class={navClass('/')}>ホーム</a>
      <a href={`${base}recipes/`} class={navClass('/recipes')}>レシピ一覧</a>
      <a href={`${base}regions/`} class={navClass('/regions')}>地域で探す</a>
      <a href={`${base}articles/`} class={navClass('/articles')}>読み物</a>
    </nav>

    <form class="site-header__search" action={`${base}search/`} method="get" role="search" aria-label="レシピ検索">
      <input
        type="search"
        name="q"
        class="site-header__search-input"
        placeholder="レシピを検索…"
        aria-label="レシピを検索"
        autocomplete="off"
      />
      <button type="submit" class="header__search-btn" aria-label="検索">🔍</button>
    </form>

    <button class="mobile-menu-btn" aria-label="メニューを開く" aria-expanded="false">
      <span class="mobile-menu-btn__line"></span>
      <span class="mobile-menu-btn__line"></span>
      <span class="mobile-menu-btn__line"></span>
    </button>
  </div>

  <div class="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav" aria-label="モバイルナビゲーション">
      <a href={base} class={navClass('/')}>ホーム</a>
      <a href={`${base}recipes/`} class={navClass('/recipes')}>レシピ一覧</a>
      <a href={`${base}regions/`} class={navClass('/regions')}>地域で探す</a>
      <a href={`${base}articles/`} class={navClass('/articles')}>読み物</a>
    </nav>
    <form class="mobile-menu__search" action={`${base}search/`} method="get" role="search" aria-label="レシピ検索">
      <input
        type="search"
        name="q"
        class="mobile-menu__search-input"
        placeholder="料理名・地域・食材で検索…"
        aria-label="レシピを検索"
        autocomplete="off"
      />
      <button type="submit" class="mobile-menu__search-btn" aria-label="検索">🔍 検索</button>
    </form>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.querySelector('.mobile-menu-btn');
  const menu = document.querySelector('.mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.setAttribute('aria-hidden', String(expanded));
    menu?.classList.toggle('is-open');
  });

  // Ticker rotation (4s interval)
  const track = document.getElementById('ticker-track');
  if (track) {
    let current = 0;
    setInterval(() => {
      const allItems = track.querySelectorAll('.ticker__item');
      if (allItems.length === 0) return;
      allItems[current].classList.remove('is-active');
      current = (current + 1) % allItems.length;
      allItems[current].classList.add('is-active');
    }, 4000);
  }
</script>
