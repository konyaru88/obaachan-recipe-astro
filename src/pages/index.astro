---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAllRecipes } from '../data/recipes';

const base = import.meta.env.BASE_URL;
const allRecipes = getAllRecipes();

const withPhotos = allRecipes
  .filter((r: any) => r.photos?.main)
  .sort((a: any, b: any) => b.meta.created_at.localeCompare(a.meta.created_at));

const latest = withPhotos.slice(0, 6);

// ヒーロースライダー用：画像ありの最新3件
const sliderRecipes = withPhotos.slice(0, 3).map((r: any, idx: number) => {
  const prefecture = r.grandmother?.prefecture || r.region?.prefecture || '';
  const seasonArr = Array.isArray(r.season) ? r.season : [];
  const season = seasonArr[0] ?? '';
  const grandmaName = r.grandmother?.name || '';
  const caption = prefecture
    ? `${prefecture}${season ? '・' + season : ''}。${grandmaName ? grandmaName + 'さん' : '誰か'}の食卓から。`
    : `${r.title}`;
  const num = String(idx + 1).padStart(2, '0');
  return {
    id: r.id,
    title: r.title,
    img: r.photos.main,
    prefecture,
    num: `#${num}`,
    tag: `#${num} — ${prefecture}`,
    caption,
  };
});

// 食卓カード（table-grid）：最新6件を「あの◯の、◯◯」形式で
const seasonLabel = (s: string): string => {
  if (!s) return 'ある日';
  if (s.includes('春')) return '春';
  if (s.includes('夏')) return '夏';
  if (s.includes('秋')) return '秋';
  if (s.includes('冬')) return '冬';
  return 'ある日';
};
const tableCards = latest.map((r: any, i: number) => {
  const prefecture = r.region?.prefecture || r.grandmother?.prefecture || '';
  const grandmaName = r.grandmother?.name || '';
  const seasonArr = Array.isArray(r.season) ? r.season : [];
  const season = seasonLabel(seasonArr[0] || '');
  const num = String(i + 2).padStart(2, '0');
  return {
    id: r.id,
    title: r.title,
    kanban: `あの${season}の、${r.title}`,
    num: `#${num}`,
    tag: `#${num} — ${prefecture}`,
    caption: prefecture
      ? `${prefecture}・${season}。${grandmaName ? grandmaName + 'さん' : '誰か'}の食卓から。`
      : r.title,
    img: r.photos.main,
    prefecture,
  };
});

// 手仕事 6漢字：調理法ラベル＋リンク先＋代表画像
const teshigotoPool = withPhotos.slice(0, 18).map((r: any) => r.photos.main);
const teshigotoItems = [
  { kanji: '煮', name: 'ことこと、煮る', desc: 'おばあちゃんの煮物には時計がいらない。\n蓋の音と湯気の匂いが、頃合いを教えてくれる。', href: `${base}teshigoto/#ni`, cta: 'teshigoto-ni' },
  { kanji: '焼', name: 'じっくり、焼く', desc: '何度もひっくり返さない。\nじっと待つことが、おいしい焦げ目をつくる。', href: `${base}teshigoto/#yaki`, cta: 'teshigoto-yaki' },
  { kanji: '炒', name: 'さっと、炒める', desc: '強火で一気に。鍋を振る音が\n台所に響くと、晩ごはんの合図。', href: `${base}teshigoto/#itame`, cta: 'teshigoto-itame' },
  { kanji: '揚', name: 'からりと、揚げる', desc: '菜箸で泡を見て、音を聞く。\n温度計のない時代から変わらない見極め。', href: `${base}teshigoto/#age`, cta: 'teshigoto-age' },
  { kanji: '和', name: 'やさしく、和える', desc: '崩さないように、でもしっかり馴染むように。\n指先の加減が、味の決め手。', href: `${base}teshigoto/#ae`, cta: 'teshigoto-ae' },
  { kanji: '漬', name: 'じっくり、漬ける', desc: '塩をして、重石をして、あとは待つだけ。\n時間がいちばんの調味料。', href: `${base}teshigoto/#tsuke`, cta: 'teshigoto-tsuke' },
].map((item, i) => ({ ...item, img: teshigotoPool[i % teshigotoPool.length] || '' }));

// シーンで選ぶ 7カード
const sceneBase = `${base}scene/`;
const scenePool = withPhotos.slice(0, 14).map((r: any) => r.photos.main);
const sceneCards = [
  { slug: 'kotokoto', name: 'ことこと系', quote: '時間が染みてる', examples: '煮物、佃煮、汁物 ── 長く火にかけてる系', num: '#01' },
  { slug: 'chachatto', name: 'ちゃちゃっと系', quote: '名前ないけど、よく食卓に出るやつ', examples: '冷蔵庫の残りで作る名もなき炒め物・和え物', num: '#02' },
  { slug: 'hozon', name: '保存・仕込み系', quote: '未来の自分のための料理', examples: '漬物、梅干し、味噌、干しもの', num: '#03' },
  { slug: 'gochiso', name: 'ごちそうの日系', quote: '人が集まる日の味', examples: '天ぷら、ちらし寿司、お赤飯', num: '#04' },
  { slug: 'oyatsu', name: 'おやつ系', quote: '買うものじゃなくて、作るもの', examples: '蒸しパン、大学芋、寒天', num: '#05' },
  { slug: 'omoide', name: '思い出系', quote: '料理じゃなくて、「シーン」で切る', examples: '風邪のとき、帰省の定番、朝ごはんの一品', num: '#06' },
  { slug: 'nazo', name: '謎の一品系', quote: '「あの甘いやつ」「あの葉っぱのやつ」', examples: '名前がない。家によって違う。レシピが存在しない。', num: '#07', mystery: true },
].map((item, i) => ({ ...item, img: scenePool[i % scenePool.length] || '' }));

// 機能3カード
const featureCards = [
  { name: '今日の食卓', desc: '3つの質問に答えるだけで、\n今の気分にぴったりの\nおばあちゃんの食卓が見つかる。', linkText: '診断してみる →', href: `${base}match/`, cta: 'feature-match', icon: 'match' },
  { name: 'どこかの食卓へ', desc: 'ボタンひとつで、\n日本のどこかのおばあちゃんの\n食卓にタイムスリップ。', linkText: '飛んでみる →', href: `${base}timemachine/`, cta: 'feature-timemachine', icon: 'timemachine' },
  { name: 'みんなの食卓', desc: 'あなたのおばあちゃんの\nレシピやエピソードを\n投稿・共有できる掲示板。', linkText: '投稿を見る →', href: `${base}board/`, cta: 'feature-board', icon: 'board' },
];
---

<BaseLayout
  title="おばあちゃんのレシピ | 全国のおばあちゃんの手料理が集まる文化メディア"
  description="あの味、もう一度作れたら──。全国のおばあちゃんから届いた手料理レシピを、作り方・材料・思い出つきで。消えゆく家庭の味を記録する文化メディア。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://www.obaachan-recipe.com/#website",
          "url": "https://www.obaachan-recipe.com/",
          "name": "おばあちゃんのレシピ",
          "description": "全国のおばあちゃんの手料理が集まる文化メディア",
          "inLanguage": ["ja", "en"],
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://www.obaachan-recipe.com/search/?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://www.obaachan-recipe.com/#organization",
          "name": "おばあちゃんのレシピ",
          "url": "https://www.obaachan-recipe.com/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://www.obaachan-recipe.com/assets/images/grandma-icon.png"
          },
          "sameAs": [
            "https://www.instagram.com/obaachan_recipe",
            "https://www.threads.net/@obaachan_recipe",
            "https://note.com/obaachan_recipe"
          ]
        },
        {
          "@type": "ItemList",
          "name": "食卓",
          "itemListElement": latest.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "url": `https://www.obaachan-recipe.com/recipes/${r.id}/`
          }))
        }
      ]
    })} />
  </Fragment>
  <Header />

  <main id="main" class="home">

    <!-- ヒーロー（pattern-c：巨大装飾＋中央フォトスライダー） -->
    <section class="home-hero" aria-label="ヒーロー">
      <div class="home-hero__giant-left" aria-hidden="true">食<br />卓</div>
      <div class="home-hero__giant-right" aria-hidden="true">お<br />ば<br />あ<br />ち<br />ゃ<br />ん<br />の</div>

      {sliderRecipes.length > 0 && (
        <div class="home-hero__photo">
          <div class="home-hero__slider" id="hero-slider" aria-roledescription="carousel" aria-label="最近届いたレシピ">
            <div class="home-hero__slides" id="hero-slides">
              {sliderRecipes.map((s, i) => (
                <a
                  href={`${base}recipes/${s.id}/`}
                  class="home-hero__slide"
                  data-num={s.tag}
                  data-title={s.caption}
                  data-index={i}
                  data-cta="hero-slider"
                  data-recipe-id={s.id}
                  data-recipe-name={s.title}
                  data-region={s.prefecture}
                  aria-label={`${s.title}のレシピを見る（${s.prefecture}）`}
                  role="group"
                  aria-roledescription="slide"
                >
                  <img src={`${base}${s.img}`} alt={s.title} loading={i === 0 ? 'eager' : 'lazy'} width="640" height="854" />
                </a>
              ))}
            </div>
          </div>
          <div class="home-hero__dots" role="tablist" aria-label="スライダーナビゲーション">
            {sliderRecipes.map((_, i) => (
              <button
                class={`home-hero__dot${i === 0 ? ' is-active' : ''}`}
                data-index={i}
                aria-label={`${i + 1}番目のスライドへ`}
                aria-selected={i === 0 ? 'true' : 'false'}
                role="tab"
              ></button>
            ))}
          </div>
          <div class="home-hero__info" id="hero-info">
            <span class="home-hero__info-num">{sliderRecipes[0].tag}</span>
            <p class="home-hero__info-title">{sliderRecipes[0].caption}</p>
          </div>
        </div>
      )}

      <!-- おばあちゃん言葉（装飾） -->
      <span class="home-hero__kotoba" style="top:8%;left:2%;font-size:clamp(1.2rem,2.5vw,2rem);transform:rotate(-3deg)" aria-hidden="true">はよ食べ</span>
      <span class="home-hero__kotoba" style="top:22%;right:18%;font-size:clamp(0.9rem,1.8vw,1.4rem);transform:rotate(2deg)" aria-hidden="true">気持ち程度でええで</span>
      <span class="home-hero__kotoba" style="bottom:30%;left:1%;font-size:clamp(1rem,2vw,1.6rem);transform:rotate(-1deg)" aria-hidden="true">ひたひたになるまで</span>
      <span class="home-hero__kotoba" style="bottom:8%;right:3%;font-size:clamp(1.1rem,2.2vw,1.8rem);transform:rotate(3deg)" aria-hidden="true">適当でええんよ</span>
      <span class="home-hero__kotoba" style="top:55%;right:4%;font-size:clamp(1rem,1.8vw,1.4rem);transform:rotate(-4deg)" aria-hidden="true">目分量でよろし</span>
      <span class="home-hero__kotoba" style="top:15%;left:25%;font-size:clamp(0.85rem,1.5vw,1.2rem);transform:rotate(3deg)" aria-hidden="true">塩はひとつまみな</span>
      <span class="home-hero__kotoba" style="bottom:45%;left:12%;font-size:clamp(0.75rem,1.3vw,1rem);transform:rotate(-3deg)" aria-hidden="true">ぐるっと3周な</span>
      <span class="home-hero__kotoba" style="top:82%;right:15%;font-size:clamp(0.9rem,1.5vw,1.2rem);transform:rotate(1deg)" aria-hidden="true">手のひらくらい</span>
    </section>

    <!-- 食卓（七八風table-grid） -->
    <section class="home-section" aria-labelledby="shokutaku-heading">
      <div class="home-section__header">
        <span class="home-section__en" id="shokutaku-heading">食卓</span>
        <span class="home-section__jp">だれかのおばあちゃんの食卓の記憶</span>
      </div>
      <div class="home-table-grid">
        {tableCards.map((c) => (
          <a
            href={`${base}recipes/${c.id}/`}
            class="home-table-card"
            data-cta="table-card"
            data-recipe-id={c.id}
            data-recipe-name={c.title}
            data-region={c.prefecture}
            aria-label={`${c.title}のレシピを見る（${c.prefecture}）`}
          >
            <div class="home-table-card__img-wrap">
              <img src={`${base}${c.img}`} alt={c.title} class="home-table-card__img" loading="lazy" width="640" height="854" />
              <span class="home-table-card__kanban">{c.kanban}</span>
              <span class="home-table-card__num">{c.num}</span>
            </div>
            <div class="home-table-card__caption">
              <span class="home-table-card__tag">{c.tag}</span>
              <p class="home-table-card__title">{c.caption}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="home-more-wrap">
        <a href={`${base}recipes/`} class="home-more-btn" data-cta="view-all-recipes">すべての食卓を見る →</a>
      </div>
    </section>

    <!-- 手仕事 -->
    <section class="home-teshigoto" aria-labelledby="teshigoto-heading">
      <div class="home-teshigoto__header">
        <span class="home-teshigoto__en" id="teshigoto-heading">手仕事</span>
      </div>
      <p class="home-teshigoto__lead">
        手で覚えた、台所の知恵。<br />
        六つの台所仕事が、食卓をつくる。
      </p>
      <div class="home-teshigoto__grid">
        {teshigotoItems.map((it) => (
          <a href={it.href} class="home-teshigoto__item" data-cta={it.cta} aria-label={`${it.name}のレシピを見る`}>
            <div class="home-teshigoto__kanji">{it.kanji}</div>
            {it.img && <img src={`${base}${it.img}`} alt="" class="home-teshigoto__img" loading="lazy" width="200" height="200" />}
            <p class="home-teshigoto__name">{it.name}</p>
            <p class="home-teshigoto__desc" set:html={it.desc.replace(/\n/g, '<br>')}></p>
          </a>
        ))}
      </div>
    </section>

    <!-- シーンで選ぶ -->
    <section class="home-scene" aria-labelledby="scene-heading">
      <div class="home-scene__header">
        <span class="home-scene__en">食卓の気分</span>
        <h2 class="home-scene__title" id="scene-heading">食卓の気分で選ぶ</h2>
      </div>
      <p class="home-scene__lead">
        「何を作ろう」じゃなくて、<br />
        「あの感じのやつ」で。
      </p>

      <div class="home-scene__row-top">
        {sceneCards.slice(0, 3).map((c) => (
          <a
            href={`${sceneBase}#${c.slug}`}
            class={`home-scene__card${c.mystery ? ' home-scene__card--mystery' : ''}`}
            data-cta={`scene-${c.slug}`}
            aria-label={`${c.name}のレシピを見る`}
          >
            <div class="home-scene__card-visual">
              {c.img && <img src={`${base}${c.img}`} alt="" loading="lazy" width="640" height="800" />}
              <span class="home-scene__card-num">{c.num}</span>
              <div class="home-scene__card-overlay">
                <h3 class="home-scene__card-name">{c.name}</h3>
                <p class="home-scene__card-quote">{c.quote}</p>
              </div>
            </div>
            <p class="home-scene__card-examples">{c.examples}</p>
          </a>
        ))}
      </div>

      <div class="home-scene__row-bottom">
        {sceneCards.slice(3).map((c) => (
          <a
            href={`${sceneBase}#${c.slug}`}
            class={`home-scene__card${c.mystery ? ' home-scene__card--mystery' : ''}`}
            data-cta={`scene-${c.slug}`}
            aria-label={`${c.name}のレシピを見る`}
          >
            <div class="home-scene__card-visual">
              {c.img && <img src={`${base}${c.img}`} alt="" loading="lazy" width="400" height="400" />}
              <span class="home-scene__card-num">{c.num}</span>
              <div class="home-scene__card-overlay">
                <h3 class="home-scene__card-name">{c.name}</h3>
                <p class="home-scene__card-quote">{c.quote}</p>
              </div>
            </div>
            <p class="home-scene__card-examples">{c.examples}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- 機能（食卓を楽しむ） -->
    <section class="home-features" aria-labelledby="features-heading">
      <div class="home-features__header">
        <h2 class="home-features__title" id="features-heading">食卓を楽しむ</h2>
        <span class="home-features__sub">いろんな使い方で、おばあちゃんの味に出会う</span>
      </div>
      <div class="home-features__grid">
        {featureCards.map((f) => (
          <a href={f.href} class="home-feature-card" data-cta={f.cta} aria-label={f.name}>
            <span class="home-feature-card__icon" aria-hidden="true">
              {f.icon === 'match' && (
                <svg viewBox="0 0 50 50" width="48" height="48" fill="none" stroke="#444" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="25" cy="22" r="12"/>
                  <path d="M18 34 Q25 38 32 34"/>
                  <path d="M20 34 L17 46"/>
                  <path d="M30 34 L33 46"/>
                  <path d="M22 18 Q25 14 28 18" opacity="0.4"/>
                  <path d="M20 22 Q25 27 30 22" opacity="0.3"/>
                </svg>
              )}
              {f.icon === 'timemachine' && (
                <svg viewBox="0 0 50 55" width="48" height="52" fill="none" stroke="#444" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <ellipse cx="25" cy="32" rx="16" ry="13"/>
                  <path d="M9 28 Q2 24 4 18"/>
                  <path d="M41 28 Q48 24 46 18"/>
                  <ellipse cx="25" cy="20" rx="10" ry="3"/>
                  <path d="M23 17 Q25 8 27 17"/>
                  <path d="M20 15 Q22 5 24 15" opacity="0.4"/>
                  <path d="M26 15 Q28 5 30 15" opacity="0.4"/>
                </svg>
              )}
              {f.icon === 'board' && (
                <svg viewBox="0 0 50 50" width="48" height="48" fill="none" stroke="#444" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="8" y="6" width="34" height="40" rx="2"/>
                  <line x1="15" y1="16" x2="35" y2="16"/>
                  <line x1="15" y1="23" x2="35" y2="23"/>
                  <line x1="15" y1="30" x2="28" y2="30"/>
                </svg>
              )}
            </span>
            <h3 class="home-feature-card__name">{f.name}</h3>
            <p class="home-feature-card__desc" set:html={f.desc.replace(/\n/g, '<br>')}></p>
            <span class="home-feature-card__link">{f.linkText}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- About（ダーク2カラム） -->
    <section class="home-about" aria-labelledby="about-heading">
      <span class="home-about__bg-text" aria-hidden="true"></span>
      <div class="home-about__inner">
        <div class="home-about__left">
          <h2 class="home-about__big" id="about-heading">
            忘れたくない、<br />ごはん。
          </h2>
        </div>
        <div class="home-about__right">
          <p class="home-about__text">
            台所に立つ背中を、<br />
            ただ眺めていた頃がありました。
          </p>
          <p class="home-about__text">
            「ちょっと味見してごらん」と<br />
            差し出された小皿のあの味。<br />
            分量は「このくらい」、<br />
            火加減は「いい匂いがしてきたら」。
          </p>
          <p class="home-about__text">
            書き留めておけばよかったと、<br />
            気づいたのはずいぶん後のことでした。
          </p>
          <p class="home-about__text">
            おばあちゃんのレシピは、<br />
            誰かの台所に確かにあった味を<br />
            ひとつずつ集めていく場所です。
          </p>
          <div class="home-about__btns">
            <a href={`${base}about/`} class="home-about__btn home-about__btn--primary" data-cta="about">もっと読む →</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- ヒーロースライダーJS -->
  <script>
    (function() {
      const slider = document.getElementById('hero-slider');
      const slidesEl = document.getElementById('hero-slides');
      const info = document.getElementById('hero-info');
      if (!slider || !slidesEl) return;

      const slides = slidesEl.querySelectorAll('.home-hero__slide');
      const dots = document.querySelectorAll('.home-hero__dot');
      if (slides.length <= 1) return;

      let current = 0;
      let timerId = null;
      const INTERVAL = 5000;

      function goTo(i) {
        current = (i + slides.length) % slides.length;
        slidesEl.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, j) => {
          d.classList.toggle('is-active', j === current);
          d.setAttribute('aria-selected', j === current ? 'true' : 'false');
        });
        const slide = slides[current];
        const numEl = info?.querySelector('.home-hero__info-num');
        const titleEl = info?.querySelector('.home-hero__info-title');
        if (numEl) numEl.textContent = slide.dataset.num || '';
        if (titleEl) titleEl.textContent = slide.dataset.title || '';
      }

      function start() {
        stop();
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        timerId = setInterval(() => goTo(current + 1), INTERVAL);
      }
      function stop() {
        if (timerId) { clearInterval(timerId); timerId = null; }
      }

      dots.forEach((d) => {
        d.addEventListener('click', () => {
          goTo(parseInt(d.dataset.index || '0', 10));
          start();
        });
      });

      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop(); else start();
      });
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => e.isIntersecting ? start() : stop());
        }, { threshold: 0.25 });
        io.observe(slider);
      } else {
        start();
      }
    })();
  </script>
</BaseLayout>

