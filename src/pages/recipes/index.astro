---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes } from '../../data/recipes';

const AREA_CODES = [
  { code: 'hokkaido', label: '北海道' },
  { code: 'tohoku',   label: '東北' },
  { code: 'kanto',    label: '関東' },
  { code: 'hokuriku', label: '北陸' },
  { code: 'koshinetsu', label: '甲信越' },
  { code: 'tokai',    label: '東海' },
  { code: 'kinki',    label: '近畿' },
  { code: 'chugoku',  label: '中国' },
  { code: 'shikoku',  label: '四国' },
  { code: 'kyushu',   label: '九州・沖縄' },
];

const COMMON_TAGS = ['煮物', '日常のごはん', 'お正月', '郷土料理', '山菜', '家庭料理', '常備菜', '保存食', '和え物', '春の味覚'];

// 全レシピを新着順で出力（JSで絞り込み）
const allRecipes = [...getAllRecipes()].sort((a, b) =>
  b.meta.created_at.localeCompare(a.meta.created_at)
);
const total = allRecipes.length;
---

<BaseLayout
  title={`おばあちゃんの手料理食卓一覧（全${total}件）| おばあちゃんのレシピ`}
  description={`煮物、漬物、おやつ──全国のおばあちゃんから届いた${total}件の手料理レシピ。地域・カテゴリで探せます。どれも「あの味」を思い出す、昔ながらの家庭料理。`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "CollectionPage",
          "name": "食卓一覧",
          "description": `全国のおばあちゃんから集めた ${total} 件の食卓一覧`,
          "url": "https://www.obaachan-recipe.com/recipes/",
          "isPartOf": { "@id": "https://www.obaachan-recipe.com/#website" },
          "numberOfItems": total
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://www.obaachan-recipe.com/" },
            { "@type": "ListItem", "position": 2, "name": "食卓一覧" }
          ]
        }
      ]
    })} />
  </Fragment>
  <Header />

  <main id="main" class="list-page">

    <!-- Hero -->
    <section class="list-page__hero">
      <span class="list-page__hero-bg" aria-hidden="true">食卓</span>
      <h1 class="list-page__title" id="page-title">食卓一覧</h1>
      <p class="list-page__lead">全国のおばあちゃんの台所から届いた、手料理の記録。</p>
    </section>

    <!-- フィルターバー -->
    <aside class="list-page__filter" aria-label="絞り込み">
      <div class="list-page__filter-section">
        <h2 class="list-page__filter-label">地方で絞り込む</h2>
        <div class="list-page__filter-buttons" id="region-buttons">
          {AREA_CODES.map(({ code, label }) => (
            <button class="list-page__filter-btn" data-filter-type="region" data-filter-value={code}>{label}</button>
          ))}
        </div>
      </div>
      <div class="list-page__filter-section">
        <h2 class="list-page__filter-label">タグで絞り込む</h2>
        <div class="list-page__filter-buttons" id="tag-buttons">
          {COMMON_TAGS.map((t) => (
            <button class="list-page__filter-btn" data-filter-type="tag" data-filter-value={t}>{t}</button>
          ))}
        </div>
      </div>
      <div class="list-page__filter-footer" id="filter-reset-wrap" style="display:none">
        <button class="list-page__filter-reset" id="filter-reset-btn">フィルターをリセット ×</button>
      </div>
    </aside>

    <!-- ツールバー -->
    <div class="list-page__toolbar">
      <p class="list-page__count" aria-live="polite">
        <strong id="result-count">{total}</strong> 件のレシピが見つかりました
      </p>
      <div class="list-page__sort">
        <span class="list-page__sort-label">並び替え：</span>
        <button class="list-page__sort-btn is-active" data-sort="newest" id="sort-newest">新着順</button>
        <button class="list-page__sort-btn" data-sort="popular" id="sort-popular">人気順</button>
      </div>
    </div>

    <!-- グリッド -->
    <div class="list-page__grid" id="recipe-grid">
      {allRecipes.map((recipe) => (
        <div
          class="recipe-card-wrap"
          data-region={recipe.region?.area ?? ''}
          data-tags={JSON.stringify(recipe.tags)}
          data-category={recipe.category ?? ''}
          data-created={recipe.meta.created_at}
          data-views={String(recipe.view_count ?? 0)}
        >
          <RecipeCard recipe={recipe} />
        </div>
      ))}
    </div>

    <!-- 空状態 -->
    <div class="list-page__empty" id="empty-state" style="display:none">
      <p class="list-page__empty-icon" aria-hidden="true">🍳</p>
      <p class="list-page__empty-msg">該当するレシピが見つかりませんでした。</p>
      <button class="list-page__empty-btn" id="empty-reset-btn">すべてのレシピを見る</button>
    </div>

  </main>

  <Footer />

  <script>
    const BASE = document.body.dataset.base || '/';
    const AREA_LABELS: Record<string, string> = {
      hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
      koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
      shikoku: '四国', kyushu: '九州・沖縄',
    };

    // カテゴリグループ化（トップページのボタン → 実データのcategory値）
    const CATEGORY_GROUPS: Record<string, string[]> = {
      '汁物': ['汁物'],
      '主菜': ['主菜', '煮物', '揚げ物'],
      '副菜': ['副菜', '佃煮・常備菜', '和え物・酢の物'],
      '漬物': ['漬物'],
      'ご飯もの': ['ご飯もの'],
      'おやつ': ['おやつ', '和菓子・甘味'],
    };

    let currentRegion = '';
    let currentTag = '';
    let currentCategory = '';
    let currentSort = 'newest';

    const grid = document.getElementById('recipe-grid')!;
    const cards = Array.from(grid.querySelectorAll('.recipe-card-wrap')) as HTMLElement[];
    const countEl = document.getElementById('result-count')!;
    const titleEl = document.getElementById('page-title')!;
    const emptyEl = document.getElementById('empty-state')!;
    const resetWrap = document.getElementById('filter-reset-wrap')!;

    // URLパラメータから初期状態を復元
    const params = new URLSearchParams(window.location.search);
    if (params.get('region')) currentRegion = params.get('region')!;
    if (params.get('tag')) currentTag = params.get('tag')!;
    if (params.get('category')) currentCategory = params.get('category')!;
    if (params.get('sort')) currentSort = params.get('sort')!;

    function applyFilters() {
      let visibleCount = 0;

      // 並び替え
      const sorted = [...cards].sort((a, b) => {
        if (currentSort === 'popular') {
          return parseInt(b.dataset.views ?? '0') - parseInt(a.dataset.views ?? '0');
        }
        return (b.dataset.created ?? '').localeCompare(a.dataset.created ?? '');
      });
      sorted.forEach((card) => grid.appendChild(card));

      // フィルタリング
      cards.forEach((card) => {
        let show = true;
        if (currentRegion && card.dataset.region !== currentRegion) show = false;
        if (currentTag) {
          const tags = JSON.parse(card.dataset.tags ?? '[]') as string[];
          if (!tags.includes(currentTag)) show = false;
        }
        if (currentCategory) {
          const group = CATEGORY_GROUPS[currentCategory];
          const cardCat = card.dataset.category ?? '';
          if (group) {
            if (!group.includes(cardCat)) show = false;
          } else if (cardCat !== currentCategory) {
            show = false;
          }
        }

        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      countEl.textContent = String(visibleCount);

      // タイトル更新
      if (currentCategory) titleEl.textContent = `「${currentCategory}」のレシピ`;
      else if (currentTag) titleEl.textContent = `「${currentTag}」のレシピ`;
      else if (currentRegion) titleEl.textContent = `${AREA_LABELS[currentRegion] ?? ''}のレシピ`;
      else titleEl.textContent = '食卓一覧';

      // 空状態
      grid.style.display = visibleCount > 0 ? '' : 'none';
      emptyEl.style.display = visibleCount > 0 ? 'none' : '';

      // リセットボタン
      const hasFilter = currentRegion || currentTag || currentCategory;
      resetWrap.style.display = hasFilter ? '' : 'none';

      // ボタンのアクティブ状態
      document.querySelectorAll('[data-filter-type="region"]').forEach((btn) => {
        btn.classList.toggle('is-active', (btn as HTMLElement).dataset.filterValue === currentRegion);
      });
      document.querySelectorAll('[data-filter-type="tag"]').forEach((btn) => {
        btn.classList.toggle('is-active', (btn as HTMLElement).dataset.filterValue === currentTag);
      });
      document.getElementById('sort-newest')!.classList.toggle('is-active', currentSort !== 'popular');
      document.getElementById('sort-popular')!.classList.toggle('is-active', currentSort === 'popular');

      // URL更新（履歴なし）
      const qp = new URLSearchParams();
      if (currentRegion) qp.set('region', currentRegion);
      if (currentTag) qp.set('tag', currentTag);
      if (currentCategory) qp.set('category', currentCategory);
      if (currentSort !== 'newest') qp.set('sort', currentSort);
      const qs = qp.toString();
      history.replaceState(null, '', qs ? `${BASE}recipes?${qs}` : `${BASE}recipes`);
    }

    function resetFilters() {
      currentRegion = '';
      currentTag = '';
      currentCategory = '';
      currentSort = 'newest';
      applyFilters();
    }

    // フィルターボタン
    document.querySelectorAll('[data-filter-type]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const type = (btn as HTMLElement).dataset.filterType;
        const value = (btn as HTMLElement).dataset.filterValue ?? '';
        if (type === 'region') {
          currentRegion = currentRegion === value ? '' : value;
          currentTag = '';
          currentCategory = '';
        } else if (type === 'tag') {
          currentTag = currentTag === value ? '' : value;
          currentRegion = '';
          currentCategory = '';
        }
        applyFilters();
      });
    });

    // 並び替え
    document.getElementById('sort-newest')!.addEventListener('click', () => { currentSort = 'newest'; applyFilters(); });
    document.getElementById('sort-popular')!.addEventListener('click', () => { currentSort = 'popular'; applyFilters(); });

    // リセット
    document.getElementById('filter-reset-btn')!.addEventListener('click', resetFilters);
    document.getElementById('empty-reset-btn')!.addEventListener('click', resetFilters);

    // 初期表示
    applyFilters();
  </script>
</BaseLayout>

<style>
  /* Recipes list page (pattern-c scoped) */
  .list-page {
    font-family: 'Noto Sans JP', sans-serif;
    color: #222;
    background: #f0ece4;
    padding-bottom: 4rem;
  }

  /* Hero */
  .list-page__hero {
    position: relative;
    overflow: hidden;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem 5% 1.5rem;
  }
  .list-page__hero-bg {
    position: absolute;
    top: 50%;
    right: 5%;
    transform: translateY(-50%);
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(6rem, 16vw, 13rem);
    font-weight: 800;
    color: rgba(0, 0, 0, 0.04);
    pointer-events: none;
    user-select: none;
    line-height: 1;
    z-index: 0;
    white-space: nowrap;
  }
  .list-page__title {
    position: relative;
    z-index: 1;
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #222;
  }
  .list-page__lead {
    position: relative;
    z-index: 1;
    margin: 0.5rem 0 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.85rem;
    color: #777;
    letter-spacing: 0.02em;
    line-height: 2;
  }

  /* Filter bar */
  .list-page__filter {
    max-width: 1100px;
    margin: 1rem auto 0;
    padding: 1.4rem 5%;
    background: #fff;
    border: 1px solid #e0dcd4;
  }
  .list-page__filter-section + .list-page__filter-section {
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px dashed #e0dcd4;
  }
  .list-page__filter-label {
    margin: 0 0 0.6rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #444;
  }
  .list-page__filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .list-page__filter-btn {
    padding: 0.5rem 1.1rem;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #222;
    background: transparent;
    border: 1.5px solid #222;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .list-page__filter-btn:hover {
    background: #222;
    color: #f0ece4;
  }
  .list-page__filter-btn.is-active {
    background: #222;
    color: #f0ece4;
  }
  .list-page__filter-btn:focus-visible {
    outline: 2px solid #222;
    outline-offset: 2px;
  }
  .list-page__filter-footer {
    margin-top: 1rem;
    padding-top: 0.8rem;
    border-top: 1px dashed #e0dcd4;
    text-align: right;
  }
  .list-page__filter-reset {
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    color: #777;
    background: transparent;
    border: 1px solid #bbb;
    border-radius: 999px;
    padding: 0.4rem 1rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .list-page__filter-reset:hover {
    color: #222;
    border-color: #222;
  }

  /* Toolbar */
  .list-page__toolbar {
    max-width: 1100px;
    margin: 1.5rem auto 1rem;
    padding: 0 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .list-page__count {
    margin: 0;
    font-size: 0.78rem;
    color: #555;
    letter-spacing: 0.02em;
  }
  .list-page__count strong {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.05rem;
    color: #222;
    margin-right: 0.25em;
  }
  .list-page__sort {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: #666;
  }
  .list-page__sort-label {
    letter-spacing: 0.04em;
  }
  .list-page__sort-btn {
    padding: 0.35rem 0.9rem;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: #555;
    background: transparent;
    border: 1px solid #bbb;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .list-page__sort-btn:hover {
    border-color: #222;
    color: #222;
  }
  .list-page__sort-btn.is-active {
    background: #222;
    color: #f0ece4;
    border-color: #222;
  }

  /* Grid */
  .list-page__grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.5rem 5% 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.8rem;
  }
  .list-page__grid :global(.recipe-card-wrap) {
    display: flex;
  }

  /* === Override RecipeCard visuals (scoped via :global) === */
  .list-page__grid :global(.recipe-card) {
    width: 100%;
    background: #fff;
    border: 1.5px solid #222;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .list-page__grid :global(.recipe-card:hover) {
    transform: translateY(-4px);
    box-shadow: 6px 6px 0 #222;
  }
  .list-page__grid :global(.recipe-card__link) {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }
  .list-page__grid :global(.recipe-card__thumb) {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f2ec;
  }
  .list-page__grid :global(.recipe-card__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .list-page__grid :global(.recipe-card__region-badge) {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    padding: 0.22em 0.7em;
    background: rgba(34, 34, 34, 0.88);
    color: #f0ece4;
    font-size: 0.62rem;
    font-family: 'Shippori Mincho', serif;
    letter-spacing: 0.08em;
  }
  .list-page__grid :global(.recipe-card__body) {
    padding: 1rem 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1 1 auto;
  }
  .list-page__grid :global(.recipe-card__title) {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.55;
    letter-spacing: 0.03em;
    color: #222;
    /* Clamp to 2 lines so card heights stay even */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .list-page__grid :global(.recipe-card__tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    min-height: 1.35rem;
  }
  .list-page__grid :global(.recipe-card__tag) {
    font-size: 0.6rem;
    color: #888;
    border: 1px solid #d0ccc4;
    padding: 0.15em 0.65em;
    letter-spacing: 0.04em;
  }
  .list-page__grid :global(.recipe-card__meta) {
    list-style: none;
    margin: auto 0 0;
    padding: 0.5rem 0 0;
    border-top: 1px dashed #e0dcd4;
    display: flex;
    gap: 0.85rem;
    font-size: 0.68rem;
    color: #777;
  }
  .list-page__grid :global(.recipe-card__meta-item) {
    white-space: nowrap;
  }

  /* Empty state */
  .list-page__empty {
    max-width: 480px;
    margin: 3rem auto;
    padding: 3rem 1.5rem;
    text-align: center;
    background: #fff;
    border: 1px solid #e0dcd4;
  }
  .list-page__empty-icon {
    margin: 0 0 0.6rem;
    font-size: 2.2rem;
    line-height: 1;
  }
  .list-page__empty-msg {
    margin: 0 0 1.4rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.8;
  }
  .list-page__empty-btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    background: transparent;
    color: #222;
    border: 1.5px solid #222;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .list-page__empty-btn:hover {
    background: #222;
    color: #f0ece4;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .list-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
    }
  }

  @media (max-width: 640px) {
    .list-page__hero {
      padding: 2.2rem 5% 1rem;
    }
    .list-page__filter {
      padding: 1rem 5%;
    }
    .list-page__filter-btn {
      font-size: 0.68rem;
      padding: 0.45rem 0.9rem;
    }
    .list-page__toolbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
    }
    .list-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.9rem;
    }
    .list-page__grid :global(.recipe-card__body) {
      padding: 0.7rem 0.7rem 0.8rem;
      gap: 0.4rem;
    }
    .list-page__grid :global(.recipe-card__title) {
      font-size: 0.86rem;
      line-height: 1.5;
    }
    .list-page__grid :global(.recipe-card__tag) {
      font-size: 0.58rem;
    }
    .list-page__grid :global(.recipe-card__meta) {
      font-size: 0.62rem;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .list-page__grid :global(.recipe-card__region-badge) {
      font-size: 0.58rem;
    }
  }

  @media (max-width: 420px) {
    .list-page__grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }
  }
</style>
