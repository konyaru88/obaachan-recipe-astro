---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Privacy Policy | Japanese Grandma Recipes"
  description="Privacy Policy for Japanese Grandma Recipes. Learn how we handle your personal information."
  lang="en"
>
  <Header lang="en" />

  <main class="privacy-page">
    <div class="privacy-page__hero">
      <h1 class="privacy-page__title">Privacy Policy</h1>
    </div>

    <div class="privacy-page__body container">

      <p class="privacy-page__updated">Last updated: April 7, 2026</p>

      <p>"Grandma's Recipes" (this website) values your privacy. This policy explains how we collect, use, and protect your personal information.</p>

      <section class="privacy-page__section">
        <h2>1. Information We Collect</h2>
        <ul>
          <li><strong>Contact Form</strong>: Name, email address, and message content</li>
          <li><strong>Recipe Submissions</strong>: Contributor name (nickname accepted) and recipe details</li>
          <li><strong>Analytics</strong>: IP address, browser information, pages visited, and access timestamps (via Google Analytics)</li>
        </ul>
      </section>

      <section class="privacy-page__section">
        <h2>2. How We Use Information</h2>
        <ul>
          <li>Responding to inquiries</li>
          <li>Improving our website and content</li>
          <li>Analyzing traffic trends</li>
        </ul>
      </section>

      <section class="privacy-page__section">
        <h2>3. Third-Party Disclosure</h2>
        <p>We do not share your personal information with third parties except as required by law or with your explicit consent.</p>
      </section>

      <section class="privacy-page__section">
        <h2>4. Google Analytics</h2>
        <p>This website uses Google Analytics to understand how visitors interact with our site. Google Analytics uses cookies to collect anonymous traffic data. This data does not identify you personally.</p>
        <p>For more details, see <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener noreferrer">Google's privacy policy</a>.</p>
      </section>

      <section class="privacy-page__section">
        <h2>5. Contact</h2>
        <p>For privacy-related questions, please use our <a href="/en/contact/">contact form</a>.</p>
      </section>

      <section class="privacy-page__section">
        <h2>6. Changes to This Policy</h2>
        <p>We may update this policy from time to time. Changes take effect immediately upon being posted on this page.</p>
      </section>

    </div>
  </main>

  <Footer lang="en" />
</BaseLayout>

<style>
  .privacy-page__hero {
    text-align: center;
    padding: 3rem 1rem 1.5rem;
  }
  .privacy-page__title {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.8rem;
    font-weight: 700;
  }
  .privacy-page__body {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1rem 4rem;
    line-height: 1.9;
  }
  .privacy-page__updated {
    color: #888;
    font-size: 0.85rem;
    margin-bottom: 2rem;
  }
  .privacy-page__section {
    margin-top: 2rem;
  }
  .privacy-page__section h2 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .privacy-page__section ul {
    padding-left: 1.5em;
    margin-top: 0.5rem;
  }
  .privacy-page__section li {
    margin-bottom: 0.3rem;
  }
  .privacy-page__section a {
    color: #7D4E1E;
    text-decoration: underline;
  }
</style>
