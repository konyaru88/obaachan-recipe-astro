---
import type { Lang } from '../i18n/index';
import { t, localePath } from '../i18n/index';
import LanguageSwitcher from './LanguageSwitcher.astro';
import recipesData from '../data/recipes.json';
const recipes = recipesData.recipes;

interface Props {
  lang?: Lang;
}
const { lang = 'ja' } = Astro.props;

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  const fullPath = lang === 'en' ? `/en${path === '/' ? '/' : path}` : base + path.replace(/^\//, '');
  if (path === '/') {
    if (lang === 'en') return pathname === '/en/' || pathname === '/en';
    return pathname === base || pathname === base.replace(/\/$/, '');
  }
  return pathname.startsWith(fullPath);
};
const navClass = (path: string) =>
  isActive(path) ? 'nav__link nav__link--active is-active' : 'nav__link';

// Ticker data (build-time)
const recipeCount = recipes.length;

const prefSet = new Set<string>();
recipes.forEach((r: any) => {
  const pref = r.grandmother?.prefecture || r.region?.prefecture || '';
  if (pref) prefSet.add(pref);
});
const prefCount = prefSet.size;

const grandmaSet = new Set<string>();
recipes.forEach((r: any) => {
  const name = r.grandmother?.name;
  const pref = r.grandmother?.prefecture || '';
  if (name) {
    grandmaSet.add(name);
  } else if (pref) {
    grandmaSet.add(pref + 'のおばあ���ゃん');
  }
});
const grandmaCount = grandmaSet.size;

const sorted = [...recipes].sort(
  (a: any, b: any) => new Date(b.meta?.created_at ?? 0).getTime() - new Date(a.meta?.created_at ?? 0).getTime()
);
const latest = sorted[0];
const latestPref = (latest?.grandmother?.prefecture || latest?.region?.prefecture || '').replace(/[都府県]$/, '');
const latestGrandma = latest?.grandmother?.name || '';
const latestTitle = latest?.title || '';
const latestLabel = lang === 'en'
  ? `New: ${latestTitle}`
  : latestGrandma
    ? `${latestPref}・${latestGrandma}さんの${latestTitle}`
    : `${latestPref}の${latestTitle}`;
const latestHref = localePath(lang, `${base}recipes/${latest?.id || ''}/`);

const homePath = localePath(lang, base);
const recipesPath = localePath(lang, `${base}recipes/`);
const regionsPath = localePath(lang, `${base}regions/`);
const articlesPath = localePath(lang, `${base}articles/`);
const searchPath = localePath(lang, `${base}search/`);
---

<!-- β版ティッカーバー -->
<div class="beta-bar" role="banner" aria-label={lang === 'en' ? 'Announcements' : 'お知らせ'}>
  <span class="beta-bar__badge">{t(lang, 'ticker.badge')}</span>
  <span class="beta-bar__sep">－</span>
  <div class="beta-bar__ticker">
    <div class="beta-bar__ticker-track" id="ticker-track">
      <span class="ticker__item is-active">{t(lang, 'ticker.recipes')}<strong>{recipeCount}</strong>{t(lang, 'ticker.recipes.unit')}</span>
      <span class="ticker__item">{t(lang, 'ticker.prefectures')}<strong>{prefCount}</strong>{t(lang, 'ticker.prefectures.unit')}</span>
      <span class="ticker__item">{t(lang, 'ticker.grandmas')}<strong>{grandmaCount}</strong>{t(lang, 'ticker.grandmas.unit')}</span>
      <span class="ticker__item">{t(lang, 'ticker.latest')}<a href={latestHref} class="ticker__link" data-cta="ticker-recipe">{latestLabel}</a></span>
    </div>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__logo" href={homePath}>
      <img src={`${base}assets/images/grandma-icon.png`} alt="" class="site-header__logo-img" aria-hidden="true" />
      {t(lang, 'site.name')}
    </a>

    <nav class="site-header__nav" aria-label={lang === 'en' ? 'Main navigation' : 'メインナビゲーション'}>
      <a href={homePath} class={navClass('/')}>{t(lang, 'nav.home')}</a>
      <a href={recipesPath} class={navClass('/recipes')}>{t(lang, 'nav.recipes')}</a>
      <a href={regionsPath} class={navClass('/regions')}>{t(lang, 'nav.regions')}</a>
      <a href={articlesPath} class={navClass('/articles')}>{t(lang, 'nav.articles')}</a>
    </nav>

    <div class="site-header__actions">
      <form class="site-header__search" action={searchPath} method="get" role="search" aria-label={t(lang, 'search.placeholder')}>
        <input
          type="search"
          name="q"
          class="site-header__search-input"
          placeholder={t(lang, 'search.placeholder')}
          aria-label={t(lang, 'search.placeholder')}
          autocomplete="off"
        />
        <button type="submit" class="header__search-btn" aria-label={t(lang, 'search.button')}>🔍</button>
      </form>
      <LanguageSwitcher lang={lang} />
    </div>

    <button class="mobile-menu-btn" aria-label={lang === 'en' ? 'Open menu' : 'メニューを開く'} aria-expanded="false">
      <span class="mobile-menu-btn__line"></span>
      <span class="mobile-menu-btn__line"></span>
      <span class="mobile-menu-btn__line"></span>
    </button>
  </div>

  <div class="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav" aria-label={lang === 'en' ? 'Mobile navigation' : 'モバイルナビゲー��ョン'}>
      <a href={homePath} class={navClass('/')}>{t(lang, 'nav.home')}</a>
      <a href={recipesPath} class={navClass('/recipes')}>{t(lang, 'nav.recipes')}</a>
      <a href={regionsPath} class={navClass('/regions')}>{t(lang, 'nav.regions')}</a>
      <a href={articlesPath} class={navClass('/articles')}>{t(lang, 'nav.articles')}</a>
    </nav>
    <div class="mobile-menu__lang">
      <LanguageSwitcher lang={lang} />
    </div>
    <form class="mobile-menu__search" action={searchPath} method="get" role="search" aria-label={t(lang, 'search.placeholder')}>
      <input
        type="search"
        name="q"
        class="mobile-menu__search-input"
        placeholder={t(lang, 'search.placeholder.long')}
        aria-label={t(lang, 'search.placeholder')}
        autocomplete="off"
      />
      <button type="submit" class="mobile-menu__search-btn" aria-label={t(lang, 'search.button')}>���� {t(lang, 'search.button')}</button>
    </form>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.querySelector('.mobile-menu-btn');
  const menu = document.querySelector('.mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.setAttribute('aria-hidden', String(expanded));
    menu?.classList.toggle('is-open');
  });

  // Ticker rotation (4s interval)
  const track = document.getElementById('ticker-track');
  if (track) {
    let current = 0;
    setInterval(() => {
      const allItems = track.querySelectorAll('.ticker__item');
      if (allItems.length === 0) return;
      allItems[current].classList.remove('is-active');
      current = (current + 1) % allItems.length;
      allItems[current].classList.add('is-active');
    }, 4000);
  }
</script>
