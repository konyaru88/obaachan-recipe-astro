---
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <a class="site-footer__logo" href={base}>
        <img src={`${base}assets/images/grandma-icon.png`} alt="" class="site-footer__logo-img" />
        おばあちゃんのレシピ
      </a>
      <p class="site-footer__tagline">おばあちゃんの台所を、あなたの食卓へ。</p>
    </div>

    <nav aria-label="フッターナビゲーション">
      <p class="site-footer__heading">MENU</p>
      <ul class="site-footer__links">
        <li><a href={base}>ホーム</a></li>
        <li><a href={`${base}recipes/`}>レシピ一覧</a></li>
        <li><a href={`${base}regions/`}>地域で探す</a></li>
        <li><a href={`${base}articles/`}>読み物</a></li>
      </ul>
    </nav>

    <div>
      <p class="site-footer__heading">SNS</p>
      <ul class="site-footer__links">
        <li><a href="https://www.instagram.com/obaachan_recipe" target="_blank" rel="noopener noreferrer" data-outbound="instagram">Instagram</a></li>
        <li><a href="https://www.threads.net/@obaachan_recipe" target="_blank" rel="noopener noreferrer" data-outbound="threads">Threads</a></li>
        <li><a href="https://note.com/obaachan_recipe" target="_blank" rel="noopener noreferrer" data-outbound="note">note</a></li>
      </ul>
    </div>

    <div>
      <p class="site-footer__heading">SUPPORT</p>
      <a href={`${base}support/`} class="site-footer__link" data-cta="footer-support">この活動に参加する</a>
    </div>
  </div>

  <div class="site-footer__bottom container">
    <p>&copy; 2026 おばあちゃんのレシピ</p>
    <a href={`${base}privacy/`} class="site-footer__privacy">プライバシーポリシー</a>
  </div>
</footer>
