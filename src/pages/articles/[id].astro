---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import articlesData from '../../data/articles.json';
import { getRecipeById, getTotalTime, getDifficultyLabel } from '../../data/recipes';

export function getStaticPaths() {
  return articlesData.map((a: any) => ({ params: { id: a.id } }));
}

const base = import.meta.env.BASE_URL;
const { id } = Astro.params;
const article = articlesData.find((a: any) => a.id === id) as any;

// タグ→リンク先マッピング
const REGION_MAP: Record<string, string> = {
  '北海道': 'hokkaido', '東北': 'tohoku', '関東': 'kanto', '北陸': 'hokuriku',
  '甲信越': 'koshinetsu', '東海': 'tokai', '近畿': 'kinki', '中国': 'chugoku',
  '四国': 'shikoku', '九州': 'kyushu',
};
function tagToUrl(tag: string): string {
  if (REGION_MAP[tag]) return `${base}region/${REGION_MAP[tag]}/`;
  return `${base}recipes/?tag=${encodeURIComponent(tag)}`;
}

if (!article) {
  return Astro.redirect('/404');
}

const siteUrl = 'https://www.obaachan-recipe.com';
const pageUrl = `${siteUrl}/articles/${article.id}/`;
const date = article.published_at.replace(/-/g, '.').slice(2);
const pageTitle = (article as any).seo_title ?? `${article.title.replace(/\n/g, '')} | おばあちゃんのレシピ`;
const pageDescription = article.meta_description ?? (article.lead.slice(0, 120) + '…');

// レシピカードHTMLを生成（既存ロジック温存）
function buildRecipeCardHtml(recipeId: string): string {
  const recipe = getRecipeById(recipeId);
  if (!recipe) return '';
  const prefecture = recipe.grandmother?.prefecture ?? recipe.region?.prefecture ?? '';
  const timeStr = getTotalTime(recipe);
  const stars = getDifficultyLabel(recipe.difficulty);
  const servingsStr = recipe.servings ? `${recipe.servings}人分` : '-';
  const imageUrl = recipe.photos?.main ?? recipe.photos?.thumbnail ?? '';
  const tags = recipe.tags.slice(0, 3).map((t: string) => `<span class="recipe-card__tag">${t}</span>`).join('');
  const imgHtml = imageUrl
    ? `<img class="recipe-card__image" src="${base}${imageUrl}" alt="${recipe.title}" loading="lazy" />`
    : `<img class="recipe-card__image recipe-card__image--placeholder" src="${base}assets/images/sample-placeholder.png.jpg" alt="準備中" loading="lazy" />`;
  return `<div class="article-recipe-card">
    <article class="recipe-card">
      <a href="${base}recipes/${recipe.id}/" class="recipe-card__link" aria-label="${recipe.title}のレシピを見る" data-cta="recipe-view" data-recipe-name="${recipe.title}" data-recipe-id="${recipe.id}" data-region="${prefecture}">
        <div class="recipe-card__thumb${imageUrl ? '' : ' recipe-card__image-placeholder'}">
          ${imgHtml}
          ${prefecture ? `<span class="recipe-card__region-badge">${prefecture}</span>` : ''}
        </div>
        <div class="recipe-card__body">
          <h3 class="recipe-card__title">${recipe.title}</h3>
          <div class="recipe-card__tags">${tags}</div>
          <ul class="recipe-card__meta">
            <li class="recipe-card__meta-item">⏱ ${timeStr}</li>
            <li class="recipe-card__meta-item">👥 ${servingsStr}</li>
            <li class="recipe-card__meta-item" aria-label="難易度">${stars}</li>
          </ul>
        </div>
      </a>
    </article>
  </div>`;
}

// 本文をHTMLに変換（既存ロジック温存）
function formatInline(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\((\/[^)]+)\)/g, (_: string, t: string, href: string) =>
      `<a href="${base}${href.slice(1)}" class="article-content__link">${t}</a>`)
    .replace(/\[([^\]]+)\]\((https?:[^)]+)\)/g, (_: string, t: string, href: string) =>
      `<a href="${href}" class="article-content__link" target="_blank" rel="noopener noreferrer">${t}</a>`);
}

function formatBody(body: string): string {
  return body
    .split('\n\n')
    .flatMap((para: string) => {
      const trimmed = para.trim();
      if (trimmed === '---') return '<hr class="article-content__divider">';
      const recipeMatch = trimmed.match(/^\{\{recipe:(.+?)\}\}$/);
      if (recipeMatch) return buildRecipeCardHtml(recipeMatch[1]);
      if (trimmed.startsWith('### ')) {
        const lines = trimmed.split('\n');
        const heading = `<h3 class="article-content__subheading">${formatInline(lines[0].slice(4))}</h3>`;
        if (lines.length > 1) {
          const rest = lines.slice(1).join('\n').trim().replace(/\n/g, '<br>');
          return [heading, `<p>${formatInline(rest)}</p>`];
        }
        return [heading];
      }
      if (trimmed.startsWith('## ')) {
        const lines = trimmed.split('\n');
        const heading = `<h2 class="article-content__heading">${formatInline(lines[0].slice(3))}</h2>`;
        if (lines.length > 1) {
          const rest = lines.slice(1).join('\n').trim().replace(/\n/g, '<br>');
          return [heading, `<p>${formatInline(rest)}</p>`];
        }
        return [heading];
      }
      const html = trimmed.replace(/\n/g, '<br>');
      return [`<p>${formatInline(html)}</p>`];
    })
    .join('');
}

const bodyHtml = formatBody(article.body);

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '読み物', item: `${siteUrl}/articles/` },
    { '@type': 'ListItem', position: 3, name: article.title.replace(/\n/g, ''), item: pageUrl },
  ],
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title.replace(/\n/g, ''),
  description: pageDescription,
  datePublished: article.published_at,
  author: { '@type': 'Organization', name: 'おばあちゃんのレシピ' },
  publisher: {
    '@type': 'Organization',
    name: 'おばあちゃんのレシピ',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/assets/images/grandma-icon.png` },
  },
  mainEntityOfPage: pageUrl,
};

const faqLd = article.faq && article.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faq.map((item: any) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
} : null;

// 関連読み物：同カテゴリ優先、最大3件
const otherArticles = articlesData.filter((a: any) => a.id !== article.id);
const sameCategory = otherArticles.filter((a: any) => a.category_slug === article.category_slug);
const diffCategory = otherArticles.filter((a: any) => a.category_slug !== article.category_slug);
const relatedArticles = [...sameCategory, ...diffCategory].slice(0, 3);
---

<BaseLayout title={pageTitle} description={pageDescription} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  {faqLd && <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />}

  <Header />

  <main id="main" class="article-detail-page">

    <!-- パンくず -->
    <nav class="article-detail-page__breadcrumb" aria-label="パンくずリスト">
      <div class="article-detail-page__breadcrumb-inner">
        <a href={base}>ホーム</a>
        <span aria-hidden="true"> › </span>
        <a href={`${base}articles/`}>読み物</a>
        <span aria-hidden="true"> › </span>
        <a href={`${base}articles/${article.category_slug}/`}>{article.category}</a>
        <span aria-hidden="true"> › </span>
        <span aria-current="page" set:html={article.title.replace(/\n/g, ' ')} />
      </div>
    </nav>

    <!-- 記事ヒーロー -->
    <section class="article-detail-page__hero">
      <span class="article-detail-page__category">{article.category}</span>
      <h1 class="article-detail-page__title" set:html={article.title.replace(/\n/g, '<br />')} />
      {article.subtitle && <p class="article-detail-page__subtitle">{article.subtitle}</p>}
      <div class="article-detail-page__meta">
        <time datetime={article.published_at}>{date}</time>
        <span>約{article.reading_time}分で読める</span>
      </div>
      <div class="article-detail-page__thumb" aria-hidden="true">{article.thumbnail_emoji}</div>
      <p class="article-detail-page__lead">{article.lead}</p>
    </section>

    <!-- 本文 -->
    <article class="article-detail-page__article">
      <div class="article-content" set:html={bodyHtml} />

      {article.references && article.references.length > 0 && (
        <aside class="article-detail-page__references">
          <h3 class="article-detail-page__references-title">参考文献</h3>
          <ul>
            {article.references.map((ref: string) => <li>{ref}</li>)}
          </ul>
        </aside>
      )}

      {article.related_recipe_id && (
        <div class="article-detail-page__related-recipe">
          <p class="article-detail-page__related-recipe-label">📌 関連レシピ</p>
          <a
            href={`${base}recipes/${article.related_recipe_id}/`}
            class="article-detail-page__related-recipe-btn"
            data-cta="article-related-recipe"
          >このレシピを見る →</a>
        </div>
      )}

      <div class="article-detail-page__tags">
        {article.tags.map((tag: string) => (
          <a href={tagToUrl(tag)} class="article-detail-page__tag">{tag}</a>
        ))}
      </div>
    </article>

    <!-- 関連読み物 -->
    {relatedArticles.length > 0 && (
      <section class="article-detail-page__related">
        <header class="article-detail-page__related-header">
          <h2 class="article-detail-page__related-title">あわせて読みたい</h2>
          <span class="article-detail-page__related-sub">Related Articles</span>
        </header>
        <div class="article-detail-page__related-grid">
          {relatedArticles.map((ra: any) => {
            const raDate = ra.published_at.replace(/-/g, '.').slice(2);
            return (
              <a
                href={`${base}articles/${ra.id}/`}
                class="article-detail-page__related-card"
                data-cta="article-related-article"
              >
                <div class="article-detail-page__related-emoji" aria-hidden="true">{ra.thumbnail_emoji}</div>
                <span class="article-detail-page__related-cat">{ra.category}</span>
                <h3 class="article-detail-page__related-card-title" set:html={ra.title.replace(/\n/g, ' ')} />
                <time class="article-detail-page__related-date" datetime={ra.published_at}>{raDate}</time>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- 戻るリンク -->
    <div class="article-detail-page__back">
      <a href={`${base}articles/`} class="article-detail-page__back-btn" data-cta="article-back-to-list">← 読み物一覧へ戻る</a>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Article detail page (pattern-c scoped) */
  .article-detail-page {
    font-family: 'Noto Sans JP', sans-serif;
    color: #222;
    background: #f0ece4;
  }

  /* Breadcrumb */
  .article-detail-page__breadcrumb {
    padding: 1rem 5% 0.3rem;
  }
  .article-detail-page__breadcrumb-inner {
    max-width: 820px;
    margin: 0 auto;
    font-size: 0.68rem;
    color: #999;
    letter-spacing: 0.04em;
    line-height: 1.6;
  }
  .article-detail-page__breadcrumb a {
    color: #999;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .article-detail-page__breadcrumb a:hover { color: #222; }
  .article-detail-page__breadcrumb span { margin: 0 0.1em; }

  /* Hero */
  .article-detail-page__hero {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 5% 3rem;
    text-align: center;
  }
  .article-detail-page__category {
    display: inline-block;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #666;
    border: 1px solid #bbb;
    padding: 0.35em 1.2em;
    margin-bottom: 1.4rem;
  }
  .article-detail-page__title {
    margin: 0 0 1rem;
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(1.6rem, 3.8vw, 2.6rem);
    font-weight: 800;
    line-height: 1.6;
    letter-spacing: 0.03em;
    color: #222;
  }
  .article-detail-page__subtitle {
    margin: 0 0 1rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    color: #888;
    line-height: 1.8;
  }
  .article-detail-page__meta {
    display: flex;
    justify-content: center;
    gap: 2rem;
    font-size: 0.7rem;
    color: #aaa;
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }
  .article-detail-page__thumb {
    width: 110px;
    height: 110px;
    margin: 0 auto 1.5rem;
    background: #fff;
    border: 1px solid #e0dcd4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    line-height: 1;
  }
  .article-detail-page__lead {
    text-align: left;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.94rem;
    line-height: 2.2;
    color: #555;
    margin: 0;
    text-wrap: pretty;
  }

  /* Body wrapper */
  .article-detail-page__article {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 5% 3rem;
  }

  /* === .article-content: existing class, overridden here (pattern-c look) === */
  .article-detail-page__article :global(.article-content) {
    font-family: 'Noto Sans JP', sans-serif;
  }
  .article-detail-page__article :global(.article-content p) {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.94rem;
    line-height: 2.3;
    color: #444;
    margin: 0 0 1.5rem;
    word-break: auto-phrase;
    overflow-wrap: anywhere;
    text-wrap: pretty;
  }
  .article-detail-page__article :global(.article-content p strong) {
    font-weight: 700;
    color: #222;
  }
  .article-detail-page__article :global(.article-content__heading) {
    position: relative;
    margin: 3rem 0 1.3rem;
    padding-bottom: 0.55rem;
    border-bottom: 2px solid #222;
    font-family: 'Shippori Mincho', serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #222;
  }
  .article-detail-page__article :global(.article-content__heading::after) {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 40px;
    height: 2px;
    background: #888;
  }
  .article-detail-page__article :global(.article-content__subheading) {
    margin: 2.2rem 0 1rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #222;
    padding-left: 0.7em;
    border-left: 3px solid #222;
    line-height: 1.6;
  }
  .article-detail-page__article :global(.article-content__divider) {
    border: none;
    height: 1px;
    background: #ddd;
    margin: 2.8rem 0;
  }
  .article-detail-page__article :global(.article-content__link) {
    color: #222;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #bbb;
    transition: text-decoration-color 0.2s ease;
  }
  .article-detail-page__article :global(.article-content__link:hover) {
    text-decoration-color: #222;
  }

  /* Lists / blockquote (rarely used but future-proof) */
  .article-detail-page__article :global(.article-content ul),
  .article-detail-page__article :global(.article-content ol) {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.94rem;
    line-height: 2;
    color: #444;
    margin: 0 0 1.5rem 1.4rem;
  }
  .article-detail-page__article :global(.article-content li) {
    margin-bottom: 0.5rem;
  }
  .article-detail-page__article :global(.article-content blockquote) {
    position: relative;
    background: #fff;
    padding: 1.3rem 1.6rem 1.3rem 2rem;
    margin: 1.8rem 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    line-height: 2.1;
    color: #555;
    border-left: 3px solid #222;
  }
  .article-detail-page__article :global(.article-content img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.8rem auto;
    border: 1px solid #e0dcd4;
  }
  .article-detail-page__article :global(.article-content table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.8rem 0;
    font-size: 0.86rem;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .article-detail-page__article :global(.article-content th),
  .article-detail-page__article :global(.article-content td) {
    border: 1px solid #e0dcd4;
    padding: 0.6rem 0.9rem;
    text-align: left;
    line-height: 1.7;
  }
  .article-detail-page__article :global(.article-content th) {
    background: #faf9f6;
    font-weight: 600;
  }

  /* === Embedded Recipe Card: re-style existing .article-recipe-card === */
  .article-detail-page__article :global(.article-recipe-card) {
    margin: 2.2rem 0;
    background: #fff;
    border: 1.5px solid #222;
    padding: 1rem;
    transition: transform 0.3s ease;
  }
  .article-detail-page__article :global(.article-recipe-card:hover) {
    transform: translateY(-3px);
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card) {
    all: unset;
    display: block;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__link) {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.2rem;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__thumb) {
    position: relative;
    width: 140px;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f2ec;
    border: 1px solid #e0dcd4;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__region-badge) {
    position: absolute;
    bottom: 0.4rem;
    left: 0.4rem;
    padding: 0.2em 0.7em;
    background: rgba(34,34,34,0.82);
    color: #f0ece4;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__body) {
    min-width: 0;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__title) {
    margin: 0 0 0.4rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #222;
    line-height: 1.5;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__tags) {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__tag) {
    font-size: 0.62rem;
    color: #888;
    border: 1px solid #d0ccc4;
    padding: 0.15em 0.7em;
    letter-spacing: 0.04em;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__meta) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.9rem;
    font-size: 0.7rem;
    color: #777;
  }
  .article-detail-page__article :global(.article-recipe-card .recipe-card__meta-item) {
    white-space: nowrap;
  }

  /* References */
  .article-detail-page__references {
    margin: 3rem 0 2rem;
    padding: 1.5rem 1.5rem 1.5rem 1.8rem;
    background: #fff;
    border-left: 3px solid #222;
  }
  .article-detail-page__references-title {
    margin: 0 0 0.7rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #222;
  }
  .article-detail-page__references ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.9;
    color: #666;
  }
  .article-detail-page__references li::before {
    content: '— ';
    color: #bbb;
  }

  /* Related recipe CTA (legacy related_recipe_id) */
  .article-detail-page__related-recipe {
    text-align: center;
    margin: 2.5rem 0 1.5rem;
    padding: 1.8rem 1.5rem;
    background: #fff;
    border: 1.5px solid #222;
  }
  .article-detail-page__related-recipe-label {
    margin: 0 0 1rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #444;
  }
  .article-detail-page__related-recipe-btn {
    display: inline-block;
    padding: 0.85rem 2.2rem;
    background: #222;
    color: #f0ece4;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }
  .article-detail-page__related-recipe-btn:hover { opacity: 0.85; }

  /* Tags */
  .article-detail-page__tags {
    margin-top: 2.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .article-detail-page__tag {
    font-size: 0.7rem;
    color: #666;
    border: 1px solid #d0ccc4;
    padding: 0.35em 1em;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .article-detail-page__tag:hover {
    background: #222;
    color: #f0ece4;
    border-color: #222;
