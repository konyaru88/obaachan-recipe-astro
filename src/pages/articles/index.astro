---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import articlesData from '../../data/articles.json';

const base = import.meta.env.BASE_URL;
const articles = [...articlesData].sort((a: any, b: any) =>
  b.published_at.localeCompare(a.published_at)
);
---

<BaseLayout
  title="読み物 | おばあちゃんのレシピ"
  description="おばあちゃんのストーリーと食文化コラム。日本の伝統的な食文化を深く知る読み物をお届けします。"
>
  <Header />

  <main id="main" class="articles-page">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">読み物</h1>
        <p class="page-subtitle">おばあちゃんの知恵と暮らしを、読み物でお届けします</p>
      </div>

      <!-- カテゴリータブ -->
      <div class="article-tabs" role="tablist" aria-label="カテゴリー">
        <button class="article-tab article-tab--active" data-category="">すべて</button>
        <a href={`${base}articles/life`} class="article-tab" data-category="life">暮らしのレシピ帖</a>
        <a href={`${base}articles/teshigoto`} class="article-tab" data-category="teshigoto">季節の手仕事</a>
        <a href={`${base}articles/story`} class="article-tab" data-category="story">おばあちゃんのストーリー</a>
        <a href={`${base}articles/column`} class="article-tab" data-category="column">食文化コラム</a>
      </div>

      <!-- 記事一覧（全記事出力、JSで表示制御） -->
      <div class="article-list" id="article-list">
        {articles.map((article: any) => {
          const date = article.published_at.replace(/-/g, '.').slice(2);
          return (
            <a href={`${import.meta.env.BASE_URL}articles/${article.id}`} class="article-card" data-category-slug={article.category_slug}>
              <div class="article-card__thumb" aria-hidden="true">{article.thumbnail_emoji}</div>
              <div class="article-card__body">
                <div class="article-card__header-row">
                  <span class="article-card__category">{article.category}</span>
                </div>
                <h2 class="article-card__title">{article.title}</h2>
                <p class="article-card__lead">{article.lead}</p>
                <div class="article-card__meta">
                  <time datetime={article.published_at}>{date}</time>
                  <span class="article-card__read">約{article.reading_time}分で読める</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>

    </div>
  </main>

  <Footer />

  <script>
    // 「すべて」ボタンはアクティブ状態を維持（他タブはリンクで遷移）
  </script>
</BaseLayout>
