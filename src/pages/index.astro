---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getAllRecipes } from '../data/recipes';

const base = import.meta.env.BASE_URL;
const allRecipes = getAllRecipes();
const latest = [...allRecipes]
  .sort((a, b) => b.meta.created_at.localeCompare(a.meta.created_at))
  .slice(0, 6);

// 地域ごとのレシピ数を集計（ヒートマップ用）
const regionRecipeCount: Record<string, number> = {};
for (const r of allRecipes) {
  const area = r.region?.area ?? '';
  if (area) regionRecipeCount[area] = (regionRecipeCount[area] ?? 0) + 1;
}

// タイムマシン用：全レシピIDの配列
const recipeIds = allRecipes.map((r: any) => r.id);
// タイムマシン用：画像ありレシピのみ（フラッシュ演出用）
const recipesWithImages = allRecipes
  .filter((r: any) => r.photos?.main)
  .map((r: any) => ({ id: r.id, img: r.photos.main }));

// ヒーロースライダー用：画像ありの最新3件
const sliderRecipes = allRecipes
  .filter((r: any) => r.photos?.main)
  .sort((a: any, b: any) => b.meta.created_at.localeCompare(a.meta.created_at))
  .slice(0, 3)
  .map((r: any, idx: number) => {
    const prefecture = r.grandmother?.prefecture || r.region?.prefecture || '';
    const seasonArr = Array.isArray(r.season) ? r.season : [];
    const season = seasonArr[0] ?? '';
    const grandmaName = r.grandmother?.name || '';
    const caption = prefecture
      ? `${prefecture}${season ? '・' + season : ''}。${grandmaName ? grandmaName + 'さん' : '誰か'}の食卓から。`
      : `${r.title}`;
    const num = String(idx + 1).padStart(2, '0');
    return {
      id: r.id,
      title: r.title,
      img: r.photos.main,
      prefecture,
      num: `#${num}`,
      tag: `#${num} — ${prefecture}`,
      caption,
    };
  });

const grandmaTags = [
  { label: 'コトコト煮物おばあちゃん', tag: '煮物' },
  { label: '毎日ごはんおばあちゃん', tag: '日常のごはん' },
  { label: '山菜採りおばあちゃん', tag: '山菜' },
  { label: 'お正月おばあちゃん', tag: 'お正月' },
  { label: '郷土料理おばあちゃん', tag: '郷土料理' },
  { label: 'お惣菜名人', tag: '家庭料理' },
  { label: '常備菜の達人', tag: '常備菜' },
  { label: '保存食おばあちゃん', tag: '保存食' },
  { label: '春の味覚おばあちゃん', tag: '春の味覚' },
];

const categories = [
  { img: `${base}assets/images/categories/shirumono.png`, label: '汁物' },
  { img: `${base}assets/images/categories/shusai.png`,   label: '主菜' },
  { img: `${base}assets/images/categories/fukusai.png`,   label: '副菜' },
  { img: `${base}assets/images/categories/tsukemono.png`, label: '漬物' },
  { img: `${base}assets/images/categories/gohanmono.png`, label: 'ご飯もの' },
  { img: `${base}assets/images/categories/oyatsu.png`,    label: 'おやつ' },
];

const regionEmoji: Record<string, string> = {
  hokkaido: '🦀', tohoku: '🍎', kanto: '🍜', hokuriku: '🦀',
  koshinetsu: '⛰️', tokai: '🏯', kinki: '🦌', chugoku: '🐙',
  shikoku: '🍊', kyushu: '🌋',
};
const regionLabels: Record<string, string> = {
  hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
  koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
  shikoku: '四国', kyushu: '九州・沖縄',
};
---

<BaseLayout
  title="おばあちゃんのレシピ | 全国のおばあちゃんの手料理が集まる文化メディア"
  description="あの味、もう一度作れたら──。全国のおばあちゃんから届いた手料理レシピを、作り方・材料・思い出つきで。消えゆく家庭の味を記録する文化メディア。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://www.obaachan-recipe.com/#website",
          "url": "https://www.obaachan-recipe.com/",
          "name": "おばあちゃんのレシピ",
          "description": "全国のおばあちゃんの手料理が集まる文化メディア",
          "inLanguage": ["ja", "en"],
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://www.obaachan-recipe.com/search/?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://www.obaachan-recipe.com/#organization",
          "name": "おばあちゃんのレシピ",
          "url": "https://www.obaachan-recipe.com/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://www.obaachan-recipe.com/assets/images/grandma-icon.png"
          },
          "sameAs": [
            "https://www.instagram.com/obaachan_recipe",
            "https://www.threads.net/@obaachan_recipe",
            "https://note.com/obaachan_recipe"
          ]
        },
        {
          "@type": "ItemList",
          "name": "届いたばかりの味",
          "itemListElement": latest.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "url": `https://www.obaachan-recipe.com/recipes/${r.id}/`
          }))
        }
      ]
    })} />
  </Fragment>
  <Header />

  <main id="main" class="home">

    <!-- ヒーロー（pattern-c 風：巨大装飾＋中央フォトスライダー） -->
    <section class="home-hero" aria-label="ヒーロー">
      <div class="home-hero__giant-left" aria-hidden="true">食<br />卓</div>
      <div class="home-hero__giant-right" aria-hidden="true">お<br />ば<br />あ<br />ち<br />ゃ<br />ん<br />の</div>

      {sliderRecipes.length > 0 && (
        <div class="home-hero__photo">
          <div class="home-hero__slider" id="hero-slider" aria-roledescription="carousel" aria-label="最近届いたレシピ">
            <div class="home-hero__slides" id="hero-slides">
              {sliderRecipes.map((s, i) => (
                <a
                  href={`${base}recipes/${s.id}/`}
                  class="home-hero__slide"
                  data-num={s.tag}
                  data-title={s.caption}
                  data-index={i}
                  data-cta="hero-slider"
                  data-recipe-id={s.id}
                  aria-label={`${s.title}のレシピを見る（${s.prefecture}）`}
                  role="group"
                  aria-roledescription="slide"
                >
                  <img src={`${base}${s.img}`} alt={s.title} loading={i === 0 ? 'eager' : 'lazy'} width="640" height="854" />
                </a>
              ))}
            </div>
          </div>
          <div class="home-hero__dots" role="tablist" aria-label="スライダーナビゲーション">
            {sliderRecipes.map((_, i) => (
              <button
                class={`home-hero__dot${i === 0 ? ' is-active' : ''}`}
                data-index={i}
                aria-label={`${i + 1}番目のスライドへ`}
                aria-selected={i === 0 ? 'true' : 'false'}
                role="tab"
              ></button>
            ))}
          </div>
          <div class="home-hero__info" id="hero-info">
            <span class="home-hero__info-num">{sliderRecipes[0].tag}</span>
            <p class="home-hero__info-title">{sliderRecipes[0].caption}</p>
          </div>
        </div>
      )}

      <!-- おばあちゃん言葉（装飾） -->
      <span class="home-hero__kotoba" style="top:8%;left:2%;font-size:clamp(1.2rem,2.5vw,2rem);transform:rotate(-3deg)" aria-hidden="true">はよ食べ</span>
      <span class="home-hero__kotoba" style="top:22%;right:18%;font-size:clamp(0.9rem,1.8vw,1.4rem);transform:rotate(2deg)" aria-hidden="true">気持ち程度でええで</span>
      <span class="home-hero__kotoba" style="bottom:30%;left:1%;font-size:clamp(1rem,2vw,1.6rem);transform:rotate(-1deg)" aria-hidden="true">ひたひたになるまで</span>
      <span class="home-hero__kotoba" style="bottom:8%;right:3%;font-size:clamp(1.1rem,2.2vw,1.8rem);transform:rotate(3deg)" aria-hidden="true">適当でええんよ</span>
      <span class="home-hero__kotoba" style="top:55%;right:4%;font-size:clamp(1rem,1.8vw,1.4rem);transform:rotate(-4deg)" aria-hidden="true">目分量でよろし</span>
      <span class="home-hero__kotoba" style="top:15%;left:25%;font-size:clamp(0.85rem,1.5vw,1.2rem);transform:rotate(3deg)" aria-hidden="true">塩はひとつまみな</span>
      <span class="home-hero__kotoba" style="bottom:45%;left:12%;font-size:clamp(0.75rem,1.3vw,1rem);transform:rotate(-3deg)" aria-hidden="true">ぐるっと3周な</span>
      <span class="home-hero__kotoba" style="top:82%;right:15%;font-size:clamp(0.9rem,1.5vw,1.2rem);transform:rotate(1deg)" aria-hidden="true">手のひらくらい</span>
    </section>

    <!-- 新着レシピ：届いたばかりの味 -->
    <section class="home__latest" aria-labelledby="latest-heading">
      <header class="home__section-header">
        <p class="home__section-en">New arrivals</p>
        <h2 id="latest-heading" class="home__section-title">届いたばかりの味</h2>
      </header>
      <div class="home__latest-grid">
        {latest.map((recipe) => <RecipeCard recipe={recipe} />)}
      </div>
      <div class="home__section-footer">
        <a href={`${base}recipes/`} class="home__btn" data-cta="view-all-recipes">すべてのレシピを見る →</a>
      </div>
    </section>

    <!-- おばあちゃんから探す / カテゴリーから探す -->
    <section class="home__explore" aria-labelledby="explore-heading">
      <header class="home__section-header">
        <p class="home__section-en">Ways to explore</p>
        <h2 id="explore-heading" class="home__section-title">探し方</h2>
      </header>
      <div class="home__explore-tabs">
        <button class="home__explore-tab explore-tab explore-tab--active" data-tab="grandma">
          おばあちゃんから探す
        </button>
        <button class="home__explore-tab explore-tab" data-tab="recipe">
          カテゴリーから探す
        </button>
      </div>

      <div class="home__explore-panel explore-panel" id="panel-grandma">
        <div class="home__hashtag-cloud">
          {grandmaTags.map(({ label, tag }) => (
            <a href={`${base}recipes/?tag=${encodeURIComponent(tag)}`} class="home__hashtag-btn hashtag-btn" data-cta="hashtag-filter">{label}</a>
          ))}
        </div>
      </div>

      <div class="home__explore-panel explore-panel" id="panel-recipe" style="display:none">
        <div class="home__category-grid">
          {categories.map((c) => (
            <a href={`${base}recipes/?category=${encodeURIComponent(c.label)}`} class="home__category-btn category-btn" data-cta="category-filter">
              <img class="home__category-btn-img category-btn__img" src={c.img} alt={c.label} loading="lazy" />
              <span class="home__category-btn-label category-btn__label">{c.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 土地の記憶をたどる（日本地図ヒートマップ） -->
    <section class="home__regions-map" aria-labelledby="regions-heading">
      <header class="home__section-header">
        <p class="home__section-en">From each land</p>
        <h2 id="regions-heading" class="home__section-title">土地の記憶をたどる</h2>
      </header>
      <div class="home__map-container japan-map-container">
        <div class="home__map-wrapper japan-map-wrapper" id="japan-map-wrapper">
          <!-- SVG will be loaded here via fetch -->
        </div>
        <div class="home__map-tooltip japan-map-tooltip" id="map-tooltip" style="display:none"></div>
      </div>
      <div class="home__section-footer">
        <a href={`${base}regions/`} class="home__btn" data-cta="view-all-regions">地域一覧をすべて見る →</a>
      </div>
    </section>

    <!-- タイムマシン -->
    <section class="home__timemachine" aria-labelledby="timemachine-heading">
      <span class="home__timemachine-bg" aria-hidden="true">時</span>
      <div class="home__timemachine-inner">
        <p class="home__section-en" style="text-align:center">Time machine</p>
        <h2 id="timemachine-heading" class="home__timemachine-title">どこかの食卓へ</h2>
        <p class="home__timemachine-lead">
          何が出てくるかはわからない。<br />
          ランダムに、誰かの記憶の味に出会う。
        </p>
        <div class="tm-btn-wrapper">
          <a href="#" id="timemachine-btn" class="home__timemachine-btn btn btn--outline tm-btn-combined" data-cta="timemachine">
            <span class="tm-clock-icon" aria-hidden="true"></span>
            タイムマシンに乗る →
          </a>
          <span class="tm-gogogo tm-gogogo--1" aria-hidden="true">ゴゴゴゴ…</span>
          <span class="tm-gogogo tm-gogogo--2" aria-hidden="true">ゴゴゴ…</span>
          <span class="tm-gogogo tm-gogogo--3" aria-hidden="true">ゴ ゴ ゴ</span>
        </div>
      </div>
    </section>

    <!-- この活動について -->
    <section class="home__about" aria-labelledby="about-heading">
      <div class="home__about-inner">
        <div class="home__about-deco" aria-hidden="true">
          <img src={`${base}assets/images/grandma-icon.png`} alt="" class="home__about-deco-img" />
        </div>
        <h2 id="about-heading" class="home__about-title">この活動について</h2>
        <p class="home__about-text">
          計量カップは使わない。<br />
          タイマーも使わない。
        </p>
        <p class="home__about-text">
          「だいたいこのくらい」と<br />
          手のひらで量り、<br />
          「昔からこうやってきた」と<br />
          火加減を調整する。
        </p>
        <p class="home__about-text">
          その曖昧さの中に、<br />
          何十年もかけて磨かれた知恵がある。
        </p>
        <p class="home__about-text">
          残したいのはレシピじゃない。<br />
          一緒に食卓を囲んだ、あの時間。
        </p>
        <a href={`${base}about/`} class="home__about-btn" data-cta="about">このサイトについて →</a>
      </div>
    </section>

  </main>

  <Footer />

  <!-- タブ切り替え・地図読み込みJS -->
  <script type="application/json" id="recipe-images-data" set:html={JSON.stringify(recipesWithImages)}></script>
  <script define:vars={{ regionRecipeCount, base, recipeIds }}>
    // タブ切り替え
    document.querySelectorAll('.explore-tab').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.explore-tab').forEach((b) => b.classList.remove('explore-tab--active'));
        btn.classList.add('explore-tab--active');
        const tab = btn.dataset.tab;
        document.querySelectorAll('.explore-panel').forEach((p) => {
          p.style.display = p.id === `panel-${tab}` ? '' : 'none';
        });
      });
    });

    // 地図SVGの読み込みとヒートマップ
    const classToRegion = {
      'hokkaido': 'hokkaido',
      'tohoku': 'tohoku',
      'kanto': 'kanto',
      'ishikawa': 'hokuriku', 'toyama': 'hokuriku', 'fukui': 'hokuriku',
      'niigata': 'koshinetsu', 'nagano': 'koshinetsu', 'yamanashi': 'koshinetsu',
      'aichi': 'tokai', 'gifu': 'tokai', 'shizuoka': 'tokai', 'mie': 'tokai',
      'kinki': 'kinki',
      'chugoku': 'chugoku',
      'shikoku': 'shikoku',
      'kyushu': 'kyushu', 'kyushu-okinawa': 'kyushu',
    };
    const regionNames = {
      hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
      koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
      shikoku: '四国', kyushu: '九州・沖縄',
    };

    // 春夏秋冬カラーパレット
    const seasonalPalettes = {
      spring: ['#F5E6EC', '#E8B4C8', '#D4839E', '#C05A7A', '#A03060'],
      summer: ['#E0EEF5', '#A8D4E6', '#6BB5D4', '#3A8FB7', '#1B6691'],
      autumn: ['#E8DCC8', '#D4B896', '#C49A6C', '#A0703C', '#7D4E1E'],
      winter: ['#F0F2F5', '#D1D9E0', '#B0BEC5', '#8A9AA5', '#607D8B'],
    };
    function getCurrentSeason() {
      const m = new Date().getMonth() + 1;
      if (m >= 3 && m <= 5) return 'spring';
      if (m >= 6 && m <= 8) return 'summer';
      if (m >= 9 && m <= 11) return 'autumn';
      return 'winter';
    }
    function getColorForCount(count) {
      const palette = seasonalPalettes[getCurrentSeason()];
      if (count === 0) return palette[0];
      if (count <= 2) return palette[1];
      if (count <= 5) return palette[2];
      if (count <= 10) return palette[3];
      return palette[4];
    }

    const mapWrapper = document.getElementById('japan-map-wrapper');
    const mapTooltip = document.getElementById('map-tooltip');
    if (mapWrapper) {
      fetch(base + 'assets/japan-map.svg')
        .then(res => res.text())
        .then(svgText => {
          mapWrapper.innerHTML = svgText;
          const svgEl = mapWrapper.querySelector('svg');
          if (!svgEl) return;

          const prefGroups = svgEl.querySelectorAll('.prefecture');
          for (const g of prefGroups) {
            const classes = (g.className.baseVal || g.getAttribute('class') || '').split(/\s+/);
            let regionCode = null;
            for (const [cls, code] of Object.entries(classToRegion)) {
              if (classes.includes(cls)) { regionCode = code; break; }
            }
            if (!regionCode) continue;

            const count = regionRecipeCount[regionCode] ?? 0;
            const color = getColorForCount(count);

            g.setAttribute('fill', color);
            g.setAttribute('stroke', '#fff');
            g.setAttribute('stroke-width', '0.8');
            g.querySelectorAll('polygon, path').forEach(s => {
              s.setAttribute('fill', color);
              s.setAttribute('stroke', '#fff');
              s.setAttribute('stroke-width', '0.8');
            });

            g.addEventListener('mouseenter', () => {
              const name = regionNames[regionCode] ?? regionCode;
              mapTooltip.innerHTML = `<strong>${name}</strong>${count}件のレシピ`;
              mapTooltip.style.display = 'block';
            });
            g.addEventListener('mousemove', (e) => {
              mapTooltip.style.left = (e.clientX + 12) + 'px';
              mapTooltip.style.top = (e.clientY + 12) + 'px';
            });
            g.addEventListener('mouseleave', () => {
              mapTooltip.style.display = 'none';
            });

            g.style.cursor = 'pointer';
            g.addEventListener('click', () => {
              window.location.href = `/recipes?region=${regionCode}`;
            });
          }
        })
        .catch(err => console.warn('Japan map SVG の読み込みに失敗しました:', err));
    }

    // ヒーロースライダー（auto advance + dots nav + click-through preserve）
    (function() {
      const slider = document.getElementById('hero-slider');
      const slidesEl = document.getElementById('hero-slides');
      const info = document.getElementById('hero-info');
      if (!slider || !slidesEl) return;

      const slides = slidesEl.querySelectorAll('.home-hero__slide');
      const dots = document.querySelectorAll('.home-hero__dot');
      if (slides.length <= 1) return;

      let current = 0;
      let timerId = null;
      const INTERVAL = 5000;

      function goTo(i) {
        current = (i + slides.length) % slides.length;
        slidesEl.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, j) => {
          d.classList.toggle('is-active', j === current);
          d.setAttribute('aria-selected', j === current ? 'true' : 'false');
        });
        const slide = slides[current];
        const numEl = info?.querySelector('.home-hero__info-num');
        const titleEl = info?.querySelector('.home-hero__info-title');
        if (numEl) numEl.textContent = slide.dataset.num || '';
        if (titleEl) titleEl.textContent = slide.dataset.title || '';
      }

      function start() {
        stop();
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        timerId = setInterval(() => goTo(current + 1), INTERVAL);
      }
      function stop() {
        if (timerId) { clearInterval(timerId); timerId = null; }
      }

      dots.forEach((d) => {
        d.addEventListener('click', () => {
          goTo(parseInt(d.dataset.index || '0', 10));
          start();
        });
      });

      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);

      // Pause when out of view / tab hidden
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop(); else start();
      });
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => e.isIntersecting ? start() : stop());
        }, { threshold: 0.25 });
        io.observe(slider);
      } else {
        start();
      }
    })();

    // タイムマシンボタン: 料理フラッシュ → ランダムレシピへ遷移
    const recipesWithImgs = JSON.parse(document.getElementById('recipe-images-data')?.textContent || '[]');
    const tmBtn = document.getElementById('timemachine-btn');
    if (tmBtn) {
      tmBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const pool = recipesWithImgs.length > 0 ? recipesWithImgs : recipeIds.map(id => ({ id, img: null }));
        const pick = pool[Math.floor(Math.random() * pool.length)];
        const randomId = pick.id;

        const imgSrc = pick.img
          ? base + pick.img
          : null;

        const overlay = document.createElement('div');
        overlay.className = 'tm-overlay';
        overlay.innerHTML = `
          <div class="tm-overlay__bg"></div>
          ${imgSrc ? `<div class="tm-overlay__food" aria-hidden="true"><img src="${imgSrc}" alt="" /></div>` : ''}
          <div class="tm-overlay__flash"></div>
        `;
        document.body.appendChild(overlay);
        overlay.offsetHeight;
        overlay.classList.add('is-active');

        setTimeout(() => {
          const flash = overlay.querySelector('.tm-overlay__flash');
