---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes, getRecipeById, getTotalTime, getDifficultyLabel } from '../../data/recipes';
import type { Recipe } from '../../data/types';
import articlesData from '../../data/articles.json';

export async function getStaticPaths() {
  const recipes = getAllRecipes();
  return recipes.map((r) => ({ params: { id: r.id } }));
}

const { id } = Astro.params;
const recipe = getRecipeById(id!) as Recipe;

if (!recipe) {
  return Astro.redirect('/404');
}

const allRecipes = getAllRecipes();
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://www.obaachan-recipe.com';

// 基本データ
const grandmother = recipe.grandmother ?? {};
const region = recipe.region ?? {};
const meta = recipe.meta ?? {};
const tags = recipe.tags ?? [];
const servings = recipe.servings ?? 2;
const cookTime = recipe.cook_time_minutes;
const prepTime = recipe.prep_time_minutes;
const difficulty = recipe.difficulty;
const isEndangered = meta.is_endangered ?? false;
const imageUrl = recipe.photos?.main ?? recipe.photos?.thumbnail ?? '';
const areaCode = region.area ?? '';
const prefecture = grandmother.prefecture ?? region.prefecture ?? '';
const AREA_LABELS: Record<string, string> = {
  hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
  koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
  shikoku: '四国', kyushu: '九州・沖縄',
};
const areaLabel = AREA_LABELS[areaCode] ?? '';
const seasonArr = Array.isArray(recipe.season) ? recipe.season : [];
const story = recipe.story ?? '';
const episode = recipe.episode ?? '';
const culturalBg = recipe.cultural_background ?? '';
const source = recipe.source ?? { types: [], contributor: '' };
const grandmaNotes = recipe.grandma_notes ?? [];

const totalTime = getTotalTime(recipe);
const difficultyLabel = getDifficultyLabel(difficulty);

// 季節絵文字
const seasonEmojiMap: Record<string, string> = { '春': '🌸', '夏': '🌻', '秋': '🍁', '冬': '⛄', '通年': '🗓' };
const seasonEmoji = (s: string) => seasonEmojiMap[s] ?? '🗓';

// SEO: meta_description があればそちらを優先、なければ自動生成
const rawEpisode = (episode || story || '').replace(/<[^>]+>/g, '').replace(/\n/g, '');
const descPrefix = `${recipe.title}（${prefecture}）`;
const descBody = rawEpisode
  ? `── ${rawEpisode}`.slice(0, 85 - descPrefix.length)
  : `── ${prefecture}のおばあちゃんから届いた手料理`;
const description = (recipe as any).meta_description || (descPrefix + descBody);
const pageTitle = (recipe as any).seo_title || `${recipe.title}（${prefecture}）| おばあちゃんのレシピ`;

// GA4 tracking vars
const trackRecipeName = recipe.title;
const trackRecipeId = recipe.id;
const trackRegion = prefecture;
const trackArea = areaCode;
const trackCategory = recipe.category ?? '';
const ogImage = imageUrl
  ? `${siteUrl}/${imageUrl}`
  : `${siteUrl}/assets/images/grandma-icon.png`;
const pageUrl = `${siteUrl}/recipes/${recipe.id}/`;

// JSON-LD
const allIngredients = recipe.ingredients.flatMap((g) =>
  g.items.map((item) => {
    const base = `${item.name} ${item.amount ?? ''}${item.unit}`.trim();
    return item.approx_weight ? `${base}（約${item.approx_weight}）` : base;
  })
);

// image: 実レシピ画像があるときだけ URL 配列で指定（フォールバックアイコンは使わない）
const recipeImageUrl = imageUrl ? `${siteUrl}/${imageUrl}` : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: recipe.title,
  description,
  ...(recipeImageUrl ? { image: [recipeImageUrl] } : {}),
  url: pageUrl,
  datePublished: meta.created_at,
  author: { '@type': 'Organization', name: 'おばあちゃんのレシピ', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'おばあちゃんのレシピ', url: siteUrl, logo: { '@type': 'ImageObject', url: `${siteUrl}/assets/images/grandma-icon.png` } },
  recipeYield: `${servings}人分`,
  prepTime: `PT${prepTime}M`,
  cookTime: `PT${cookTime}M`,
  totalTime: `PT${prepTime + cookTime}M`,
  recipeCategory: recipe.category,
  recipeCuisine: '日本料理',
  keywords: tags.join(','),
  recipeIngredient: allIngredients,
  recipeInstructions: recipe.steps.map((s) => ({
    '@type': 'HowToStep',
    position: s.step,
    text: s.text,
    url: `${pageUrl}#step-${s.step}`,
    ...(s.tip ? { name: s.tip } : {}),
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'レシピ一覧', item: `${siteUrl}/recipes/` },
    { '@type': 'ListItem', position: 3, name: recipe.title, item: pageUrl },
  ],
};

// 関連レシピ（同地域 → 同カテゴリ → 新着の順でフォールバックして最大4件）
const RELATED_MAX = 4;
const sameArea = areaCode
  ? allRecipes.filter((r) => r.region?.area === areaCode && r.id !== recipe.id)
  : [];
const sameCategory = allRecipes.filter(
  (r) => r.category === recipe.category && r.id !== recipe.id &&
         !sameArea.some((s) => s.id === r.id)
);
const others = allRecipes.filter(
  (r) => r.id !== recipe.id &&
         !sameArea.some((s) => s.id === r.id) &&
         !sameCategory.some((s) => s.id === r.id)
);
const related = [...sameArea, ...sameCategory, ...others].slice(0, RELATED_MAX);

// 関連記事（地域タグ一致 → レシピタグ一致の優先順）
const AREA_TO_REGION: Record<string, string> = {
  hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
  koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
  shikoku: '四国', kyushu: '九州',
};
const regionName = AREA_TO_REGION[areaCode] ?? '';
const regionArticles = regionName
  ? (articlesData as any[]).filter((a: any) => a.tags?.includes(regionName))
  : [];
const tagArticles = (articlesData as any[]).filter((a: any) =>
  !regionArticles.some((ra: any) => ra.id === a.id) &&
  a.tags?.some((t: string) => tags.includes(t))
);
const relatedArticles = [...regionArticles, ...tagArticles].slice(0, 2);

// 似た料理（related_recipe_ids）
const relatedRecipeIds: string[] = (recipe as any).related_recipe_ids ?? [];
const similarRecipes = relatedRecipeIds
  .map((rid: string) => getRecipeById(rid))
  .filter((r): r is Recipe => r != null && r.id !== recipe.id);

// 食文化背景（文字列 or オブジェクト対応）
const bgHistory = typeof culturalBg === 'string' ? culturalBg : (culturalBg.history ?? story ?? '');
const bgIngredients = typeof culturalBg === 'object' && culturalBg !== null ? (culturalBg.local_ingredients ?? []).join('、') : '';
const bgSimilar = typeof culturalBg === 'object' && culturalBg !== null ? (culturalBg.similar_dishes ?? []).join('、') : '';
const hasBackground = bgHistory || bgIngredients;

// formatTime helper
function formatTime(minutes: number): string {
  if (!minutes) return '-';
  if (minutes >= 60) {
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m > 0 ? `${h}時間${m}分` : `${h}時間`;
  }
  return `${minutes}分`;
}

function difficultyStars(d: number): string {
  const labels = ['', '★☆☆', '★★☆', '★★★'];
  return labels[d] ?? '★☆☆';
}
---

<BaseLayout title={pageTitle} description={description} ogImage={ogImage} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <Header />

  <main id="main" class="recipe-detail">

    <!-- パンくず -->
    <nav class="recipe-detail__breadcrumb" aria-label="パンくずリスト">
      <div class="recipe-detail__breadcrumb-inner">
        <a href={base}>ホーム</a>
        <span aria-hidden="true"> › </span>
        <a href={`${base}recipes/`}>レシピ一覧</a>
        {areaCode && (
          <>
            <span aria-hidden="true"> › </span>
            <a href={`${base}region/${areaCode}/`}>{areaLabel}</a>
          </>
        )}
        <span aria-hidden="true"> › </span>
        <span aria-current="page">{recipe.title}</span>
      </div>
    </nav>

    <!-- ヒーロー -->
    <section class="recipe-detail__hero">
      <div class="recipe-detail__hero-visual">
        {imageUrl ? (
          <div class="recipe-detail__hero-img-wrap">
            <span class="recipe-detail__hero-kanban">{recipe.title}</span>
            <img
              class="recipe-detail__hero-img"
              src={`${base}${imageUrl}`}
              alt={recipe.title}
              width="1200"
              height="800"
              style={recipe.photos?.position ? `object-position: ${recipe.photos.position}` : ''}
            />
            <span class="recipe-detail__hero-note">※写真はイメージです</span>
          </div>
        ) : (
          <div class="recipe-detail__hero-img-wrap recipe-detail__hero-img-wrap--placeholder">
            <span class="recipe-detail__hero-kanban">{recipe.title}</span>
            <img
              class="recipe-detail__hero-img"
              src={`${base}assets/images/sample-placeholder.png.jpg`}
              alt="準備中"
              width="1200"
              height="800"
            />
          </div>
        )}
      </div>

      <div class="recipe-detail__hero-info">
        <p class="recipe-detail__hero-region">
          {prefecture && areaCode && <a href={`${base}region/${areaCode}/`}>{prefecture}</a>}
          {prefecture && !areaCode && prefecture}
          {seasonArr.length > 0 && (
            <span class="recipe-detail__hero-season">{seasonEmoji(seasonArr[0])} {seasonArr.join('・')}</span>
          )}
          {isEndangered && <span class="recipe-detail__hero-endangered">🕯 消えゆくレシピ</span>}
        </p>

        <h1 class="recipe-detail__title">{recipe.title}</h1>

        {recipe.category && (
          <p class="recipe-detail__subtitle">{recipe.category}{prefecture ? ` — ${prefecture}の味` : ''}</p>
        )}

        <ul class="recipe-detail__meta">
          {prepTime > 0 && (
            <li class="recipe-detail__meta-item">
              <span class="recipe-detail__meta-label">下準備</span>
              <span class="recipe-detail__meta-value">{formatTime(prepTime)}</span>
            </li>
          )}
          <li class="recipe-detail__meta-item">
            <span class="recipe-detail__meta-label">調理時間</span>
            <span class="recipe-detail__meta-value">{formatTime(cookTime)}</span>
          </li>
          <li class="recipe-detail__meta-item">
            <span class="recipe-detail__meta-label">人数</span>
            <span class="recipe-detail__meta-value" id="current-servings">{servings}人分</span>
          </li>
          <li class="recipe-detail__meta-item">
            <span class="recipe-detail__meta-label">難易度</span>
            <span class="recipe-detail__meta-value">{difficultyStars(difficulty)}</span>
          </li>
        </ul>

        <div class="recipe-detail__tags">
          {tags.map((t) => (
            <a href={`${base}recipes/?tag=${encodeURIComponent(t)}`} class="recipe-detail__tag">{t}</a>
          ))}
        </div>
      </div>
    </section>

    <!-- 材料 -->
    <section class="recipe-detail__ingredients" aria-labelledby="ingredients-heading">
      <div class="recipe-detail__ingredients-inner">
        <div class="recipe-detail__ingredients-head">
          <h2 class="recipe-detail__section-title" id="ingredients-heading">材料</h2>
          <p class="recipe-detail__ingredients-en">Ingredients</p>
          <div class="servings-control">
            <button class="servings-btn" id="servings-minus" aria-label="人数を減らす">−</button>
            <span class="servings-display"><output id="servings-output">{servings}</output>人分</span>
            <button class="servings-btn" id="servings-plus" aria-label="人数を増やす">＋</button>
          </div>
        </div>

        <div class="recipe-detail__ingredients-body">
          <div class="measure-toggle">
            <button class="measure-toggle__btn measure-toggle__btn--active" data-mode="grandma">
              👵 おばあちゃん流
            </button>
            <button class="measure-toggle__btn" data-mode="precise">
              ⚖️ きっちり計量
            </button>
          </div>
          <p class="ingredient__approx-note">※ おばあちゃんのレシピでは「だいたいこのくらい」で作ることも多いため、分量は目安としてご覧ください。</p>
          <table class="ingredient-table">
            <tbody id="ingredient-tbody">
              {recipe.ingredients.map((group) => (
                <>
                  {group.group && (
                    <tr class="ingredient-group-header">
                      <td colspan="2" class="ingredient__group">{group.group}</td>
                    </tr>
                  )}
                  {group.items.map((ing) => (
                    <tr class="ingredient-row" data-base-amount={String(ing.amount ?? '')} data-unit={ing.unit ?? ''} data-base-unit={ing.unit ?? ''}>
                      <td class="ingredient__name">{ing.name}</td>
                      <td class="ingredient__amount">
                        {ing.grandma_amount ? (
                          <>
                            <span class="ingredient__grandma">{ing.grandma_amount}</span>
                            <span class="ingredient__precise" style="display:none">
                              <span class="ingredient__qty">{String(ing.amount ?? '')}</span><span class="ingredient__unit-text">{ing.unit ?? ''}</span>{ing.approx_weight && <span class="ingredient__approx-weight">（約{ing.approx_weight}）</span>}
                            </span>
                          </>
                        ) : (
                          <span class="ingredient__precise-always">
                            <span class="ingredient__qty">{String(ing.amount ?? '')}</span><span class="ingredient__unit-text">{ing.unit ?? ''}</span>{ing.approx_weight && <span class="ingredient__approx-weight">（約{ing.approx_weight}）</span>}
                          </span>
                        )}
                        {ing.note && <small class="ingredient__note">（{ing.note}）</small>}
                      </td>
                    </tr>
                  ))}
                </>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- 作り方 -->
    <section class="recipe-detail__steps" aria-labelledby="steps-heading">
      <header class="recipe-detail__steps-head">
        <h2 class="recipe-detail__section-title" id="steps-heading">作り方</h2>
        <p class="recipe-detail__steps-en">How to cook</p>
      </header>
      <ol class="step-list">
        {recipe.steps.map((step, i) => (
          <li class="step" id={`step-${step.step ?? (i + 1)}`}>
            <div class="step__num">{String(step.step ?? (i + 1)).padStart(2, '0')}</div>
            <div class="step__content">
              {step.title && <p class="step__title">{step.title}</p>}
              <p class="step__text">{step.text}</p>
              {step.tip && <p class="step__tip">💡 {step.tip}</p>}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- 思い出・エピソード（ダーク背景） -->
    {episode && (
      <section class="recipe-detail__episode" aria-labelledby="episode-heading">
        <span class="recipe-detail__episode-bg" aria-hidden="true">{prefecture ? prefecture.replace(/[都府県]$/, '') : '味'}</span>
        <div class="recipe-detail__episode-inner">
          <p class="recipe-detail__episode-en">Story</p>
          <h2 class="recipe-detail__episode-title" id="episode-heading">📖 思い出・エピソード</h2>
          <div class="episode-block">
            <p class="episode-block__text" set:html={episode} />
            {source && (
              <div class="episode-block__source">
                <span class="episode-block__source-label">情報源：</span>
                {source.types.map((t) => <span class="episode-block__source-tag">{t}</span>)}
                {source.contributor && <span class="episode-block__contributor">（投稿者：{source.contributor}さん）</span>}
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- 食文化の背景 -->
    {hasBackground && (
      <section class="recipe-detail__background" aria-labelledby="background-heading">
        <div class="recipe-detail__background-inner">
          <h2 class="recipe-detail__section-title" id="background-heading">🍽 食文化の背景</h2>
          <div class="background-block">
            {bgHistory && <p class="background-block__text" set:html={bgHistory} />}
            {bgIngredients && <p class="background-block__text"><strong>この地域の特産食材：</strong>{bgIngredients}</p>}
            {bgSimilar && <p class="background-block__text"><strong>似た料理：</strong>{bgSimilar}</p>}
          </div>
        </div>
      </section>
    )}

    <!-- 関連レシピ -->
    {related.length > 0 && (
      <section class="recipe-detail__related" aria-labelledby="related-heading">
        <header class="recipe-detail__related-head">
          <h2 class="recipe-detail__section-title" id="related-heading">🍽 {areaLabel ? `${areaLabel}のレシピ` : 'おすすめのレシピ'}</h2>
          <p class="recipe-detail__related-en">More recipes</p>
        </header>
        <div class="recipe-detail__related-grid">
          {related.map((r) => <RecipeCard recipe={r} />)}
        </div>
      </section>
    )}

    <!-- 似た料理（related_recipe_ids） -->
    {similarRecipes.length > 0 && (
      <section class="recipe-detail__related" aria-labelledby="similar-heading">
        <header class="recipe-detail__related-head">
          <h2 class="recipe-detail__section-title" id="similar-heading">🍳 似た料理</h2>
          <p class="recipe-detail__related-en">Similar dishes</p>
        </header>
        <div class="recipe-detail__related-grid">
          {similarRecipes.map((r) => <RecipeCard recipe={r} />)}
        </div>
      </section>
    )}

    <!-- 関連する読み物 -->
    {relatedArticles.length > 0 && (
      <section class="recipe-detail__related-articles" aria-labelledby="related-articles-heading">
        <header class="recipe-detail__related-head">
          <h2 class="recipe-detail__section-title" id="related-articles-heading">📖 関連する読み物</h2>
          <p class="recipe-detail__related-en">Related articles</p>
        </header>
        <div class="related-articles__grid">
          {relatedArticles.map((ra: any) => {
            const raDate = ra.published_at.replace(/-/g, '.').slice(2);
            return (
              <a
                href={`${base}articles/${ra.id}/`}
                class="related-article-card"
                data-cta="recipe-to-article"
              >
                <div class="related-article-card__emoji" aria-hidden="true">{ra.thumbnail_emoji}</div>
                <div class="related-article-card__body">
                  <span class="related-article-card__category">{ra.category}</span>
                  <h3 class="related-article-card__title">{ra.title.replace(/\n/g, '')}</h3>
                  <p class="related-article-card__lead">{ra.lead.slice(0, 60)}…</p>
                  <time class="related-article-card__date" datetime={ra.published_at}>{raDate}</time>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </main>

  <Footer />

  <!-- 人数変更 & おばあちゃん流/きっちり計量トグル (既存ロジックそのまま) -->
  <script define:vars={{ servings }}>
    let currentServings = Number(servings) || 2;
    const baseServings = currentServings;
    const output = document.getElementById('servings-output');
    const tbody = document.getElementById('ingredient-tbody');
    const currentServingsEl = document.getElementById('current-servings');

    function formatScaled(val) {
      return Number.isInteger(val) ? String(val) : val.toFixed(1);
    }

    function updateServings(n) {
      currentServings = Math.max(1, Math.min(20, n));
      if (output) output.textContent = String(currentServings);
      if (currentServingsEl) currentServingsEl.textContent = `${currentServings}人分`;
      if (!tbody) return;
      const ratio = currentServings / baseServings;
      tbody.querySelectorAll('.ingredient-row').forEach((row) => {
        const base = parseFloat(row.dataset.baseAmount);
        const unit = row.dataset.unit || '';
        const qtyEl = row.querySelector('.ingredient__qty');
        if (qtyEl && !isNaN(base) && base !== 0) {
          const scaled = base * ratio;
          qtyEl.textContent = formatScaled(scaled);
        }
        const baseUnit = row.dataset.baseUnit;
        if (baseUnit) {
          row.querySelectorAll('.ingredient__precise .ingredient__unit-text, .ingredient__precise-always .ingredient__unit-text').forEach((el) => {
            const m = baseUnit.match(/^(.+?)(\d+(?:\.\d+)?(?:\/\d+)?)(.*)$/);
            if (m) {
              const num = parseFloat(m[2]);
              const scaled = num * ratio;
              el.textContent = m[1] + formatScaled(scaled) + m[3];
            }
          });
        }
      });
    }

    const minusBtn = document.getElementById('servings-minus');
    const plusBtn = document.getElementById('servings-plus');
    if (minusBtn) minusBtn.addEventListener('click', () => updateServings(currentServings - 1));
    if (plusBtn) plusBtn.addEventListener('click', () => updateServings(currentServings + 1));

    const toggleBtns = document.querySelectorAll('.measure-toggle__btn');
    toggleBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        toggleBtns.forEach((b) => b.classList.remove('measure-toggle__btn--active'));
        btn.classList.add('measure-toggle__btn--active');
        const mode = btn.dataset.mode;
        if (!tbody) return;
        const grandmaEls = tbody.querySelectorAll('.ingredient__grandma');
        const preciseEls = tbody.querySelectorAll('.ingredient__precise');
        if (mode === 'grandma') {
          grandmaEls.forEach((el) => { if (el.textContent.trim()) el.style.display = ''; });
          preciseEls.forEach((el) => { el.style.display = 'none'; });
        } else {
          grandmaEls.forEach((el) => { el.style.display = 'none'; });
          preciseEls.forEach((el) => { el.style.display = ''; });
        }
      });
    });
  </script>

  <!-- GA4: recipe_view (既存ロジックそのまま) -->
  <script define:vars={{ trackRecipeName, trackRecipeId, trackRegion, trackArea, trackCategory }}>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof gtag === 'function') {
        var isDev = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
        var params = {
          recipe_name: trackRecipeName,
          recipe_id: trackRecipeId,
          region: trackRegion,
          area: trackArea,
          category: trackCategory,
          page_location: location.href
        };
        if (isDev) console.log('[GA4] recipe_view', params);
        gtag('event', 'recipe_view', params);
      }
    }, { once: true });
  </script>
</BaseLayout>

<style>
  /* Recipe detail page (pattern-c scoped) */
  .recipe-detail {
    font-family: 'Noto Sans JP', sans-serif;
    color: #222;
    background: #f0ece4;
  }

  /* Breadcrumb */
  .recipe-detail__breadcrumb {
    padding: 1rem 5% 0.2rem;
  }
  .recipe-detail__breadcrumb-inner {
    max-width: 1200px;
    margin: 0 auto;
    font-size: 0.68rem;
    color: #999;
    letter-spacing: 0.04em;
  }
  .recipe-detail__breadcrumb a {
    color: #999;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .recipe-detail__breadcrumb a:hover { color: #222; }
  .recipe-detail__breadcrumb span { margin: 0 0.1em; }

  /* Hero: 2-column on desktop */
  .recipe-detail__hero {
    max-width: 1200px;
    max-height: none;
    height: auto;
    margin: 0 auto;
    padding: 1.5rem 5% 3.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  /* Hero visual */
  .recipe-detail__hero-visual {
    position: relative;
  }
  .recipe-detail__hero-img-wrap {
    position: relative;
  }
  .recipe-detail__hero-img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1.5px solid #222;
  }
  .recipe-detail__hero-kanban {
    position: absolute;
    top: 1.2rem;
    left: -1rem;
    z-index: 3;
    background: #f5f0e6;
    border: 2px solid #222;
    padding: 0.7em 0.55em;
    writing-mode: vertical-rl;
    font-family: 'Shippori Mincho', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #222;
    letter-spacing: 0.18em;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 2px 3px 0 rgba(0, 0, 0, 0.1);
    max-height: 70%;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .recipe-detail__hero-note {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.65rem;
    color: #aaa;
    letter-spacing: 0.04em;
    text-align: right;
  }

  /* Hero info */
  .recipe-detail__hero-info {
    padding-top: 0.5rem;
  }
  .recipe-detail__hero-region {
    margin: 0 0 0.8rem;
    font-family: 'Playfair Display', serif;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: #888;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
  .recipe-detail__hero-region a {
    color: #888;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .recipe-detail__hero-region a:hover {
    color: #222;
    border-bottom-color: #222;
  }
  .recipe-detail__hero-season,
  .recipe-detail__hero-endangered {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.68rem;
    padding: 0.2em 0.7em;
    border: 1px solid #ccc;
    letter-spacing: 0.06em;
  }
  .recipe-detail__hero-endangered {
    color: #8a5a1a;
    border-color: #c9a168;
    background: rgba(201, 161, 104, 0.08);
  }
  .recipe-detail__title {
    margin: 0 0 0.5rem;
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 800;
    line-height: 1.35;
    letter-spacing: 0.04em;
    color: #222;
  }
  .recipe-detail__subtitle {
    margin: 0 0 1.8rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: #aaa;
  }

  .recipe-detail__meta {
    list-style: none;
    padding: 1.2rem 0 1.4rem;
    margin: 0 0 1.5rem;
    border-top: 1px solid #d8d3c8;
    border-bottom: 1px solid #d8d3c8;
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem 2rem;
  }
  .recipe-detail__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .recipe-detail__meta-label {
    font-size: 0.6rem;
    color: #999;
    letter-spacing: 0.1em;
  }
  .recipe-detail__meta-value {
    font-family: 'Shippori Mincho', serif;
    font-size: 1rem;
    font-weight: 600;
    color: #222;
  }

  .recipe-detail__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .recipe-detail__tag {
    font-size: 0.68rem;
    color: #666;
    border: 1px solid #d0ccc4;
    padding: 0.3em 0.9em;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .recipe-detail__tag:hover {
    background: #222;
    color: #f0ece4;
    border-color: #222;
  }

  /* Section titles (common) */
  .recipe-detail__section-title {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(1.3rem, 2.6vw, 1.8rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #222;
  }

  /* Ingredients section (white bg) */
  .recipe-detail__ingredients {
    background: #fff;
    padding: 4rem 5%;
  }
  .recipe-detail__ingredients-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .recipe-detail__ingredients-head {
    position: sticky;
    top: 80px;
  }
  .recipe-detail__ingredients-en {
    margin: 0.3rem 0 1rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: #aaa;
  }

  /* Servings control */
  .recipe-detail__ingredients :global(.servings-control) {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.8rem;
    border: 1px solid #e0dcd4;
    font-size: 0.8rem;
  }
  .recipe-detail__ingredients :global(.servings-btn) {
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.95rem;
    color: #222;
    background: transparent;
    border: 1px solid #222;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .recipe-detail__ingredients :global(.servings-btn:hover) {
    background: #222;
    color: #f0ece4;
  }
  .recipe-detail__ingredients :global(.servings-display) {
    font-family: 'Shippori Mincho', serif;
    font-weight: 600;
    letter-spacing: 0.05em;
    min-width: 4em;
    text-align: center;
  }

  /* Measure toggle */
  .recipe-detail__ingredients :global(.measure-toggle) {
    display: flex;
    gap: 0;
    margin-bottom: 0.8rem;
    border: 1.5px solid #222;
  }
  .recipe-detail__ingredients :global(.measure-toggle__btn) {
    flex: 1 1 0;
    padding: 0.6rem 0.8rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #444;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .recipe-detail__ingredients :global(.measure-toggle__btn + .measure-toggle__btn) {
    border-left: 1px solid #222;
  }
  .recipe-detail__ingredients :global(.measure-toggle__btn:hover) {
    background: rgba(34, 34, 34, 0.06);
  }
  .recipe-detail__ingredients :global(.measure-toggle__btn--active) {
    background: #222;
    color: #f0ece4;
  }
  .recipe-detail__ingredients :global(.measure-toggle__btn--active:hover) {
    background: #222;
  }

  .recipe-detail__ingredients :global(.ingredient__approx-note) {
    margin: 0 0 1rem;
    font-size: 0.7rem;
    color: #999;
    letter-spacing: 0.04em;
    line-height: 1.7;
  }

  /* Ingredient table */
  .recipe-detail__ingredients :global(.ingredient-table) {
    width: 100%;
    border-collapse: collapse;
  }
  .recipe-detail__ingredients :global(.ingredient-group-header .ingredient__group) {
    padding: 0.9rem 0 0.3rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #222;
    border-bottom: 2px solid #222;
  }
  .recipe-detail__ingredients :global(.ingredient-row) {
    border-bottom: 1px solid #eee;
  }
  .recipe-detail__ingredients :global(.ingredient-row:first-child) {
    border-top: 1px solid #eee;
  }
  .recipe-detail__ingredients :global(.ingredient-row .ingredient__name) {
    padding: 0.9rem 1rem 0.9rem 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: #222;
    vertical-align: baseline;
    line-height: 1.6;
  }
  .recipe-detail__ingredients :global(.ingredient-row .ingredient__amount) {
    padding: 0.9rem 0;
    font-size: 0.82rem;
    color: #666;
    text-align: right;
    white-space: normal;
    word-break: break-word;
    vertical-align: baseline;
    line-height: 1.6;
  }
  .recipe-detail__ingredients :global(.ingredient__grandma) {
    font-family: 'Shippori Mincho', serif;
    font-style: italic;
    font-size: 0.82rem;
    color: #8a847a;
  }
  .recipe-detail__ingredients :global(.ingredient__precise),
  .recipe-detail__ingredients :global(.ingredient__precise-always) {
    display: inline;
  }
  .recipe-detail__ingredients :global(.ingredient__qty) {
    font-family: 'Shippori Mincho', serif;
    font-weight: 600;
    color: #333;
  }
  .recipe-detail__ingredients :global(.ingredient__unit-text) {
    margin-left: 0.1em;
    color: #555;
  }
  .recipe-detail__ingredients :global(.ingredient__approx-weight) {
    display: inline-block;
    margin-left: 0.3em;
    font-size: 0.68rem;
    color: #aaa;
  }
  .recipe-detail__ingredients :global(.ingredient__note) {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.68rem;
    color: #a8a39a;
  }

  /* Steps */
  .recipe-detail__steps {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 5%;
  }
  .recipe-detail__steps-head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .recipe-detail__steps-en {
    margin: 0.3rem 0 0;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    color: #aaa;
  }

  .recipe-detail__steps :global(.step-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .recipe-detail__steps :global(.step) {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    align-items: start;
  }
  .recipe-detail__steps :global(.step__num) {
    font-family: 'Playfair Display', serif;
    font-size: 2.3rem;
    font-weight: 700;
    color: #b8b0a4;
    line-height: 1;
    text-align: right;
    padding-top: 0.15rem;
    font-style: italic;
    letter-spacing: -0.02em;
  }
  .recipe-detail__steps :global(.step__content) {
    border-left: 2px solid #d8d3c8;
    padding: 0 0 1.2rem 1.5rem;
    position: relative;
  }
  .recipe-detail__steps :global(.step:last-child .step__content) {
    border-left-color: transparent;
    padding-bottom: 0;
  }
  .recipe-detail__steps :global(.step__title) {
    margin: 0 0 0.6rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #222;
  }
  .recipe-detail__steps :global(.step__text) {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.94rem;
    line-height: 2.2;
    color: #444;
    text-wrap: pretty;
  }
  .recipe-detail__steps :global(.step__tip) {
    margin: 0.9rem 0 0;
    padding: 0.6rem 0.9rem;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.82rem;
    font-style: italic;
    color: #888;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 2px;
  }

  /* Episode (dark section) */
  .recipe-detail__episode {
    position: relative;
    overflow: hidden;
    background: #222;
    color: #fff;
    padding: 5rem 5%;
    margin-top: 1rem;
  }
  .recipe-detail__episode-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(10rem, 28vw, 22rem);
    font-weight: 800;
    color: rgba(255, 255, 255, 0.03);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    z-index: 0;
  }
  .recipe-detail__episode-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
  }
  .recipe-detail__episode-en {
    margin: 0 0 0.5rem;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: #6a6560;
    text-align: center;
  }
  .recipe-detail__episode-title {
    margin: 0 0 2rem;
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(1.2rem, 2.4vw, 1.7rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #f0ece4;
    text-align: center;
  }
  /* override existing global .episode-block white-box styling */
  .recipe-detail__episode :global(.episode-block) {
    background: transparent;
    padding: 0;
    border: none;
    box-shadow: none;
  }
  .recipe-detail__episode :global(.episode-block__text) {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.92rem;
    line-height: 2.4;
    color: rgba(240, 236, 228, 0.82);
    margin: 0 0 1.5rem;
  }
  .recipe-detail__episode :global(.episode-block__text strong) {
    color: #f0ece4;
    font-weight: 600;
  }
  .recipe-detail__episode :global(.episode-block__source) {
    margin-top: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(240, 236, 228, 0.12);
    font-size: 0.72rem;
    color: rgba(240, 236, 228, 0.55);
    letter-spacing: 0.06em;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.5rem;
    align-items: baseline;
  }
  .recipe-detail__episode :global(.episode-block__source-label) {
    color: rgba(240, 236, 228, 0.7);
  }
  .recipe-detail__episode :global(.episode-block__source-tag) {
    padding: 0.15em 0.6em;
    border: 1px solid rgba(240, 236, 228, 0.3);
  }
  .recipe-detail__episode :global(.episode-block__contributor) {
    color: rgba(240, 236, 228, 0.7);
  }

  /* Background (food culture) */
  .recipe-detail__background {
    padding: 4rem 5%;
  }
  .recipe-detail__background-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .recipe-detail__background :global(.background-block) {
    margin-top: 1.4rem;
    padding: 1.6rem 1.8rem;
    background: #fff;
    border-left: 3px solid #222;
  }
  .recipe-detail__background :global(.background-block__text) {
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    line-height: 2.2;
    color: #555;
    margin: 0 0 0.8rem;
  }
  .recipe-detail__background :global(.background-block__text:last-child) {
    margin-bottom: 0;
  }
  .recipe-detail__background :global(.background-block__text strong) {
    color: #222;
    font-weight: 700;
  }

  /* Related recipes / similar */
  .recipe-detail__related,
  .recipe-detail__related-articles {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem 5%;
  }
  .recipe-detail__related-head {
    text-align: center;
    margin-bottom: 2.2rem;
  }
  .recipe-detail__related-en {
    margin: 0.3rem 0 0;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: #aaa;
  }
  .recipe-detail__related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.4rem;
  }

  /* RecipeCard overrides (same look as /recipes/ grid for consistency) */
  .recipe-detail__related-grid :global(.recipe-card) {
    height: 100%;
    background: #fff;
    border: 1.5px solid #222;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .recipe-detail__related-grid :global(.recipe-card:hover) {
    transform: translateY(-4px);
    box-shadow: 6px 6px 0 #222;
  }
  .recipe-detail__related-grid :global(.recipe-card__link) {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }
  .recipe-detail__related-grid :global(.recipe-card__thumb) {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f2ec;
  }
  .recipe-detail__related-grid :global(.recipe-card__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .recipe-detail__related-grid :global(.recipe-card__region-badge) {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    padding: 0.22em 0.7em;
    background: rgba(34, 34, 34, 0.88);
    color: #f0ece4;
    font-size: 0.62rem;
    font-family: 'Shippori Mincho', serif;
    letter-spacing: 0.08em;
  }
  .recipe-detail__related-grid :global(.recipe-card__body) {
    padding: 0.9rem 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1 1 auto;
  }
  .recipe-detail__related-grid :global(.recipe-card__title) {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.94rem;
    font-weight: 700;
    line-height: 1.55;
    letter-spacing: 0.03em;
    color: #222;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .recipe-detail__related-grid :global(.recipe-card__tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    min-height: 1.35rem;
  }
  .recipe-detail__related-grid :global(.recipe-card__tag) {
    font-size: 0.58rem;
    color: #888;
    border: 1px solid #d0ccc4;
    padding: 0.15em 0.6em;
    letter-spacing: 0.04em;
  }
  .recipe-detail__related-grid :global(.recipe-card__meta) {
    list-style: none;
    margin: auto 0 0;
    padding: 0.5rem 0 0;
    border-top: 1px dashed #e0dcd4;
    display: flex;
    gap: 0.7rem;
    font-size: 0.64rem;
    color: #777;
    flex-wrap: wrap;
  }

  /* Related articles */
  .recipe-detail__related-articles :global(.related-articles__grid) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .recipe-detail__related-articles :global(.related-article-card) {
    display: flex;
    gap: 1rem;
    padding: 1.2rem;
    background: #fff;
    border: 1px solid #e0dcd4;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .recipe-detail__related-articles :global(.related-article-card:hover) {
    transform: translateY(-3px);
    border-color: #222;
  }
  .recipe-detail__related-articles :global(.related-article-card__emoji) {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f2ec;
    border: 1px solid #e0dcd4;
    font-size: 2rem;
  }
  .recipe-detail__related-articles :global(.related-article-card__body) {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .recipe-detail__related-articles :global(.related-article-card__category) {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: #999;
  }
  .recipe-detail__related-articles :global(.related-article-card__title) {
    margin: 0;
    font-family: 'Shippori Mincho', serif;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.55;
    color: #222;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .recipe-detail__related-articles :global(.related-article-card__lead) {
    margin: 0;
    font-size: 0.72rem;
    color: #777;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .recipe-detail__related-articles :global(.related-article-card__date) {
    margin-top: auto;
    font-size: 0.62rem;
    color: #bbb;
    letter-spacing: 0.06em;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .recipe-detail__hero {
      display: block;
      padding: 1rem 5% 2.5rem;
    }
    .recipe-detail__hero-visual {
      margin-bottom: 2rem;
