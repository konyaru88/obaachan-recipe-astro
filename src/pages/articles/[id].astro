---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import articlesData from '../../data/articles.json';
import { getRecipeById, getTotalTime, getDifficultyLabel } from '../../data/recipes';

export function getStaticPaths() {
  return articlesData.map((a: any) => ({ params: { id: a.id } }));
}

const base = import.meta.env.BASE_URL;
const { id } = Astro.params;
const article = articlesData.find((a: any) => a.id === id) as any;

// タグ→リンク先マッピング
const REGION_MAP: Record<string, string> = {
  '北海道': 'hokkaido', '東北': 'tohoku', '関東': 'kanto', '北陸': 'hokuriku',
  '甲信越': 'koshinetsu', '東海': 'tokai', '近畿': 'kinki', '中国': 'chugoku',
  '四国': 'shikoku', '九州': 'kyushu',
};
function tagToUrl(tag: string): string {
  if (REGION_MAP[tag]) return `${base}region/${REGION_MAP[tag]}/`;
  return `${base}recipes/?tag=${encodeURIComponent(tag)}`;
}

if (!article) {
  return Astro.redirect('/404');
}

const siteUrl = 'https://www.obaachan-recipe.com';
const pageUrl = `${siteUrl}/articles/${article.id}/`;
const date = article.published_at.replace(/-/g, '.').slice(2);
const pageTitle = (article as any).seo_title ?? `${article.title.replace(/\n/g, '')} | おばあちゃんのレシピ`;
const pageDescription = article.meta_description ?? (article.lead.slice(0, 120) + '…');

// レシピカードHTMLを生成
function buildRecipeCardHtml(recipeId: string): string {
  const recipe = getRecipeById(recipeId);
  if (!recipe) return '';
  const prefecture = recipe.grandmother?.prefecture ?? recipe.region?.prefecture ?? '';
  const timeStr = getTotalTime(recipe);
  const stars = getDifficultyLabel(recipe.difficulty);
  const servingsStr = recipe.servings ? `${recipe.servings}人分` : '-';
  const imageUrl = recipe.photos?.main ?? recipe.photos?.thumbnail ?? '';
  const tags = recipe.tags.slice(0, 3).map((t: string) => `<span class="recipe-card__tag">${t}</span>`).join('');
  const imgHtml = imageUrl
    ? `<img class="recipe-card__image" src="${base}${imageUrl}" alt="${recipe.title}" loading="lazy" />`
    : `<img class="recipe-card__image recipe-card__image--placeholder" src="${base}assets/images/sample-placeholder.png.jpg" alt="準備中" loading="lazy" />`;
  return `<div class="article-recipe-card">
    <article class="recipe-card">
      <a href="${base}recipes/${recipe.id}/" class="recipe-card__link" aria-label="${recipe.title}のレシピを見る">
        <div class="recipe-card__thumb${imageUrl ? '' : ' recipe-card__image-placeholder'}">
          ${imgHtml}
          ${prefecture ? `<span class="recipe-card__region-badge">${prefecture}</span>` : ''}
        </div>
        <div class="recipe-card__body">
          <h3 class="recipe-card__title">${recipe.title}</h3>
          <div class="recipe-card__tags">${tags}</div>
          <ul class="recipe-card__meta">
            <li class="recipe-card__meta-item">⏱ ${timeStr}</li>
            <li class="recipe-card__meta-item">👥 ${servingsStr}</li>
            <li class="recipe-card__meta-item" aria-label="難易度">${stars}</li>
          </ul>
        </div>
      </a>
    </article>
  </div>`;
}

// 本文をHTMLに変換
function formatInline(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\((\/[^)]+)\)/g, (_: string, t: string, href: string) =>
      `<a href="${base}${href.slice(1)}" class="article-content__link">${t}</a>`)
    .replace(/\[([^\]]+)\]\((https?:[^)]+)\)/g, (_: string, t: string, href: string) =>
      `<a href="${href}" class="article-content__link" target="_blank" rel="noopener noreferrer">${t}</a>`);
}

function formatBody(body: string): string {
  return body
    .split('\n\n')
    .flatMap((para: string) => {
      const trimmed = para.trim();
      if (trimmed === '---') return '<hr class="article-content__divider">';
      // レシピカード埋め込み
      const recipeMatch = trimmed.match(/^\{\{recipe:(.+?)\}\}$/);
      if (recipeMatch) return buildRecipeCardHtml(recipeMatch[1]);
      if (trimmed.startsWith('### ')) {
        const lines = trimmed.split('\n');
        const heading = `<h3 class="article-content__subheading">${formatInline(lines[0].slice(4))}</h3>`;
        if (lines.length > 1) {
          const rest = lines.slice(1).join('\n').trim().replace(/\n/g, '<br>');
          return [heading, `<p>${formatInline(rest)}</p>`];
        }
        return [heading];
      }
      if (trimmed.startsWith('## ')) {
        const lines = trimmed.split('\n');
        const heading = `<h2 class="article-content__heading">${formatInline(lines[0].slice(3))}</h2>`;
        if (lines.length > 1) {
          const rest = lines.slice(1).join('\n').trim().replace(/\n/g, '<br>');
          return [heading, `<p>${formatInline(rest)}</p>`];
        }
        return [heading];
      }
      const html = trimmed.replace(/\n/g, '<br>');
      return [`<p>${formatInline(html)}</p>`];
    })
    .join('');
}

const bodyHtml = formatBody(article.body);

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '読み物', item: `${siteUrl}/articles/` },
    { '@type': 'ListItem', position: 3, name: article.title.replace(/\n/g, ''), item: pageUrl },
  ],
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title.replace(/\n/g, ''),
  description: pageDescription,
  datePublished: article.published_at,
  author: { '@type': 'Organization', name: 'おばあちゃんのレシピ' },
  publisher: {
    '@type': 'Organization',
    name: 'おばあちゃんのレシピ',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/assets/images/grandma-icon.png` },
  },
  mainEntityOfPage: pageUrl,
};

const faqLd = article.faq && article.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faq.map((item: any) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
} : null;

// 関連読み物：同カテゴリ優先、最大3件
const otherArticles = articlesData.filter((a: any) => a.id !== article.id);
const sameCategory = otherArticles.filter((a: any) => a.category_slug === article.category_slug);
const diffCategory = otherArticles.filter((a: any) => a.category_slug !== article.category_slug);
const relatedArticles = [...sameCategory, ...diffCategory].slice(0, 3);
---

<BaseLayout title={pageTitle} description={pageDescription} ogType="article">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  {faqLd && <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />}

  <Header />

  <main id="main" class="article-detail-page">
    <div class="container container--narrow">

      <!-- パンくず -->
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href={base}>ホーム</a>
        <span aria-hidden="true"> › </span>
        <a href={`${base}articles/`}>読み物</a>
        <span aria-hidden="true"> › </span>
        <span aria-current="page">{article.title}</span>
      </nav>

      <article class="article-body">
        <!-- ヘッダー -->
        <header class="article-header">
          <span class="article-card__category">{article.category}</span>
          <h1 class="article-header__title" set:html={article.title.replace(/\n/g, '<br>')} />
          {article.subtitle && <p class="article-header__subtitle">{article.subtitle}</p>}
          <div class="article-header__meta">
            <time datetime={article.published_at}>{date}</time>
            <span>約{article.reading_time}分で読める</span>
          </div>
          <div class="article-header__thumb" aria-hidden="true">{article.thumbnail_emoji}</div>
          <p class="article-header__lead">{article.lead}</p>
        </header>

        <!-- 本文 -->
        <div class="article-content" set:html={bodyHtml} />

        <!-- 参考文献 -->
        {article.references && article.references.length > 0 && (
          <footer class="article-references">
            <h3 class="article-references__title">参考文献</h3>
            <ul class="article-references__list">
              {article.references.map((ref: string) => <li>{ref}</li>)}
            </ul>
          </footer>
        )}

        <!-- 関連レシピ -->
        {article.related_recipe_id && (
          <div class="article-related">
            <p class="article-related__label">📌 関連レシピ</p>
            <a href={`${base}recipes/${article.related_recipe_id}/`} class="btn btn--primary">このレシピを見る →</a>
          </div>
        )}

        <!-- タグ -->
        <div class="article-tags">
          {article.tags.map((tag: string) => (
            <a href={tagToUrl(tag)} class="article-tag">{tag}</a>
          ))}
        </div>
      </article>

      <!-- 関連読み物 -->
      {relatedArticles.length > 0 && (
        <section class="related-articles">
          <h2 class="related-articles__title">あわせて読みたい</h2>
          <div class="related-articles__grid">
            {relatedArticles.map((ra: any) => {
              const raDate = ra.published_at.replace(/-/g, '.').slice(2);
              return (
                <a href={`${base}articles/${ra.id}/`} class="related-article-card">
                  <div class="related-article-card__emoji" aria-hidden="true">{ra.thumbnail_emoji}</div>
                  <div class="related-article-card__body">
                    <span class="related-article-card__category">{ra.category}</span>
                    <h3 class="related-article-card__title">{ra.title}</h3>
                    <p class="related-article-card__lead">{ra.lead.slice(0, 60)}…</p>
                    <time class="related-article-card__date" datetime={ra.published_at}>{raDate}</time>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <!-- 戻るリンク -->
      <div style="text-align:center; margin: var(--space-2xl) 0">
        <a href={`${base}articles/`} class="btn btn--outline">← 読み物一覧へ戻る</a>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>
