---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getAllRecipes } from '../data/recipes';

const base = import.meta.env.BASE_URL;
const allRecipes = getAllRecipes();
const latest = [...allRecipes]
  .sort((a, b) => b.meta.created_at.localeCompare(a.meta.created_at))
  .slice(0, 6);

// 地域ごとのレシピ数を集計（ヒートマップ用）
const regionRecipeCount: Record<string, number> = {};
for (const r of allRecipes) {
  const area = r.region?.area ?? '';
  if (area) regionRecipeCount[area] = (regionRecipeCount[area] ?? 0) + 1;
}

// タイムマシン用：全レシピIDの配列
const recipeIds = allRecipes.map((r: any) => r.id);
// タイムマシン用：画像ありレシピのみ（フラッシュ演出用）
const recipesWithImages = allRecipes
  .filter((r: any) => r.photos?.main)
  .map((r: any) => ({ id: r.id, img: r.photos.main }));

const grandmaTags = [
  { label: 'コトコト煮物おばあちゃん', tag: '煮物' },
  { label: '毎日ごはんおばあちゃん', tag: '日常のごはん' },
  { label: '山菜採りおばあちゃん', tag: '山菜' },
  { label: 'お正月おばあちゃん', tag: 'お正月' },
  { label: '郷土料理おばあちゃん', tag: '郷土料理' },
  { label: 'お惣菜名人', tag: '家庭料理' },
  { label: '常備菜の達人', tag: '常備菜' },
  { label: '保存食おばあちゃん', tag: '保存食' },
  { label: '春の味覚おばあちゃん', tag: '春の味覚' },
];

const categories = [
  { img: `${base}assets/images/categories/shirumono.png`, label: '汁物' },
  { img: `${base}assets/images/categories/shusai.png`,   label: '主菜' },
  { img: `${base}assets/images/categories/fukusai.png`,   label: '副菜' },
  { img: `${base}assets/images/categories/tsukemono.png`, label: '漬物' },
  { img: `${base}assets/images/categories/gohanmono.png`, label: 'ご飯もの' },
  { img: `${base}assets/images/categories/oyatsu.png`,    label: 'おやつ' },
];

const regionEmoji: Record<string, string> = {
  hokkaido: '🦀', tohoku: '🍎', kanto: '🍜', hokuriku: '🦀',
  koshinetsu: '⛰️', tokai: '🏯', kinki: '🦌', chugoku: '🐙',
  shikoku: '🍊', kyushu: '🌋',
};
const regionLabels: Record<string, string> = {
  hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
  koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
  shikoku: '四国', kyushu: '九州・沖縄',
};
---

<BaseLayout
  title="おばあちゃんのレシピ | 全国のおばあちゃんの手料理が集まる文化メディア"
  description="もう一度たべたいのに、作り方がわからない味がある。全国のおばあちゃんの手料理が集まる文化メディア。"
>
  <Header />

  <main id="main" class="home">

    <!-- ヒーローセクション -->
    <section class="hero" aria-label="キャッチコピーと検索">
      <div class="hero__bg" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__ripple" aria-hidden="true"></div>
      <div class="hero__content">
        <h1 class="hero__title">
          <span class="hero__line" style="--line-i:0">その一口で、</span><br />
          <span class="hero__line" style="--line-i:1">私たちは過去へ旅をする。</span>
        </h1>
        <p class="hero__lead">
          <span class="hero__line" style="--line-i:2">レシピは単なる作り方じゃない。</span><br />
          <span class="hero__line" style="--line-i:3">誰かの暮らしと愛情の記録だ。</span><br />
          <span class="hero__line" style="--line-i:4">使い込まれた鍋の音、</span><br />
          <span class="hero__line" style="--line-i:5">まな板の傷、台所の匂い。</span><br />
          <span class="hero__line" style="--line-i:6">これは、日本中の</span><br />
          <span class="hero__line" style="--line-i:7">「あの日の食卓」を次世代へつなぐ、</span><br />
          <span class="hero__line" style="--line-i:8">最も温かいタイムマシン。</span>
        </p>
        <!-- 検索はヘッダーに集約 -->
      </div>
    </section>

    <div class="hero__divider" aria-hidden="true"><div class="hero__divider-line"></div></div>

    <!-- 新着レシピ -->
    <section class="home__latest" aria-labelledby="latest-heading">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <h2 id="latest-heading" class="section-title">届いたばかりの味</h2>
        </div>
        <div class="recipe-grid recipe-grid--3">
          {latest.map((recipe) => <RecipeCard recipe={recipe} />)}
        </div>
        <div class="section-footer">
          <a href={`${base}recipes/`} class="btn btn--outline" data-cta="view-all-recipes">すべてのレシピを見る</a>
        </div>
      </div>
    </section>

    <!-- wave -->
    <div class="wave-divider wave-divider--cream-to-green">
      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C240,40 480,0 720,20 C960,40 1200,0 1440,20 L1440,40 L0,40 Z" fill="#F5F3EF"/>
      </svg>
    </div>

    <!-- おばあちゃんから探す / レシピから探す -->
    <section class="home__explore" aria-labelledby="explore-heading">
      <div class="container">
        <div class="explore-tabs">
          <button class="explore-tab explore-tab--active" data-tab="grandma">
            おばあちゃんから探す
          </button>
          <button class="explore-tab" data-tab="recipe">
            カテゴリーから探す
          </button>
        </div>

        <div class="explore-panel" id="panel-grandma">
          <div class="hashtag-cloud">
            {grandmaTags.map(({ label, tag }) => (
              <a href={`${base}recipes/?tag=${encodeURIComponent(tag)}`} class="hashtag-btn" data-cta="hashtag-filter">{label}</a>
            ))}
          </div>
        </div>

        <div class="explore-panel" id="panel-recipe" style="display:none">
          <div class="category-grid">
            {categories.map((c) => (
              <a href={`${base}recipes/?category=${encodeURIComponent(c.label)}`} class="category-btn animate-on-scroll" data-cta="category-filter">
                <img class="category-btn__img" src={c.img} alt={c.label} loading="lazy" />
                <span class="category-btn__label">{c.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- wave -->
    <div class="wave-divider wave-divider--green-to-blue">
      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C240,0 480,40 720,20 C960,0 1200,40 1440,20 L1440,40 L0,40 Z" fill="#FAFAF8"/>
      </svg>
    </div>

    <!-- 地域で探す（マップ風） -->
    <section class="home__regions-map" aria-labelledby="regions-heading">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <h2 id="regions-heading" class="section-title">土地の記憶をたどる</h2>
        </div>
        <div class="japan-map-container">
          <div class="japan-map-wrapper" id="japan-map-wrapper">
            <!-- SVG will be loaded here via fetch -->
          </div>
          <div class="japan-map-tooltip" id="map-tooltip" style="display:none"></div>
        </div>
        <div class="section-footer">
          <a href={`${base}regions/`} class="btn btn--outline" data-cta="view-all-regions">地域一覧をすべて見る</a>
        </div>
      </div>
    </section>

    <!-- wave -->
    <div class="wave-divider wave-divider--blue-to-warm">
      <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C240,40 480,0 720,20 C960,40 1200,0 1440,20 L1440,40 L0,40 Z" fill="#F5F3EF"/>
      </svg>
    </div>

    <!-- タイムマシンセクション -->
    <section class="home__timemachine" aria-labelledby="timemachine-heading">
      <div class="container" style="text-align:center; padding: 5rem 1rem;">
        <h2 id="timemachine-heading" style="font-family:var(--font-serif); font-size:clamp(1.5rem,3vw,2rem); font-weight:400; color:var(--color-text-primary); margin-bottom:1.5rem; letter-spacing:0.05em;">どこかの食卓へ</h2>
        <p style="font-family:var(--font-serif); font-size:0.95rem; color:var(--color-text-muted); line-height:2; margin-bottom:2.5rem;">
          何が出てくるかはわからない。<br />
          ランダムに、誰かの記憶の味に出会う。
        </p>
        <div class="tm-btn-wrapper">
          <a href="#" id="timemachine-btn" class="btn btn--outline tm-btn-combined" data-cta="timemachine" style="padding:1rem 3.5rem; font-family:var(--font-sans); font-size:0.8rem; letter-spacing:0.15em;">
            <span class="tm-clock-icon" aria-hidden="true"></span>
            タイムマシンに乗る
          </a>
          <span class="tm-gogogo tm-gogogo--1" aria-hidden="true">ゴゴゴゴ…</span>
          <span class="tm-gogogo tm-gogogo--2" aria-hidden="true">ゴゴゴ…</span>
          <span class="tm-gogogo tm-gogogo--3" aria-hidden="true">ゴ ゴ ゴ</span>
        </div>
      </div>
    </section>

    <!-- サービスの想い -->
    <section class="home__about" aria-labelledby="about-heading">
      <div class="container">
        <div class="about-block animate-on-scroll">
          <div class="about-block__deco" aria-hidden="true"><img src={`${base}assets/images/grandma-icon.png`} alt="" class="about-block__deco-img" /></div>
          <h2 id="about-heading" class="about-block__title">この活動について</h2>
          <p class="about-block__text">
            計量カップは使わない。<br />
            タイマーも使わない。
          </p>
          <p class="about-block__text">
            「だいたいこのくらい」と<br />
            手のひらで量り、<br />
            「昔からこうやってきた」と<br />
            火加減を調整する。
          </p>
          <p class="about-block__text">
            その曖昧さの中に、<br />
            何十年もかけて磨かれた知恵がある。
          </p>
          <p class="about-block__text">
            残したいのはレシピじゃない。<br />
            一緒に食卓を囲んだ、あの時間。
          </p>
          <a href={base + 'support/'} class="about-block__btn" data-cta="about">about</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- タブ切り替え・地図読み込みJS -->
  <script type="application/json" id="recipe-images-data" set:html={JSON.stringify(recipesWithImages)}></script>
  <script define:vars={{ regionRecipeCount, base, recipeIds }}>
    // タブ切り替え
    document.querySelectorAll('.explore-tab').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.explore-tab').forEach((b) => b.classList.remove('explore-tab--active'));
        btn.classList.add('explore-tab--active');
        const tab = btn.dataset.tab;
        document.querySelectorAll('.explore-panel').forEach((p) => {
          p.style.display = p.id === `panel-${tab}` ? '' : 'none';
        });
      });
    });

    // 地図SVGの読み込みとヒートマップ
    const classToRegion = {
      'hokkaido': 'hokkaido',
      'tohoku': 'tohoku',
      'kanto': 'kanto',
      'ishikawa': 'hokuriku', 'toyama': 'hokuriku', 'fukui': 'hokuriku',
      'niigata': 'koshinetsu', 'nagano': 'koshinetsu', 'yamanashi': 'koshinetsu',
      'aichi': 'tokai', 'gifu': 'tokai', 'shizuoka': 'tokai', 'mie': 'tokai',
      'kinki': 'kinki',
      'chugoku': 'chugoku',
      'shikoku': 'shikoku',
      'kyushu': 'kyushu', 'kyushu-okinawa': 'kyushu',
    };
    const regionNames = {
      hokkaido: '北海道', tohoku: '東北', kanto: '関東', hokuriku: '北陸',
      koshinetsu: '甲信越', tokai: '東海', kinki: '近畿', chugoku: '中国',
      shikoku: '四国', kyushu: '九州・沖縄',
    };

    function getColorForCount(count) {
      if (count === 0) return '#E8DCC8';
      if (count <= 2) return '#D4B896';
      if (count <= 5) return '#C49A6C';
      if (count <= 10) return '#A0703C';
      return '#7D4E1E';
    }

    const mapWrapper = document.getElementById('japan-map-wrapper');
    const mapTooltip = document.getElementById('map-tooltip');
    if (mapWrapper) {
      fetch(base + 'assets/japan-map.svg')
        .then(res => res.text())
        .then(svgText => {
          mapWrapper.innerHTML = svgText;
          const svgEl = mapWrapper.querySelector('svg');
          if (!svgEl) return;

          const prefGroups = svgEl.querySelectorAll('.prefecture');
          for (const g of prefGroups) {
            const classes = (g.className.baseVal || g.getAttribute('class') || '').split(/\s+/);
            let regionCode = null;
            for (const [cls, code] of Object.entries(classToRegion)) {
              if (classes.includes(cls)) { regionCode = code; break; }
            }
            if (!regionCode) continue;

            const count = regionRecipeCount[regionCode] ?? 0;
            const color = getColorForCount(count);

            g.setAttribute('fill', color);
            g.setAttribute('stroke', '#fff');
            g.setAttribute('stroke-width', '0.8');
            g.querySelectorAll('polygon, path').forEach(s => {
              s.setAttribute('fill', color);
              s.setAttribute('stroke', '#fff');
              s.setAttribute('stroke-width', '0.8');
            });

            g.addEventListener('mouseenter', () => {
              const name = regionNames[regionCode] ?? regionCode;
              mapTooltip.innerHTML = `<strong>${name}</strong>${count}件のレシピ`;
              mapTooltip.style.display = 'block';
            });
            g.addEventListener('mousemove', (e) => {
              mapTooltip.style.left = (e.clientX + 12) + 'px';
              mapTooltip.style.top = (e.clientY + 12) + 'px';
            });
            g.addEventListener('mouseleave', () => {
              mapTooltip.style.display = 'none';
            });

            g.style.cursor = 'pointer';
            g.addEventListener('click', () => {
              window.location.href = `/recipes?region=${regionCode}`;
            });
          }
        })
        .catch(err => console.warn('Japan map SVG の読み込みに失敗しました:', err));
    }

    // スクロールアニメーション
    const animatedEls = document.querySelectorAll('.animate-on-scroll');
    if (animatedEls.length > 0 && 'IntersectionObserver' in window) {
      document.documentElement.classList.add('js-scroll-ready');
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      }, { threshold: 0.1 });
      animatedEls.forEach((el) => observer.observe(el));
    } else {
      animatedEls.forEach((el) => el.classList.add('is-visible'));
    }

    // タイムマシンボタン: 料理フラッシュ → ランダムレシピへ遷移
    const recipesWithImgs = JSON.parse(document.getElementById('recipe-images-data')?.textContent || '[]');
    const tmBtn = document.getElementById('timemachine-btn');
    if (tmBtn) {
      tmBtn.addEventListener('click', (e) => {
        e.preventDefault();
        // 画像ありレシピがあればそこから選ぶ、なければ全レシピから選ぶ
        const pool = recipesWithImgs.length > 0 ? recipesWithImgs : recipeIds.map(id => ({ id, img: null }));
        const pick = pool[Math.floor(Math.random() * pool.length)];
        const randomId = pick.id;

        // 画像パスを決定
        const imgSrc = pick.img
          ? base + pick.img
          : null;

        // オーバーレイを生成
        const overlay = document.createElement('div');
        overlay.className = 'tm-overlay';
        overlay.innerHTML = `
          <div class="tm-overlay__bg"></div>
          ${imgSrc ? `<div class="tm-overlay__food"><img src="${imgSrc}" alt="" /></div>` : ''}
          <div class="tm-overlay__flash"></div>
        `;
        document.body.appendChild(overlay);
        overlay.offsetHeight;
        overlay.classList.add('is-active');

        // フラッシュが白く覆ったタイミングでページ遷移
        setTimeout(() => {
          const flash = overlay.querySelector('.tm-overlay__flash');
          if (flash) { flash.style.animation = 'none'; flash.style.opacity = '1'; }
          window.location.href = base + 'recipes/' + randomId + '/';
        }, 1600);
      });
    }
  </script>
</BaseLayout>
