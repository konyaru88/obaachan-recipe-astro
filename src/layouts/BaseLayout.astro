---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage = '/assets/images/grandma-icon.png',
  ogType = 'website',
  canonicalUrl,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://www.obaachan-recipe.com';
const currentUrl = canonicalUrl ?? siteUrl + Astro.url.pathname;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : siteUrl + ogImage;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <!-- SEO -->
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />
  <link rel="icon" type="image/png" href={`${base}assets/images/grandma-icon.png`} />

  <!-- OGP -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:site_name" content="おばあちゃんのレシピ" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />
  <meta name="twitter:site" content="@obaachan_recipe" />

  <!-- Google Search Console -->
  <meta name="google-site-verification" content="o8CGRwi6p8d6FL8x-uHhxRCxZVuSK3pnas4yYmXAnJY" />

  <!-- Google Analytics (GA4) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-EVYD2MEX67"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EVYD2MEX67');
  </script>

  <!-- GA4 Custom Events (イベント委譲で一括処理・二重発火なし) -->
  <script is:inline>
  (function() {
    var isDev = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
    document.addEventListener('click', function(e) {
      var ctaEl = e.target.closest('[data-cta]');
      if (ctaEl) {
        var params = {
          cta_name: ctaEl.getAttribute('data-cta'),
          page_location: location.href,
          transport_type: 'beacon'
        };
        if (isDev) console.log('[GA4] cta_click', params);
        gtag('event', 'cta_click', params);

        if (ctaEl.getAttribute('data-cta') === 'recipe-view') {
          var rp = {
            recipe_name: ctaEl.getAttribute('data-recipe-name') || '',
            recipe_id: ctaEl.getAttribute('data-recipe-id') || '',
            region: ctaEl.getAttribute('data-region') || '',
            click_source: location.pathname,
            transport_type: 'beacon'
          };
          if (isDev) console.log('[GA4] recipe_click', rp);
          gtag('event', 'recipe_click', rp);
        }
      }

      var outEl = e.target.closest('[data-outbound]');
      if (outEl) {
        var op = {
          link_url: outEl.href || '',
          link_text: outEl.getAttribute('data-outbound'),
          page_location: location.href,
          transport_type: 'beacon'
        };
        if (isDev) console.log('[GA4] outbound_click', op);
        gtag('event', 'outbound_click', op);
      }
    });
  })();
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@400;600;700&family=Kaisei+Tokumin:wght@400;700&family=Zen+Maru+Gothic:wght@400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- Global CSS -->
  <link rel="stylesheet" href={`${base}styles/global.css`} />

  <!-- Page-specific structured data slot -->
  <slot name="head" />
</head>
<body data-base={base}>
  <slot />
</body>
</html>
